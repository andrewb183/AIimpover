FROM python:3.11-slim

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    OUTLINE_AUTO_START=1 \
    OUTLINE_INTERVAL_SECONDS=300 \
    OUTLINE_REQUEST_TIMEOUT_SECONDS=120 \
    OUTLINE_QUEUE_PAUSE_THRESHOLD=10 \
    OUTLINE_QUEUE_RESUME_THRESHOLD=1 \
    CONFIG_PATH=/etc/swarm-config/config.json \
    OLLAMA_QWEN_ENDPOINT=http://ollama-qwen:11435 \
    OLLAMA_DEEPSEEK_ENDPOINT=http://ollama-deepseek:11437

RUN apt-get update -qq \
    && apt-get install -y --no-install-recommends python3-tk xvfb \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /workspace/create

RUN python -m pip install --no-cache-dir -q requests redis psycopg2-binary ujson python-dotenv

CMD ["bash", "-lc", "xvfb-run -a -s '-screen 0 1280x720x24' python /workspace/create/outline"]
