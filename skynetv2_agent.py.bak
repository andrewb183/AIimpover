def _safe_int(value: Any, default: int) -> int:
    try:
        return int(value)
    except Exception:
        return int(default)


def send_email(subject: str, body: str, to_email: str, attachments: Optional[list[Any]] = None) -> bool:
    smtp_user = os.environ.get("GMAIL_USER") or os.environ.get("SMTP_USER")
    smtp_password = (
        os.environ.get("GMAIL_APP_PASSWORD")
        or os.environ.get("SMTP_PASSWORD")
        or os.environ.get("SMTP_PASS")
    )
    smtp_host = os.environ.get("SMTP_HOST", "smtp.gmail.com")
    smtp_port = int(os.environ.get("SMTP_PORT", "587"))
    smtp_use_tls = os.environ.get("SMTP_USE_TLS", "1") != "0"
    from_addr = os.environ.get("SMTP_FROM", smtp_user or "skynetv2@localhost")

    if not smtp_user or not smtp_password or not to_email:
        return False

    if attachments:
        msg = MIMEMultipart()
        msg.attach(MIMEText(body, "plain", "utf-8"))
        for item in attachments:
            path = Path(str(item))
            if not path.exists() or not path.is_file():
                continue
            try:
                payload = path.read_bytes()
                part = MIMEApplication(payload, Name=path.name)
                part["Content-Disposition"] = f'attachment; filename="{path.name}"'
                msg.attach(part)
            except Exception as exc:
                log_action(f"Failed to attach file '{path}': {exc}", level="warning")
    else:
        msg = MIMEText(body, "plain", "utf-8")

    msg["Subject"] = subject
    msg["From"] = from_addr
    msg["To"] = to_email

    try:
        with smtplib.SMTP(smtp_host, smtp_port, timeout=60) as server:
            if smtp_use_tls:
                server.starttls()
            server.login(smtp_user, smtp_password)
            server.sendmail(from_addr, [to_email], msg.as_string())
        return True
    except Exception as exc:
        error_message = str(exc)
        now = time.time()
        last_logged = _email_error_last_logged.get(error_message, 0)
        if now - last_logged >= 300:
            _email_error_last_logged[error_message] = now
            log_action(f"Failed to send email to {to_email}: {error_message}", level="warning")
        return False


def _create_simple_docx(lines: list[str], output_path: Path) -> None:
    output_path.parent.mkdir(parents=True, exist_ok=True)
    paragraphs = []
    for line in lines:
        text = xml_escape(str(line or ""))
        paragraphs.append(
            "<w:p><w:r><w:t xml:space=\"preserve\">" + text + "</w:t></w:r></w:p>"
        )
    document_xml = (
        "<?xml version=\"1.0\" encoding=\"UTF-8\" standalone=\"yes\"?>"
        "<w:document xmlns:w=\"http://schemas.openxmlformats.org/wordprocessingml/2006/main\">"
        "<w:body>"
        + "".join(paragraphs)
        + "<w:sectPr><w:pgSz w:w=\"12240\" w:h=\"15840\"/><w:pgMar w:top=\"1440\" w:right=\"1440\" w:bottom=\"1440\" w:left=\"1440\"/></w:sectPr>"
        "</w:body></w:document>"
    )

    with zipfile.ZipFile(output_path, "w", compression=zipfile.ZIP_DEFLATED) as zf:
        zf.writestr(
            "[Content_Types].xml",
            "<?xml version=\"1.0\" encoding=\"UTF-8\"?>"
            "<Types xmlns=\"http://schemas.openxmlformats.org/package/2006/content-types\">"
            "<Default Extension=\"rels\" ContentType=\"application/vnd.openxmlformats-package.relationships+xml\"/>"
            "<Default Extension=\"xml\" ContentType=\"application/xml\"/>"
            "<Override PartName=\"/word/document.xml\" ContentType=\"application/vnd.openxmlformats-officedocument.wordprocessingml.document.main+xml\"/>"
            "</Types>",
        )
        zf.writestr(
            "_rels/.rels",
            "<?xml version=\"1.0\" encoding=\"UTF-8\"?>"
            "<Relationships xmlns=\"http://schemas.openxmlformats.org/package/2006/relationships\">"
            "<Relationship Id=\"rId1\" Type=\"http://schemas.openxmlformats.org/officeDocument/2006/relationships/officeDocument\" Target=\"word/document.xml\"/>"
            "</Relationships>",
        )
        zf.writestr("word/document.xml", document_xml)


def load_network_scan_policy() -> dict:
    policy = read_json(NETWORK_SCAN_POLICY_FILE)
    if not isinstance(policy, dict):
        policy = {}
    policy.setdefault("enable_port_scan", True)
    policy.setdefault("port_scan_interval_sec", 1800)
    policy.setdefault("port_scan_ports", [22, 80, 443])
    policy.setdefault("port_scan_timeout_ms", 250)
    policy.setdefault("port_scan_max_hosts_per_network", 16)
    policy.setdefault("network_scan_report_dir", str(BASE_DIR / "network_reports"))
    policy.setdefault("network_scan_email_enabled", True)
    policy.setdefault("network_scan_daily_email_interval_sec", 86400)
    policy.setdefault("network_scan_email_to", ADMIN_EMAIL)
    write_json(NETWORK_SCAN_POLICY_FILE, policy)
    return policy


def _get_local_ipv4() -> str:
    try:
        with socket.socket(socket.AF_INET, socket.SOCK_DGRAM) as sock:
            sock.connect(("8.8.8.8", 80))
            ip = sock.getsockname()[0]
            if ip and ip != "127.0.0.1":
                return ip
    except Exception:
        pass
    return "127.0.0.1"


def _scan_open_ports(ip: str, ports: list[int], timeout_sec: float) -> list[int]:
    open_ports: list[int] = []
    for port in ports:
        try:
            with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as sock:
                sock.settimeout(timeout_sec)
                if sock.connect_ex((ip, int(port))) == 0:
                    open_ports.append(int(port))
        except Exception:
            continue
    return open_ports


def _render_network_report_lines(report: dict[str, Any]) -> list[str]:
    lines: list[str] = []
    lines.append("Skynetv2 Network Scan Report")
    lines.append(f"Generated: {report.get('generated_at', '')}")
    lines.append(f"Local IP: {report.get('local_ip', 'unknown')}")
    lines.append(f"Ports tested: {', '.join(str(p) for p in report.get('ports_tested', []))}")
    lines.append(
        f"Totals: hosts_scanned={report.get('hosts_scanned_total', 0)} hosts_with_open_ports={report.get('hosts_with_open_ports_total', 0)}"
    )
    lines.append("")
    lines.append("Hosts with open ports:")
    for item in report.get("hosts", []):
        lines.append(f"- {item.get('ip')}: {', '.join(str(p) for p in item.get('open_ports', []))}")
    if not report.get("hosts"):
        lines.append("- none")
    return lines


def run_network_port_scan_and_email_report(policy: dict[str, Any] | None = None) -> dict[str, Any]:
    global _last_network_port_scan_at
    global _last_network_scan_daily_email_at

    policy = policy or load_network_scan_policy()
    if not bool(policy.get("enable_port_scan", True)):
        return {"status": "disabled"}

    now = time.time()
    interval = max(60, _safe_int(policy.get("port_scan_interval_sec", 1800), 1800))
    if now - _last_network_port_scan_at < interval:
        return {"status": "throttled", "next_in_sec": int(interval - (now - _last_network_port_scan_at))}

    ports_raw = policy.get("port_scan_ports", [22, 80, 443])
    ports = [p for p in [_safe_int(v, 0) for v in ports_raw if isinstance(v, (int, str))] if 1 <= p <= 65535]
    if not ports:
        ports = [22, 80, 443]

    timeout_sec = max(0.05, min(1.5, float(_safe_int(policy.get("port_scan_timeout_ms", 250), 250)) / 1000.0))
    max_hosts = max(1, _safe_int(policy.get("port_scan_max_hosts_per_network", 16), 16))

    local_ip = _get_local_ipv4()
    targets = ["127.0.0.1", local_ip]
    try:
        network = ipaddress.ip_network(f"{local_ip}/24", strict=False)
        for host in network.hosts():
            host_ip = str(host)
            if host_ip not in targets:
                targets.append(host_ip)
            if len(targets) >= max_hosts:
                break
    except Exception:
        pass

    hosts_with_open_ports: list[dict[str, Any]] = []
    scanned = 0
    for ip in targets[:max_hosts]:
        scanned += 1
        open_ports = _scan_open_ports(ip, ports, timeout_sec)
        if open_ports:
            hosts_with_open_ports.append({"ip": ip, "open_ports": open_ports})

    report = {
        "status": "ok",
        "generated_at": datetime.now().isoformat(),
        "local_ip": local_ip,
        "ports_tested": ports,
        "hosts_scanned_total": scanned,
        "hosts_with_open_ports_total": len(hosts_with_open_ports),
        "hosts": hosts_with_open_ports,
    }

    report_dir = Path(str(policy.get("network_scan_report_dir", BASE_DIR / "network_reports")))
    report_name = f"network_scan_{datetime.now().strftime('%Y%m%d_%H%M%S')}.docx"
    report_path = report_dir / report_name
    try:
        lines = _render_network_report_lines(report)
        _create_simple_docx(lines, report_path)
        report["report_path"] = str(report_path)
    except Exception as exc:
        report["report_error"] = str(exc)

    email_enabled = bool(policy.get("network_scan_email_enabled", True))
    daily_email_interval = max(300, _safe_int(policy.get("network_scan_daily_email_interval_sec", 86400), 86400))
    recipient = str(policy.get("network_scan_email_to", "")).strip() or ADMIN_EMAIL
    should_send = (now - _last_network_scan_daily_email_at) >= daily_email_interval
    if email_enabled and ENABLE_EMAIL_REPORTS and recipient and report.get("report_path") and should_send:
        summary = (
            "Skynetv2 Network Scan Summary\n\n"
            f"Generated: {report.get('generated_at')}\n"
            f"Local IP: {report.get('local_ip')}\n"
            f"Hosts scanned: {report.get('hosts_scanned_total', 0)}\n"
            f"Hosts with open ports: {report.get('hosts_with_open_ports_total', 0)}\n"
            f"Ports tested: {', '.join(str(p) for p in report.get('ports_tested', []))}\n"
        )
        sent = send_email(
            f"Skynetv2 Network Report - {datetime.now().strftime('%Y-%m-%d')}",
            summary,
            recipient,
            attachments=[report["report_path"]],
        )
        report["email_sent"] = bool(sent)
        if sent:
            _last_network_scan_daily_email_at = now
    else:
        report["email_sent"] = False

    _last_network_port_scan_at = now

    def mutate(state):
        stats = state.setdefault("synthesis_stats", {})
        stats["latest_network_scan_report"] = {
            "generated_at": report.get("generated_at", ""),
            "local_ip": report.get("local_ip", ""),
            "hosts_scanned_total": report.get("hosts_scanned_total", 0),
            "hosts_with_open_ports_total": report.get("hosts_with_open_ports_total", 0),
            "report_path": report.get("report_path", ""),
            "email_sent": bool(report.get("email_sent", False)),
        }

    update_registry_state(mutate)
    return report


def maybe_send_weekly_docx_email(policy: dict[str, Any] | None = None) -> dict[str, Any]:
    """Every Friday, email all .docx files generated that week, then delete them after send."""
    global _last_weekly_docx_email_at

    policy = policy or load_network_scan_policy()
    if not bool(policy.get("network_scan_email_enabled", True)):
        return {"status": "disabled"}

    now = time.time()
    today = datetime.now()

    # Only trigger on Friday (weekday index 4) and guard against double-send within 23 h
    if today.weekday() != 4:
        return {"status": "not_friday", "weekday": today.weekday()}
    if now - _last_weekly_docx_email_at < 82800:  # ~23 h de-dupe guard
        return {"status": "already_sent_today"}

    report_dir = Path(str(policy.get("network_scan_report_dir", BASE_DIR / "network_reports")))
    if not report_dir.exists():
        return {"status": "no_report_dir"}

    week_ago = now - 7 * 86400
    docx_files = sorted(
        [p for p in report_dir.glob("*.docx") if p.stat().st_mtime >= week_ago],
        key=lambda p: p.stat().st_mtime,
    )

    if not docx_files:
        return {"status": "no_files_this_week"}

    smtp_user = os.environ.get("GMAIL_USER") or os.environ.get("SMTP_USER", "")
    recipient = str(policy.get("network_scan_email_to", "")).strip() or ADMIN_EMAIL or smtp_user
    if not recipient:
        return {"status": "no_recipient"}

    summary = (
        f"Skynetv2 Weekly Network Scan Report Bundle\n\n"
        f"Week ending: {today.strftime('%Y-%m-%d (%A)')}\n"
        f"Reports attached: {len(docx_files)}\n\n"
        "Files:\n" + "\n".join(f"  - {p.name}" for p in docx_files)
    )

    sent = send_email(
        f"Skynetv2 Weekly DOCX Reports - {today.strftime('%Y-%m-%d')}",
        summary,
        recipient,
        attachments=[str(p) for p in docx_files],
    )

    deleted: list[str] = []
    if sent:
        _last_weekly_docx_email_at = now
        for p in docx_files:
            try:
                p.unlink()
                deleted.append(p.name)
            except Exception as exc:
                log_action(f"weekly_docx_email: could not delete {p.name}: {exc}", level="warning")

    result = {
        "status": "sent" if sent else "send_failed",
        "files_found": len(docx_files),
        "email_sent": bool(sent),
        "recipient": recipient,
        "deleted": deleted,
    }
    log_action(f"weekly_docx_email: {result}")
    return result


