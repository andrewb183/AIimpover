def ensure_local_user_auth_bootstrap(policy: dict):
    """Auto-generated docstring."""
    if not policy.get("user_auth_autobootstrap_enabled", True):
        return False

    jwt_secret = os.environ.get("JWT_SECRET", "").strip()
    oauth_client = os.environ.get("OAUTH_CLIENT_ID", "").strip()
    if jwt_secret and oauth_client:
        return False

    auth_file = Path(str(policy.get("user_auth_secret_file", BASE_DIR / ".auth_bootstrap.env")))
    auth_file.parent.mkdir(parents=True, exist_ok=True)

    existing = {}
    if auth_file.exists():
        try:
            for raw_line in auth_file.read_text(encoding="utf-8").splitlines():
                line = raw_line.strip()
                if not line or line.startswith("#") or "=" not in line:
                    continue
                key, value = line.split("=", 1)
                existing[key.strip()] = value.strip()
        except Exception:
            existing = {}

    if not jwt_secret:
        jwt_secret = existing.get("JWT_SECRET", "").strip() or secrets.token_urlsafe(48)
    if not oauth_client:
        oauth_client = existing.get("OAUTH_CLIENT_ID", "").strip() or f"local-skynet-{secrets.token_hex(12)}"

    os.environ["JWT_SECRET"] = jwt_secret
    os.environ["OAUTH_CLIENT_ID"] = oauth_client

    payload = [
        "# Auto-generated by skynetv2 local auth bootstrap",
        f"JWT_SECRET={jwt_secret}",
        f"OAUTH_CLIENT_ID={oauth_client}",
        f"GENERATED_AT={datetime.now().isoformat()}",
    ]
    try:
        auth_file.write_text("\n".join(payload) + "\n", encoding="utf-8")
        log_action(f"Local user_auth bootstrap ensured via {auth_file}.")
        return True
    except Exception as exc:
        log_action(f"Failed to persist local auth bootstrap: {exc}")
        return False

def load_self_heal_outcomes():
    """Auto-generated docstring."""
    data = read_json(SELF_HEAL_OUTCOMES_FILE)
    if not isinstance(data, dict):
        data = {}
    data.setdefault("pending", [])
    data.setdefault("evaluated", [])
    data.setdefault("stats", {})
    stats = data["stats"]
    stats.setdefault("intents_total", 0)
    stats.setdefault("evaluated_total", 0)
    stats.setdefault("success_total", 0)
    stats.setdefault("failure_total", 0)
    stats.setdefault("last_tuned_at", "")
    write_json(SELF_HEAL_OUTCOMES_FILE, data)
    return data

def save_self_heal_outcomes(data):
    """Auto-generated docstring."""
    write_json(SELF_HEAL_OUTCOMES_FILE, data)

def _get_deployment_db_path() -> Path:
    """Return path to SQLite approval database."""
    return BASE_DIR / "deployment_approvals.db"

def _init_deployment_approvals_db() -> bool:
    """Initialize SQLite database schema if not exists. Returns True if initialized or exists."""
    try:
        import sqlite3
    except ImportError:
        log_action("sqlite3 not available; deployment approval database disabled")
        return False

    db_path = _get_deployment_db_path()
    db_path.parent.mkdir(parents=True, exist_ok=True)

    try:
        conn = sqlite3.connect(str(db_path), timeout=10.0)
        cursor = conn.cursor()

        # Create table if not exists
        cursor.execute("""
            CREATE TABLE IF NOT EXISTS approved_devices (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                device_name TEXT NOT NULL UNIQUE,
                ip_address TEXT NOT NULL,
                mac_address TEXT,
                os_type TEXT,
                approved INTEGER DEFAULT 0,
                approval_date TEXT,
                install_ready INTEGER DEFAULT 0,
                install_attempted_at TEXT,
                install_status TEXT,
                install_error TEXT,
                created_at TEXT,
                updated_at TEXT,
                notes TEXT
            )
        """)
        conn.commit()
        conn.close()
        return True
    except Exception as exc:
        log_action(f"Failed to initialize deployment approvals database: {exc}")
        return False

def add_device_to_deployment_approvals(device_name: str, ip_address: str, os_type: str, mac_address: str = "") -> dict:
    """Add a device to the approval database. Returns result dict."""
    try:
        import sqlite3
    except ImportError:
        return {"status": "error", "reason": "sqlite3_unavailable"}

    if not _init_deployment_approvals_db():
        return {"status": "error", "reason": "db_init_failed"}

    db_path = _get_deployment_db_path()
    try:
        conn = sqlite3.connect(str(db_path), timeout=10.0)
        cursor = conn.cursor()

        cursor.execute("""
            INSERT OR REPLACE INTO approved_devices
                (device_name, ip_address, mac_address, os_type, created_at, updated_at)
            VALUES (?, ?, ?, ?, ?, ?)
        """, (
            str(device_name).strip(),
            str(ip_address).strip(),
            str(mac_address).strip(),
            str(os_type).strip(),
            datetime.now().isoformat(),
            datetime.now().isoformat(),
        ))
        conn.commit()
        conn.close()
        return {
            "status": "added",
            "device_name": device_name,
            "ip_address": ip_address,
            "os_type": os_type,
        }
    except Exception as exc:
        return {"status": "error", "reason": str(exc)[:200]}

def approve_device_for_deployment(device_name: str) -> dict:
    """Mark a device as approved (approved=1). Returns result dict."""
    try:
        import sqlite3
    except ImportError:
        return {"status": "error", "reason": "sqlite3_unavailable"}

    if not _init_deployment_approvals_db():
        return {"status": "error", "reason": "db_init_failed"}

    db_path = _get_deployment_db_path()
    try:
        conn = sqlite3.connect(str(db_path), timeout=10.0)
        cursor = conn.cursor()

        cursor.execute("""
            UPDATE approved_devices
            SET approved = 1, approval_date = ?, updated_at = ?
            WHERE device_name = ?
        """, (datetime.now().isoformat(), datetime.now().isoformat(), str(device_name).strip()))

        conn.commit()
        rows_updated = cursor.rowcount
        conn.close()

        return {
            "status": "approved" if rows_updated > 0 else "not_found",
            "device_name": device_name,
            "rows_updated": rows_updated,
        }
    except Exception as exc:
        return {"status": "error", "reason": str(exc)[:200]}

def list_approved_devices_for_deployment() -> dict:
    """Return list of all approved devices (approved=1). Returns dict with status and devices."""
    try:
        import sqlite3
    except ImportError:
        return {"status": "error", "reason": "sqlite3_unavailable", "devices": []}

    if not _init_deployment_approvals_db():
        return {"status": "error", "reason": "db_init_failed", "devices": []}

    db_path = _get_deployment_db_path()
    try:
        conn = sqlite3.connect(str(db_path), timeout=10.0)
        cursor = conn.cursor()

        cursor.execute("""
            SELECT device_name, ip_address, mac_address, os_type, approval_date, install_status, notes
            FROM approved_devices
            WHERE approved = 1
            ORDER BY created_at ASC
        """)
        rows = cursor.fetchall()
        conn.close()

        devices = []
        for row in rows:
            devices.append({
                "device_name": row[0],
                "ip_address": row[1],
                "mac_address": row[2] or "",
                "os_type": row[3] or "unknown",
                "approval_date": row[4] or "",
                "install_status": row[5] or "pending",
                "notes": row[6] or "",
            })

        return {
            "status": "ok",
            "count": len(devices),
            "devices": devices,
        }
    except Exception as exc:
        return {"status": "error", "reason": str(exc)[:200], "devices": []}

def list_all_deployment_devices() -> dict:
    """Return list of ALL devices in approval database (any approval status). For admin review."""
    try:
        import sqlite3
    except ImportError:
        return {"status": "error", "reason": "sqlite3_unavailable", "devices": []}

    if not _init_deployment_approvals_db():
        return {"status": "error", "reason": "db_init_failed", "devices": []}

    db_path = _get_deployment_db_path()
    try:
        conn = sqlite3.connect(str(db_path), timeout=100.0)
        cursor = conn.cursor()

        cursor.execute("""
            SELECT device_name, ip_address, mac_address, os_type, approved, approval_date, install_status, created_at
            FROM approved_devices
            ORDER BY created_at DESC
        """)
        rows = cursor.fetchall()
        conn.close()

        devices = []
        for row in rows:
            devices.append({
                "device_name": row[0],
                "ip_address": row[1],
                "mac_address": row[2] or "",
                "os_type": row[3] or "unknown",
                "approved": bool(row[4]),
                "approval_date": row[5] or "",
                "install_status": row[6] or "pending",
                "created_at": row[7] or "",
            })

        return {
            "status": "ok",
            "count": len(devices),
            "devices": devices,
        }
    except Exception as exc:
        return {"status": "error", "reason": str(exc)[:200], "devices": []}

def update_device_install_status(device_name: str, status: str, error_msg: str = "") -> dict:
    """Update install status for a device. status='success', 'failed', 'in_progress', etc."""
    try:
        import sqlite3
    except ImportError:
        return {"status": "error", "reason": "sqlite3_unavailable"}

    if not _init_deployment_approvals_db():
        return {"status": "error", "reason": "db_init_failed"}

    db_path = _get_deployment_db_path()
    try:
        conn = sqlite3.connect(str(db_path), timeout=100.0)
        cursor = conn.cursor()

        cursor.execute("""
            UPDATE approved_devices
            SET install_status = ?,
                install_attempted_at = ?,
                install_error = ?,
                updated_at = ?
            WHERE device_name = ?
        """, (
            str(status).strip(),
            datetime.now().isoformat(),
            str(error_msg).strip()[:500],
            datetime.now().isoformat(),
            str(device_name).strip(),
        ))

        conn.commit()
        rows_updated = cursor.rowcount
        conn.close()

        return {
            "status": "updated" if rows_updated > 0 else "not_found",
            "device_name": device_name,
            "rows_updated": rows_updated,
        }
    except Exception as exc:
        return {"status": "error", "reason": str(exc)[:200]}

def prepare_install_bundle_for_approved_devices(policy: dict | None = None) -> dict:
    """
    Read all approved devices from database and prepare platform-specific install bundles.
    Returns dict with bundle paths and metadata.

    Layout (pseudocode structure):
    - For each approved device in database
      - Fetch device metadata (IP, OS, device_name)
      - Generate OS-specific install script (Linux: bash, Windows: ps1, macOS: sh)
      - Create bundle directory: bundles/{device_name}_{timestamp}/
      - Write: install.sh (or .ps1 / .command for Windows/macOS)
      - Write: skynetv2_agent.py (target-adjusted)
      - Write: README.md with device-specific instructions
      - Write: manifest.json with checksums
      - Prepare: tar.gz or zip (OS-dependent)
      - Return: {device_name, bundle_path, install_instructions_url}
    """
    result = {
        "status": "starting",
        "bundles_prepared": 0,
        "bundles": [],
        "errors": [],
    }

    approvals = list_approved_devices_for_deployment()
    if approvals.get("status") != "ok":
        result["status"] = "error"
        result["errors"].append(f"Failed to read approvals: {approvals.get('reason')}")
        return result

    devices = approvals.get("devices", [])
    if not devices:
        result["status"] = "no_approved_devices"
        return result

    bundles_dir = BASE_DIR / "deployment_bundles"
    bundles_dir.mkdir(parents=True, exist_ok=True)

    for device in devices:
        device_name = str(device.get("device_name", "unknown")).strip()
        ip_address = str(device.get("ip_address", "unknown")).strip()
        os_type = str(device.get("os_type", "linux")).strip().lower()
        mac_address = str(device.get("mac_address", "")).strip()

        # Create device-specific bundle directory
        timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
        device_bundle_dir = bundles_dir / f"{device_name}_{timestamp}"
        device_bundle_dir.mkdir(parents=True, exist_ok=True)

        bundle_info = {
            "device_name": device_name,
            "ip_address": ip_address,
            "os_type": os_type,
            "mac_address": mac_address,
            "bundle_path": str(device_bundle_dir),
            "files": [],
            "status": "preparing",
            "error": "",
        }

        try:
            # Generate OS-specific install script
            if os_type in ["ubuntu", "debian", "raspbian", "linux"]:
                install_script = _generate_linux_install_script(device_name, ip_address)
                script_path = device_bundle_dir / "install.sh"
            elif os_type in ["windows"]:
                install_script = _generate_windows_install_script(device_name, ip_address)
                script_path = device_bundle_dir / "install.ps1"
            elif os_type in ["macos"]:
                install_script = _generate_macos_install_script(device_name, ip_address)
                script_path = device_bundle_dir / "install.command"
            else:
                install_script = _generate_linux_install_script(device_name, ip_address)
                script_path = device_bundle_dir / "install.sh"

            script_path.write_text(install_script, encoding="utf-8")
            script_path.chmod(0o755)
            bundle_info["files"].append({"name": script_path.name, "type": "install_script"})

            # Copy skynetv2_agent.py
            agent_src = Path(__file__)
            if agent_src.exists():
                agent_dst = device_bundle_dir / "skynetv2_agent.py"
                agent_dst.write_bytes(agent_src.read_bytes())
                bundle_info["files"].append({"name": agent_dst.name, "type": "agent_code"})

            # Create README with device-specific instructions
            readme_content = _generate_bundle_readme(device_name, ip_address, os_type)
            readme_path = device_bundle_dir / "README.md"
            readme_path.write_text(readme_content, encoding="utf-8")
            bundle_info["files"].append({"name": readme_path.name, "type": "instructions"})

            # Create manifest.json
            manifest = {
                "device_name": device_name,
                "device_ip": ip_address,
                "device_os": os_type,
                "mac_address": mac_address,
                "generated_at": datetime.now().isoformat(),
                "bundle_version": "1.0",
                "files": bundle_info["files"],
            }
            manifest_path = device_bundle_dir / "manifest.json"
            write_json(manifest_path, manifest)
            bundle_info["files"].append({"name": manifest_path.name, "type": "manifest"})

            bundle_info["status"] = "prepared"
            result["bundles"].append(bundle_info)
            result["bundles_prepared"] += 1

            update_device_install_status(device_name, "bundle_prepared")

        except Exception as exc:
            bundle_info["status"] = "failed"
            bundle_info["error"] = str(exc)[:200]
            result["errors"].append(f"{device_name}: {str(exc)[:100]}")
            result["bundles"].append(bundle_info)

    result["status"] = "complete"
    result["total_errors"] = len(result["errors"])
    return result

def _generate_linux_install_script(device_name: str, target_ip: str) -> str:
    """Generate bash install script for Linux targets."""
    agent_url = "http://127.0.0.1:14400"  # Placeholder; user configures before deploy
    return f"""#!/bin/bash
# Skynetv2 Auto-Install Script (Linux/Debian/Ubuntu/Raspbian)
# Device: {device_name}
# Target IP: {target_ip}
# Generated: {datetime.now().isoformat()}

set -e

echo "[skynetv2] Installing autonomous agent code..."

# Create installation directory
INSTALL_DIR="/opt/skynetv2"
sudo mkdir -p "$INSTALL_DIR"
sudo chown $USER:$USER "$INSTALL_DIR"

# Copy files
cp skynetv2_agent.py "$INSTALL_DIR/"
cp manifest.json "$INSTALL_DIR/"

# Set executable permissions
chmod +x "$INSTALL_DIR/skynetv2_agent.py"

# Optional: Create systemd service
cat > /tmp/skynetv2.service <<'SYSTEMD'
[Unit]
Description=Skynetv2 Autonomous Agent
After=network.target

[Service]
Type=simple
User=$USER
WorkingDirectory=/opt/skynetv2
ExecStart=/usr/bin/python3 /opt/skynetv2/skynetv2_agent.py
Restart=on-failure
RestartSec=10

[Install]
WantedBy=multi-user.target
SYSTEMD

# Note: Requires sudo to install systemd service
# sudo mv /tmp/skynetv2.service /etc/systemd/system/
# sudo systemctl daemon-reload
# sudo systemctl enable skynetv2
# sudo systemctl start skynetv2

echo "[skynetv2] Installation complete. See README.md for next steps."
echo "[skynetv2] Manual systemd installation (requires sudo):"
echo "  sudo mv /tmp/skynetv2.service /etc/systemd/system/"
echo "  sudo systemctl daemon-reload"
echo "  sudo systemctl enable skynetv2"
echo "  sudo systemctl start skynetv2"
"""

def _generate_windows_install_script(device_name: str, target_ip: str) -> str:
    """Generate PowerShell install script for Windows targets."""
    return f"""# Skynetv2 Auto-Install Script (Windows)
# Device: {device_name}
# Target IP: {target_ip}
# Generated: {datetime.now().isoformat()}

$ErrorActionPreference = "Stop"

Write-Host "[skynetv2] Installing autonomous agent code..." -ForegroundColor Green

# Create installation directory
$INSTALL_DIR = "C:\\\\Program Files\\\\skynetv2"
New-Item -ItemType Directory -Path $INSTALL_DIR -Force | Out-Null

# Copy files
Copy-Item "skynetv2_agent.py" "$INSTALL_DIR\\"
Copy-Item "manifest.json" "$INSTALL_DIR\\"

# Create batch launcher
@'
@echo off
set BASE_DIR=C:\\Program Files\\skynetv2
cd /d %BASE_DIR%
python.exe skynetv2_agent.py
'@ | Out-File "$INSTALL_DIR\\launcher.bat" -Encoding ASCII

Write-Host "[skynetv2] Installation complete." -ForegroundColor Green
Write-Host "[skynetv2] To start: python.exe 'C:\\Program Files\\skynetv2\\skynetv2_agent.py'" -ForegroundColor Yellow
Write-Host "[skynetv2] To schedule as task, see README.md for instructions." -ForegroundColor Yellow
"""

def _generate_macos_install_script(device_name: str, target_ip: str) -> str:
    """Generate shell install script for macOS targets."""
    return f"""#!/bin/bash
# Skynetv2 Auto-Install Script (macOS)
# Device: {device_name}
# Target IP: {target_ip}
# Generated: {datetime.now().isoformat()}

set -e

echo "[skynetv2] Installing autonomous agent code..."

# Create installation directory
INSTALL_DIR="$HOME/Library/Application Support/skynetv2"
mkdir -p "$INSTALL_DIR"

# Copy files
cp skynetv2_agent.py "$INSTALL_DIR/"
cp manifest.json "$INSTALL_DIR/"

# Set executable
chmod +x "$INSTALL_DIR/skynetv2_agent.py"

# Optional: Create LaunchAgent (user-level daemon)
PLIST="$HOME/Library/LaunchAgents/com.skynetv2.agent.plist"
cat > /tmp/com.skynetv2.agent.plist <<'PLIST_END'
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.skynetv2.agent</string>
    <key>ProgramArguments</key>
    <array>
        <string>$INSTALL_DIR/skynetv2_agent.py</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>StandardErrorPath</key>
    <string>$HOME/Library/Logs/skynetv2.err</string>
    <key>StandardOutPath</key>
    <string>$HOME/Library/Logs/skynetv2.out</string>
</dict>
</plist>
PLIST_END

echo "[skynetv2] Installation complete. See README.md for LaunchAgent setup."
"""

def _generate_bundle_readme(device_name: str, target_ip: str, os_type: str) -> str:
    """Generate README.md with device-specific deployment instructions."""
    os_section = ""
    if os_type in ["ubuntu", "debian", "raspbian", "linux"]:
        os_section = """
### Linux/Debian/Ubuntu Installation

```bash
bash install.sh
```

**To enable systemd auto-start:**
```bash
sudo mv /tmp/skynetv2.service /etc/systemd/system/
sudo systemctl daemon-reload
sudo systemctl enable skynetv2
sudo systemctl start skynetv2
```
"""
    elif os_type == "windows":
        os_section = """
### Windows Installation

```powershell
powershell -ExecutionPolicy Bypass -File install.ps1
```

**To enable Task Scheduler auto-start:**
1. Open Task Scheduler (taskschd.msc)
2. Create New Task: Name = "skynetv2"
3. Action: Start program = `C:\\Program Files\\skynetv2\\launcher.bat`
4. Trigger: At startup OR At user login
"""
    elif os_type == "macos":
        os_section = """
### macOS Installation

```bash
bash install.command
```

**To enable LaunchAgent auto-start:**
```bash
cp /tmp/com.skynetv2.agent.plist ~/Library/LaunchAgents/
launchctl load ~/Library/LaunchAgents/com.skynetv2.agent.plist
```
"""

    return f"""# Skynetv2 Autonomous Agent - Deployment Bundle

**Device:** {device_name}
**Target IP:** {target_ip}
**OS:** {os_type.upper()}
**Created:** {datetime.now().isoformat()}

## Contents

- `install.sh` / `install.ps1` / `install.command` - OS-specific installer script
- `skynetv2_agent.py` - Core autonomous agent code
- `manifest.json` - Bundle metadata and file checksums
- `README.md` - This file

## Installation Steps

1. **Transfer bundle to target device** (secure transfer recommended)
   - Use SCP, SSH, or secure file copy
   - Example: `scp -r . user@{target_ip}:/tmp/skynetv2_bundle/`

2. **Run installer script on target**
   {os_section}

3. **Verify installation**
   - Check logs for startup messages
   - Confirm agent process is running

## Configuration

Edit the agent policy file to customize behavior:
- Network scanning options
- Device discovery settings
- Auto-rewrite thresholds
- Email/notification recipients

## Troubleshooting

- Check install logs: `tail -f /var/log/skynetv2.log` (Linux)
- Verify Python 3.9+ installed: `python3 --version`
- Test manually: `python3 skynetv2_agent.py --print-active-architecture`

## Support

For issues or configuration questions, refer to the main Skynetv2 documentation.
"""

def _record_self_heal_intent(kind: str, target: str, actions: list[str], baseline: dict, policy: dict):
    """Auto-generated docstring."""
    if not policy.get("self_heal_outcome_tracking_enabled", True):
        return
    if not actions:
        return
    data = load_self_heal_outcomes()
    intent = {
        "id": hashlib.sha256(f"{kind}|{target}|{time.time()}".encode("utf-8")).hexdigest()[:16],
        "kind": kind,
        "target": target,
        "actions": list(actions),
        "baseline": baseline if isinstance(baseline, dict) else {},
        "created_at": datetime.now().isoformat(),
        "evaluate_after": datetime.now().timestamp() + float(max(60, int(policy.get("self_heal_evaluation_delay_sec", 600)))),
    }
    data["pending"].append(intent)
    data["pending"] = data["pending"][-500:]
    data["stats"]["intents_total"] = int(data["stats"].get("intents_total", 0)) + 1
    save_self_heal_outcomes(data)

def _get_swarm_service_issue_hits(service_name: str, policy: dict) -> tuple[int, int, int]:
    """Auto-generated docstring."""
    rows = _list_swarm_services_basic()
    running = 0
    desired = 0
    for row in rows:
        if str(row.get("name", "")) == service_name:
            running, desired = _parse_replica_counts(row.get("replicas", "0/0"))
            break

    tail_lines = max(20, int(policy.get("swarm_log_tail_lines", 120)))
    rc, logs_out, logs_err, _ = _run_command_with_optional_sudo(
        ["docker", "service", "logs", "--tail", str(tail_lines), "--timestamps", service_name],
        timeout=20,
    )
    text = (logs_out or logs_err or "") if rc == 0 or logs_out or logs_err else ""
    lowered = text.lower()
    hits = sum(
        lowered.count(token)
        for token in ["error", "exception", "traceback", "panic", "fatal", "segfault", "oom"]
    )
    return hits, running, desired

def update_trainer_reliability_trend(policy: dict):
    """Auto-generated docstring."""
    if str(policy.get("trainer_runtime_target", "docker-swarm")).lower() != "docker-swarm":
        return
    service_name = str(policy.get("trainer_swarm_service_name", "")).strip()
    if not service_name:
        services = _list_swarm_services_basic()
        for svc in services:
            name = str(svc.get("name", "")).lower()
            if "nlp" in name and "trainer" in name:
                service_name = str(svc.get("name", ""))
                break
    if not service_name:
        return

    hits, running, desired = _get_swarm_service_issue_hits(service_name, policy)
    required = max(1, int(policy.get("trainer_required_replicas", 1)))
    reliability = max(0.0, min(1.0, float(running) / float(max(required, desired, 1))))

    def mutate(state):
        """Auto-generated docstring."""
        stats = state.setdefault("synthesis_stats", {})
        trend = stats.setdefault("trainer_reliability_trend", [])
        trend.append(
            {
                "at": datetime.now().isoformat(),
                "service": service_name,
                "running": running,
                "desired": desired,
                "required": required,
                "issue_hits": hits,
                "reliability": round(reliability, 3),
            }
        )
        # Keep roughly 6h of minute-ish samples.
        stats["trainer_reliability_trend"] = trend[-360:]

        points = stats["trainer_reliability_trend"]
        one_hour = points[-60:]
        three_hour = points[-180:]
        if one_hour:
            stats["trainer_reliability_1h"] = round(
                sum(float(p.get("reliability", 0.0)) for p in one_hour) / len(one_hour), 3
            )
        if three_hour:
            stats["trainer_reliability_3h"] = round(
                sum(float(p.get("reliability", 0.0)) for p in three_hour) / len(three_hour), 3
            )

    update_registry_state(mutate)

def _auto_tune_from_outcomes(policy: dict):
    """Auto-generated docstring."""
    if not policy.get("auto_tune_enabled", True):
        return
    data = load_self_heal_outcomes()
    evaluated = data.get("evaluated", [])[-60:]
    if not evaluated:
        return

    success_count = sum(1 for item in evaluated if bool(item.get("success")))
    success_rate = float(success_count) / float(len(evaluated))

    service_data = load_service_registry()
    summary = service_data.get("swarm_scan_summary", {}) if isinstance(service_data, dict) else {}
    scanned = int(summary.get("services_scanned", 0) or 0)
    issues = int(summary.get("issue_signatures", 0) or 0)
    issue_per_service = (float(issues) / float(max(1, scanned))) if scanned > 0 else 0.0

    changed = False
    th_min = max(0, int(policy.get("swarm_threshold_min", 1)))
    th_max = max(th_min + 1, int(policy.get("swarm_threshold_max", 12)))
    medium = int(policy.get("swarm_health_threshold_medium", 1))
    high = int(policy.get("swarm_health_threshold_high", 5))
    target_density = float(policy.get("swarm_issue_target_per_service", 1.5))

    if success_rate >= 0.75 and issue_per_service <= target_density:
        new_medium = min(th_max, medium + 1)
        new_high = min(th_max, max(new_medium + 1, high + 1))
        if new_medium != medium or new_high != high:
            policy["swarm_health_threshold_medium"] = new_medium
            policy["swarm_health_threshold_high"] = new_high
            changed = True
    elif success_rate < 0.55 or issue_per_service > target_density * 1.25:
        new_medium = max(th_min, medium - 1)
        new_high = max(new_medium + 1, high - 1)
        if new_medium != medium or new_high != high:
            policy["swarm_health_threshold_medium"] = new_medium
            policy["swarm_health_threshold_high"] = new_high
            changed = True

    # Tune rewrite coverage based on observed rewrite success ratio.
    rewrite_log = load_auto_rewrite_log()
    last_run = rewrite_log.get("last_test_run", {}) if isinstance(rewrite_log, dict) else {}
    kept = int(last_run.get("kept", 0) or 0)
    rolled_back = int(last_run.get("rolled_back", 0) or 0)
    attempted = max(1, kept + rolled_back)
    rewrite_success = float(kept) / float(attempted)
    max_files = int(policy.get("max_auto_rewrite_files_per_cycle", 500))
    floor = max(50, int(policy.get("rewrite_max_files_floor", 200)))
    ceiling = max(floor, int(policy.get("rewrite_max_files_ceiling", 5000)))
    target_rewrite_success = float(policy.get("rewrite_success_target", 0.65))

    if rewrite_success >= target_rewrite_success and max_files < ceiling:
        policy["max_auto_rewrite_files_per_cycle"] = min(ceiling, max_files + 150)
        changed = True
    elif rewrite_success < max(0.2, target_rewrite_success - 0.25) and max_files > floor:
        policy["max_auto_rewrite_files_per_cycle"] = max(floor, max_files - 150)
        changed = True

    if changed:
        write_json(WORKSPACE_POLICY_FILE, policy)
        data["stats"]["last_tuned_at"] = datetime.now().isoformat()
        data["stats"]["last_tuned_success_rate"] = round(success_rate, 3)
        data["stats"]["last_tuned_issue_per_service"] = round(issue_per_service, 3)
        save_self_heal_outcomes(data)
        log_action(
            "Auto-tuned policy: "
            f"medium={policy.get('swarm_health_threshold_medium')} "
            f"high={policy.get('swarm_health_threshold_high')} "
            f"max_auto_rewrite_files={policy.get('max_auto_rewrite_files_per_cycle')}"
        )

def evaluate_pending_self_heal_outcomes(policy: dict):
    """Auto-generated docstring."""
    if not policy.get("self_heal_outcome_tracking_enabled", True):
        return
    data = load_self_heal_outcomes()
    pending = data.get("pending", [])
    if not isinstance(pending, list) or not pending:
        return

    now_ts = datetime.now().timestamp()
    still_pending = []
    evaluated_new = []

    for item in pending:
        evaluate_after = float(item.get("evaluate_after", 0.0) or 0.0)
        if now_ts < evaluate_after:
            still_pending.append(item)
            continue

        kind = str(item.get("kind", ""))
        target = str(item.get("target", ""))
        baseline = item.get("baseline", {}) if isinstance(item.get("baseline"), dict) else {}
        success = False
        detail = {}

        if kind == "swarm_service":
            current_hits, running, desired = _get_swarm_service_issue_hits(target, policy)
            base_hits = int(baseline.get("issue_hits", 0) or 0)
            success = (current_hits <= base_hits) and (running >= max(1, desired))
            detail = {
                "current_issue_hits": current_hits,
                "baseline_issue_hits": base_hits,
                "running": running,
                "desired": desired,
            }
        elif kind == "trainer_swarm":
            current_hits, running, desired = _get_swarm_service_issue_hits(target, policy)
            required = max(1, int(policy.get("trainer_required_replicas", 1)))
            base_hits = int(baseline.get("issue_hits", 0) or 0)
            success = (running >= required) and (current_hits <= max(base_hits, 1))
            detail = {
                "current_issue_hits": current_hits,
                "baseline_issue_hits": base_hits,
                "running": running,
                "desired": desired,
                "required": required,
            }

        item["evaluated_at"] = datetime.now().isoformat()
        item["success"] = bool(success)
        item["detail"] = detail
        evaluated_new.append(item)

    if not evaluated_new:
        return

    data["pending"] = still_pending[-500:]
    data["evaluated"] = (data.get("evaluated", []) + evaluated_new)[-1000:]
    stats = data.setdefault("stats", {})
    stats["evaluated_total"] = int(stats.get("evaluated_total", 0)) + len(evaluated_new)
    stats["success_total"] = int(stats.get("success_total", 0)) + sum(1 for x in evaluated_new if x.get("success"))
    stats["failure_total"] = int(stats.get("failure_total", 0)) + sum(1 for x in evaluated_new if not x.get("success"))
    save_self_heal_outcomes(data)

    _auto_tune_from_outcomes(policy)

def _parse_replica_counts(replicas_text: str) -> tuple[int, int]:
    """Auto-generated docstring."""
    text = str(replicas_text or "").strip()
    if "/" not in text:
        return 0, 0
    left, right = text.split("/", 1)
    try:
        running = int(left.strip())
    except Exception:
        running = 0
    try:
        desired = int(right.strip())
    except Exception:
        desired = 0
    return max(0, running), max(0, desired)

def _list_swarm_services_basic() -> list[dict]:
    """Auto-generated docstring."""
    rc, services_out, services_err, _ = _run_command_with_optional_sudo(
        ["docker", "service", "ls", "--format", "{{.Name}}|{{.Replicas}}|{{.Image}}"],
        timeout=15,
    )
    if rc != 0:
        log_action(f"Swarm service list failed: {(services_err or services_out).strip()[:300]}")
        return []
    rows = []
    for line in (services_out or "").splitlines():
        row = line.strip()
        if not row:
            continue
        parts = row.split("|", 2)
        rows.append(
            {
                "name": parts[0].strip() if len(parts) > 0 else "",
                "replicas": parts[1].strip() if len(parts) > 1 else "",
                "image": parts[2].strip() if len(parts) > 2 else "",
            }
        )
    return rows

def _ensure_swarm_active() -> bool:
    """Auto-generated docstring."""
    rc, state_out, state_err, _ = _run_command_with_optional_sudo(
        ["docker", "info", "--format", "{{.Swarm.LocalNodeState}}"],
        timeout=8,
    )
    if rc != 0:
        log_action(f"Swarm check failed: {(state_err or state_out).strip()[:200]}")
        return False
    return (state_out or "").strip().lower() == "active"

def _rewrite_priority_score(reason: str, source: str, severity: str) -> int:
    """Auto-generated docstring."""
    severity_weight = {
        "info": 20,
        "warning": 35,
        "medium": 50,
        "high": 80,
        "critical": 95,
    }
    source_weight = {
        "swarm_logs": 40,
        "trainer_swarm": 45,
        "training_monitor": 25,
        "error_learning_cycle": 20,
        "v1_bridge": 10,
    }
    score = severity_weight.get(str(severity or "info").lower(), 20)
    src = str(source or "")
    for key, weight in source_weight.items():
        if key in src:
            score += weight
            break
    text = f"{reason} {source}".lower()
    for token, bonus in {
        "fatal": 12,
        "panic": 12,
        "exception": 8,
        "traceback": 8,
        "not running": 10,
        "oom": 10,
        "segfault": 12,
    }.items():
        if token in text:
            score += bonus
    return max(0, min(100, int(score)))

def _sort_backlog_by_priority(backlog: list[dict]) -> list[dict]:
    """Auto-generated docstring."""
    queued = [item for item in backlog if item.get("status") == "queued"]
    others = [item for item in backlog if item.get("status") != "queued"]
    queued.sort(
        key=lambda item: (
            float(item.get("priority_score", 0)),
            str(item.get("created_at", "")),
        ),
        reverse=True,
    )
    return queued + others

def _maybe_remediate_swarm_service(
    service_name: str,
    replicas_text: str,
    issue_hits: int,
    policy: dict,
    recurring_midlevel_streak: int = 0,
) -> list[str]:
    if not policy.get("swarm_remediation_enabled", True):
        return []

    now = time.time()
    backoff = max(30, int(policy.get("swarm_service_backoff_sec", 240)))
    last_fix_at = float(_last_swarm_service_fix_at.get(service_name, 0.0) or 0.0)
    if now - last_fix_at < backoff:
        return []

    running, desired = _parse_replica_counts(replicas_text)
    medium_threshold = max(0, int(policy.get("swarm_health_threshold_medium", 1)))
    high_threshold = max(medium_threshold, int(policy.get("swarm_health_threshold_high", 5)))
    recurring_threshold = max(2, int(policy.get("swarm_recurring_midlevel_threshold", 3)))
    actions = []

    if desired > 0 and running < desired:
        rc, _, err, _ = _run_command_with_optional_sudo(
            ["docker", "service", "scale", f"{service_name}={desired}"],
            timeout=20,
        )
        if rc == 0:
            actions.append(f"scaled_to_{desired}")
        else:
            actions.append(f"scale_failed:{(err or '').strip()[:120]}")

    if issue_hits >= high_threshold:
        rc, _, err, _ = _run_command_with_optional_sudo(
            ["docker", "service", "update", "--force", service_name],
            timeout=25,
        )
        if rc == 0:
            actions.append("forced_restart")
        else:
            actions.append(f"restart_failed:{(err or '').strip()[:120]}")
    elif issue_hits >= medium_threshold and running == 0 and desired > 0:
        rc, _, err, _ = _run_command_with_optional_sudo(
            ["docker", "service", "update", "--force", service_name],
            timeout=25,
        )
        if rc == 0:
            actions.append("forced_restart_zero_running")
        else:
            actions.append(f"restart_failed:{(err or '').strip()[:120]}")
    elif issue_hits >= medium_threshold and recurring_midlevel_streak >= recurring_threshold:
        # Escalate recurring medium-level noise even when replicas are still running.
        rc, _, err, _ = _run_command_with_optional_sudo(
            ["docker", "service", "update", "--force", service_name],
            timeout=25,
        )
        if rc == 0:
            actions.append(f"forced_restart_midlevel_streak_{recurring_midlevel_streak}")
        else:
            actions.append(f"restart_failed:{(err or '').strip()[:120]}")

    if actions:
        _last_swarm_service_fix_at[service_name] = now
        _record_self_heal_intent(
            kind="swarm_service",
            target=service_name,
            actions=actions,
            baseline={
                "issue_hits": issue_hits,
                "replicas": replicas_text,
            },
            policy=policy,
        )
    return actions

def remediate_trainer_on_swarm(policy: dict) -> dict:
    """Auto-generated docstring."""
    global _last_trainer_swarm_fix_at
    if str(policy.get("trainer_runtime_target", "docker-swarm")).lower() != "docker-swarm":
        return {"status": "skipped_non_swarm_target"}
    if not _ensure_swarm_active():
        return {"status": "skipped_swarm_inactive"}

    now = time.time()
    backoff = max(30, int(policy.get("trainer_restart_backoff_sec", 180)))
    if now - _last_trainer_swarm_fix_at < backoff:
        return {"status": "backoff"}

    services = _list_swarm_services_basic()
    target = str(policy.get("trainer_swarm_service_name", "")).strip()
    chosen = None
    for svc in services:
        name = str(svc.get("name", ""))
        if target and name == target:
            chosen = svc
            break
    if chosen is None:
        for svc in services:
            name = str(svc.get("name", "")).lower()
            if "nlp" in name and "trainer" in name:
                chosen = svc
                break
    if chosen is None:
        queue_code_rewrite(
            reason="trainer expected on swarm but no nlp-trainer service was found",
            source="trainer_swarm",
            severity="high",
        )
        return {"status": "trainer_service_not_found"}

    service_name = str(chosen.get("name", ""))
    running, desired = _parse_replica_counts(chosen.get("replicas", "0/0"))
    required = max(1, int(policy.get("trainer_required_replicas", 1)))
    actions = []

    if desired < required:
        rc, _, err, _ = _run_command_with_optional_sudo(
            ["docker", "service", "scale", f"{service_name}={required}"],
            timeout=20,
        )
        if rc == 0:
            actions.append(f"scale_to_{required}")
            desired = required
        else:
            actions.append(f"scale_failed:{(err or '').strip()[:120]}")

    if running < required:
        rc, _, err, _ = _run_command_with_optional_sudo(
            ["docker", "service", "update", "--force", service_name],
            timeout=25,
        )
        if rc == 0:
            actions.append("forced_restart")
        else:
            actions.append(f"restart_failed:{(err or '').strip()[:120]}")

    if actions:
        _last_trainer_swarm_fix_at = now
        _record_self_heal_intent(
            kind="trainer_swarm",
            target=service_name,
            actions=actions,
            baseline={
                "issue_hits": 0,
                "running": running,
                "desired": desired,
            },
            policy=policy,
        )

    return {
        "status": "remediated" if actions else "healthy",
        "service": service_name,
        "running": running,
        "desired": desired,
        "required": required,
        "actions": actions,
    }

def _run_command_with_optional_sudo(command, timeout=15):
    """Auto-generated docstring."""
    try:
        first = subprocess.run(
            command,
            capture_output=True,
            text=True,
            timeout=timeout,
            check=False,
        )
    except FileNotFoundError:
        return 127, "", f"command not found: {command[0]}", False
    except Exception as exc:
        return 1, "", str(exc), False

    if first.returncode == 0:
        return first.returncode, first.stdout or "", first.stderr or "", False

    stderr_text = (first.stderr or "").lower()
    stdout_text = (first.stdout or "").lower()
    permission_like = any(
        marker in (stderr_text + "\n" + stdout_text)
        for marker in [
            "permission denied",
            "cannot connect to the docker daemon",
            "got permission denied",
            "this node is not a swarm manager",
        ]
    )

    if not permission_like:
        return first.returncode, first.stdout or "", first.stderr or "", False

    sudo_cmd = ["sudo", "-n", *command]
    try:
        second = subprocess.run(
            sudo_cmd,
            capture_output=True,
            text=True,
            timeout=timeout,
            check=False,
        )
        return second.returncode, second.stdout or "", second.stderr or "", True
    except Exception as exc:
        return first.returncode, first.stdout or "", f"{first.stderr}\n{exc}", False

def discover_swarm_services_and_logs(policy=None):
    """Auto-generated docstring."""
    global _last_swarm_scan_at
    if policy is None:
        policy = load_workspace_policy()
    if not policy.get("swarm_log_scan_enabled", True):
        return []

    with _swarm_lock:
        now = time.time()
        interval = max(30, int(policy.get("swarm_scan_interval_sec", 300)))
        if now - _last_swarm_scan_at < interval:
            return []
        _last_swarm_scan_at = now

    rc, state_out, state_err, used_sudo_info = _run_command_with_optional_sudo(
        ["docker", "info", "--format", "{{.Swarm.LocalNodeState}}"],
        timeout=8,
    )
    if rc != 0:
        log_action(f"Swarm scan skipped; docker info failed: {(state_err or state_out).strip()[:200]}")
        return []

    if (state_out or "").strip().lower() != "active":
        return []

    rc, services_out, services_err, used_sudo_services = _run_command_with_optional_sudo(
        ["docker", "service", "ls", "--format", "{{.Name}}|{{.Replicas}}|{{.Image}}"],
        timeout=15,
    )
    if rc != 0:
        log_action(f"Swarm service list failed: {(services_err or services_out).strip()[:300]}")
        return []

    max_services = max(1, int(policy.get("swarm_max_services_per_scan", 50)))
    tail_lines = max(20, int(policy.get("swarm_log_tail_lines", 120)))
    excerpt_chars = max(200, int(policy.get("swarm_log_excerpt_chars", 5000)))

    registry = load_service_registry()
    streaks = registry.get("swarm_midlevel_streaks", {}) if isinstance(registry.get("swarm_midlevel_streaks"), dict) else {}
    updated_streaks = dict(streaks)

    raw_lines = [line.strip() for line in (services_out or "").splitlines() if line.strip()]
    swarm_services = []
    issue_count = 0

    for row in raw_lines[:max_services]:
        parts = row.split("|", 2)
        name = parts[0].strip() if len(parts) > 0 else ""
        replicas = parts[1].strip() if len(parts) > 1 else ""
        image = parts[2].strip() if len(parts) > 2 else ""
        if not name:
            continue

        rc, logs_out, logs_err, used_sudo_logs = _run_command_with_optional_sudo(
            ["docker", "service", "logs", "--tail", str(tail_lines), "--timestamps", name],
            timeout=20,
        )

        logs_text = (logs_out or logs_err or "").strip()
        excerpt = logs_text[-excerpt_chars:]
        lowered = logs_text.lower()
        issue_hits = sum(
            lowered.count(token)
            for token in ["error", "exception", "traceback", "panic", "fatal", "segfault", "oom"]
        )
        issue_count += issue_hits

        medium_threshold = max(0, int(policy.get("swarm_health_threshold_medium", 1)))
        prev_streak = int(updated_streaks.get(name, 0) or 0)
        current_streak = prev_streak + 1 if issue_hits >= medium_threshold else 0
        updated_streaks[name] = current_streak

        if issue_hits > 0:
            queue_code_rewrite(
                reason=f"docker swarm service {name} logs show {issue_hits} error signatures",
                source="swarm_logs",
                severity="medium" if issue_hits < 6 else "high",
            )

        remediation_actions = _maybe_remediate_swarm_service(
            name,
            replicas,
            issue_hits,
            policy,
            recurring_midlevel_streak=current_streak,
        )

        swarm_services.append(
            {
                "name": name,
                "replicas": replicas,
                "image": image,
                "log_issue_hits": issue_hits,
                "log_excerpt": excerpt,
                "log_scanned_at": datetime.now().isoformat(),
                "log_rc": rc,
                "used_sudo": bool(used_sudo_info or used_sudo_services or used_sudo_logs),
                "midlevel_issue_streak": current_streak,
                "remediation_actions": remediation_actions,
            }
        )

    registry["swarm_services"] = swarm_services
    registry["last_swarm_scan"] = datetime.now().isoformat()
    registry["swarm_midlevel_streaks"] = updated_streaks
    registry["swarm_scan_summary"] = {
        "services_scanned": len(swarm_services),
        "issue_signatures": issue_count,
    }
    save_service_registry(registry)
    log_action(
        f"Swarm scan complete: services={len(swarm_services)} issue_signatures={issue_count}"
    )
    return swarm_services

def _is_url_allowed(url: str, policy: dict) -> bool:
    """Auto-generated docstring."""
    allowlist = policy.get("web_allowlist", [])
    if not isinstance(allowlist, list) or not allowlist:
        return True
    host = urllib.parse.urlparse(url).netloc.lower()
    for allowed in allowlist:
        token = str(allowed or "").strip().lower()
        if token and token in host:
            return True
    return False

def _fetch_url_text(url: str, policy: dict) -> str:
    """Auto-generated docstring."""
    if not _is_url_allowed(url, policy):
        return ""
    timeout = int(policy.get("web_timeout_sec", 12))
    max_chars = int(policy.get("max_web_response_chars", 8000))
    max_download_bytes = max(8192, int(policy.get("max_web_download_bytes", 2097152)))
    request = urllib.request.Request(
        url,
        headers={
            "User-Agent": "skynetv2-agent/1.0 (+local)"
        },
    )
    try:
        chunks = []
        total = 0
        code_signals = {
            "imports": 0,
            "functions": 0,
            "scripts": 0,
            "urls": 0,
        }
        with urllib.request.urlopen(request, timeout=timeout) as response:
            while True:
                chunk = response.read(4096)
                if not chunk:
                    break
                # Analyze downloaded content byte-by-byte as it streams in.
                for b in chunk:
                    if b in (10, 13):
                        continue
                total += len(chunk)
                if total > max_download_bytes:
                    chunk = chunk[: max(0, len(chunk) - (total - max_download_bytes))]
                    chunks.append(chunk)
                    break
                chunks.append(chunk)

                lowered = chunk.lower()
                code_signals["imports"] += lowered.count(b"import ") + lowered.count(b"require(")
                code_signals["functions"] += lowered.count(b"def ") + lowered.count(b"function ")
                code_signals["scripts"] += lowered.count(b"<script")
                code_signals["urls"] += lowered.count(b"http://") + lowered.count(b"https://")

        raw = b"".join(chunks)
        text = raw.decode("utf-8", errors="replace")
        scan = {
            "downloaded_bytes": len(raw),
            "sha256": hashlib.sha256(raw).hexdigest(),
            "code_signals": code_signals,
        }
        _log_web_visit(url=url, query="", downloaded_bytes=len(raw), scan=scan, policy=policy)
        return text[:max_chars]
    except Exception as exc:
        log_action(f"Web lookup failed for {url}: {exc}")
        return ""

def _log_web_visit(url: str, query: str, downloaded_bytes: int, scan: dict, policy: dict):
    """Auto-generated docstring."""
    domain = urllib.parse.urlparse(url).netloc.lower()
    with _web_lock:
        payload = read_json(WEB_INTELLIGENCE_FILE)
        if not isinstance(payload, dict):
            payload = {"queries": [], "visits": []}
        payload.setdefault("queries", [])
        visits = payload.setdefault("visits", [])
        visits.append(
            {
                "at": datetime.now().isoformat(),
                "domain": domain,
                "url": url,
                "query": query,
                "downloaded_bytes": int(downloaded_bytes),
                "scan": scan,
                "emailed": False,
            }
        )
        payload["visits"] = visits[-400:]
        write_json(WEB_INTELLIGENCE_FILE, payload)

def _maybe_email_web_visit_digest(policy: dict, force: bool = False):
    """Auto-generated docstring."""
    global _last_web_email_sent_at
    if not policy.get("web_email_reports_enabled", True):
        return
    smtp_user = os.environ.get("GMAIL_USER") or os.environ.get("SMTP_USER")
    recipient = (ADMIN_EMAIL or smtp_user or "").strip()
    if not ENABLE_EMAIL_REPORTS or not recipient:
        return

    now = time.time()
    interval = max(60, int(policy.get("web_email_report_interval_sec", 900)))
    if not force and now - _last_web_email_sent_at < interval:
        return

    with _web_lock:
        payload = read_json(WEB_INTELLIGENCE_FILE)
        if not isinstance(payload, dict):
            return
        visits = payload.get("visits", [])
        if not isinstance(visits, list):
            return

        pending = [v for v in visits if isinstance(v, dict) and not bool(v.get("emailed", False))]
        if not pending:
            _last_web_email_sent_at = now
            return

        lines = ["skynetv2 web activity digest", "", f"new visits: {len(pending)}", ""]
        for v in pending[:120]:
            domain = v.get("domain", "")
            url = v.get("url", "")
            b = v.get("downloaded_bytes", 0)
            scan = v.get("scan", {}) if isinstance(v.get("scan"), dict) else {}
            signals = scan.get("code_signals", {}) if isinstance(scan.get("code_signals"), dict) else {}
            lines.append(
                f"- {v.get('at','')} | {domain} | bytes={b} | imports={signals.get('imports',0)} functions={signals.get('functions',0)} scripts={signals.get('scripts',0)} urls={signals.get('urls',0)}"
            )
            lines.append(f"  url: {url}")

        body = "\n".join(lines)
        sent = send_email("skynetv2 web domain report", body, recipient)
        if sent:
            for v in pending:
                v["emailed"] = True
            payload["last_web_email_at"] = datetime.now().isoformat()
            write_json(WEB_INTELLIGENCE_FILE, payload)
            _last_web_email_sent_at = now

def _talk_to_google_ai(query: str, context: str, policy: dict) -> dict:
    """Auto-generated docstring."""
    if not policy.get("allow_google_ai_chat", True):
        return {"status": "disabled"}

    api_key = os.environ.get("GOOGLE_AI_API_KEY", "").strip()
    if not api_key:
        return {"status": "missing_api_key"}

    model = str(policy.get("google_ai_model", "gemini-1.5-flash") or "gemini-1.5-flash")
    endpoint = (
        f"https://generativelanguage.googleapis.com/v1beta/models/{urllib.parse.quote(model)}:generateContent"
        f"?key={urllib.parse.quote(api_key)}"
    )

    prompt = (
        "You are assisting skynetv2 with software reliability. "
        f"Problem: {query}\n"
        f"Web context: {context[:2000]}\n"
        "Return concise actionable remediation ideas."
    )
    payload = {
        "contents": [
            {
                "parts": [
                    {"text": prompt}
                ]
            }
        ]
    }
    req = urllib.request.Request(
        endpoint,
        data=json.dumps(payload).encode("utf-8"),
        headers={"Content-Type": "application/json"},
        method="POST",
    )
    try:
        with urllib.request.urlopen(req, timeout=max(6, int(policy.get("web_timeout_sec", 12)))) as resp:
            body = resp.read(65536).decode("utf-8", errors="replace")
        _log_web_visit(
            url="https://generativelanguage.googleapis.com",
            query=query,
            downloaded_bytes=len(body.encode("utf-8", errors="ignore")),
            scan={"provider": "google_ai", "model": model},
            policy=policy,
        )
        return {"status": "ok", "model": model, "response": body[:4000]}
    except Exception as exc:
        log_action(f"Google AI request failed: {exc}")
        return {"status": "error", "error": str(exc)}

def lookup_web_context(query: str, policy: dict) -> dict:
    """Auto-generated docstring."""
    q = str(query or "").strip()
    if not q:
        return {"query": "", "sources": []}
    if not policy.get("allow_web_lookup", True):
        return {"query": q, "sources": []}

    encoded = urllib.parse.quote_plus(q)
    urls = [
        f"https://duckduckgo.com/html/?q={encoded}",
        f"https://en.wikipedia.org/w/index.php?search={encoded}",
    ]
    sources = []
    for url in urls:
        text = _fetch_url_text(url, policy)
        if text:
            sources.append({"url": url, "snippet": text[:1200]})

    google_ai = _talk_to_google_ai(q, "\n\n".join(src.get("snippet", "") for src in sources), policy)

    payload = {
        "queried_at": datetime.now().isoformat(),
        "query": q,
        "sources": sources,
        "google_ai": google_ai,
    }
    try:
        existing = read_json(WEB_INTELLIGENCE_FILE)
        if not isinstance(existing, dict):
            existing = {"queries": []}
        existing.setdefault("queries", []).append(payload)
        existing["queries"] = existing["queries"][-50:]
        write_json(WEB_INTELLIGENCE_FILE, existing)
    except Exception:
        pass

    _maybe_email_web_visit_digest(policy)
    return payload

def _extract_recent_problem_signal() -> tuple[str, str]:
    """Auto-generated docstring."""
    backlog = load_rewrite_backlog()
    for entry in reversed(backlog):
        if entry.get("status") in {"queued", "analyzing", "validated"}:
            return str(entry.get("reason", "")), str(entry.get("source", "backlog"))

    status = read_json(TRAINING_STATUS)
    if isinstance(status, dict):
        trainer = status.get("processes", {}).get("nlp_trainer", {})
        if isinstance(trainer, dict) and not bool(trainer.get("running", False)):
            return "nlp_trainer not running", "training_status"

    return "general reliability drift", "system_monitor"

def run_controlled_algorithmic_synthesis(policy: dict):
    """Auto-generated docstring."""
    global _last_algorithmic_synthesis_at
    if not policy.get("algorithmic_synthesis_enabled", True):
        return None

    now = time.time()
    interval = max(60, int(policy.get("algorithmic_synthesis_interval_sec", 600)))
    if now - _last_algorithmic_synthesis_at < interval:
        return None

    problem, source = _extract_recent_problem_signal()
    if policy.get("allow_web_lookup", True):
        try:
            lookup_web_context(problem, policy)
        except Exception:
            pass

    synthesis_goal = str(policy.get("algorithmic_synthesis_goal", "latency") or "latency")
    result = run_algorithmic_synthesis(problem=problem, language="python", goal=synthesis_goal)
    _last_algorithmic_synthesis_at = now

    def mutate(state):
        """Auto-generated docstring."""
        stats = state.setdefault("synthesis_stats", {})
        stats["last_external_synthesis"] = {
            "at": datetime.now().isoformat(),
            "problem": problem,
            "source": source,
            "goal": synthesis_goal,
            "returncode": result.get("returncode"),
            "stderr": str(result.get("stderr", ""))[:800],
            "stdout_preview": str(result.get("stdout", ""))[:1200],
        }

    update_registry_state(mutate)
    return result

def ingest_v1_outputs_one_way(policy: dict):
    """Auto-generated docstring."""
    global _last_v1_bridge_poll_at
    if not policy.get("v1_bridge_enabled", True):
        return

    now = time.time()
    interval = max(30, int(policy.get("v1_bridge_poll_interval_sec", 300)))
    if now - _last_v1_bridge_poll_at < interval:
        return
    _last_v1_bridge_poll_at = now

    v1_registry = read_json(V1_REGISTRY_FILE)
    v1_rewrite_history = read_json(V1_REWRITE_HISTORY_FILE)
    v1_rewrite_log = read_json(V1_AUTO_REWRITE_LOG_FILE)

    v1_rewrite_count = len(v1_rewrite_history) if isinstance(v1_rewrite_history, list) else 0
    v1_file_rewrites = 0
    if isinstance(v1_rewrite_log, dict):
        v1_file_rewrites = len(v1_rewrite_log.get("rewrites", []) or [])

    trainer_issue = False
    if isinstance(v1_registry, dict):
        failure_log = v1_registry.get("failure_log", [])
        if isinstance(failure_log, list):
            for item in reversed(failure_log[-20:]):
                message = str(item.get("message", "")).lower() if isinstance(item, dict) else ""
                if "trainer" in message and ("not running" in message or "stale pid" in message):
                    trainer_issue = True
                    break

    def mutate(state):
        """Auto-generated docstring."""
        stats = state.setdefault("synthesis_stats", {})
        bridge = stats.setdefault("v1_bridge", {})
        previous_rewrites = int(bridge.get("v1_rewrite_history_entries", 0))
        bridge["last_polled_at"] = datetime.now().isoformat()
        bridge["v1_rewrite_history_entries"] = v1_rewrite_count
        bridge["v1_file_rewrites_logged"] = v1_file_rewrites
        bridge["trainer_issue_seen"] = bool(trainer_issue)

        if v1_rewrite_count > previous_rewrites:
            queue_code_rewrite(
                reason=f"v1 created {v1_rewrite_count - previous_rewrites} new rewrite history entries; inspect for reusable patterns",
                source="v1_bridge",
                severity="info",
            )
        if trainer_issue:
            queue_code_rewrite(
                reason="v1 reported trainer instability; verify v2 trainer process supervision",
                source="v1_bridge",
                severity="medium",
            )

    update_registry_state(mutate)

