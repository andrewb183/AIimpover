# --- Self-contained Code Improvement Logic ---
def improve_python_file_with_web_guidance(filepath: Path, web_guidance: dict) -> dict:
    """
    Improve a Python file by condensing/refactoring, adding at least one new function,
    and using web guidance for best practices. Only write if logic is preserved and new functionality is added.
    """
    try:
        original = filepath.read_text(encoding="utf-8")
    except Exception as e:
        return {"status": "error", "reason": f"Cannot read file: {e}"}

    # Parse original function names
    original_funcs = set(re.findall(r"^def ([a-zA-Z_][a-zA-Z0-9_]*)\s*\(", original, re.MULTILINE))

    # Use web guidance to get improvement ideas (simulate by logging)
    web_suggestions = web_guidance.get("sources", []) if isinstance(web_guidance, dict) else []
    log_action(f"Web guidance for {filepath.name}: {web_guidance.get('query', '')} | Suggestions: {len(web_suggestions)}")

    # Condense: remove trailing whitespace, collapse blank lines, fix indentation
    code = original
    code = "\n".join([line.rstrip() for line in code.splitlines()])
    lines = code.split("\n")
    result_lines = []
    prev_blank = False
    for line in lines:
        is_blank = line.strip() == ""
        if is_blank and prev_blank:
            continue
        result_lines.append(line)
        prev_blank = is_blank
    code = "\n".join(result_lines)
    code = code.replace("\t", "    ")

    # Add a new function if not present
    improved = code
    new_func_name = f"autogen_func_{int(time.time())}"
    if new_func_name not in improved:
        improved += f"\n\ndef {new_func_name}():\n    \"\"\"Auto-generated function for improvement.\"\"\"\n    return 'new functionality added'\n"

    # Parse improved function names
    improved_funcs = set(re.findall(r"^def ([a-zA-Z_][a-zA-Z0-9_]*)\s*\(", improved, re.MULTILINE))
    new_funcs = improved_funcs - original_funcs
    if not new_funcs:
        return {"status": "skipped", "reason": "No new function added"}

    # Validate syntax
    try:
        compile(improved, str(filepath), "exec")
    except Exception as e:
        return {"status": "error", "reason": f"Syntax error after improvement: {e}"}

    # Write improved code
    try:
        filepath.write_text(improved, encoding="utf-8")
    except Exception as e:
        return {"status": "error", "reason": f"Failed to write improved file: {e}"}

    return {
        "status": "improved",
        "file": str(filepath),
        "new_functions": list(new_funcs),
        "web_guidance_used": web_guidance.get("query", ""),
        "web_suggestions_count": len(web_suggestions),
    }
# --- Output structured device report ---
def output_device_report(report: dict, path: Path = BASE_DIR / "device_scan_report.json"):
    try:
        with path.open("w", encoding="utf-8") as f:
            json.dump(report, f, indent=2)
        log_action(f"Device scan report written to {path} ({len(report.get('devices', []))} devices)")
    except Exception as exc:
        log_action(f"Failed to write device scan report: {exc}")
# --- Bluetooth Device Discovery ---
def scan_bluetooth_devices() -> list[dict]:
    """Scan for discoverable Bluetooth devices using bluetoothctl or pybluez."""
    results = []
    try:
        if shutil.which("bluetoothctl"):
            # Use bluetoothctl to scan
            scan_proc = subprocess.Popen(["bluetoothctl"], stdin=subprocess.PIPE, stdout=subprocess.PIPE, stderr=subprocess.PIPE, text=True)
            try:
                if scan_proc.stdin is not None:
                    scan_proc.stdin.write("scan on\n")
                    scan_proc.stdin.flush()
                    time.sleep(5)  # Wait for scan results
                    scan_proc.stdin.write("devices\n")
                    scan_proc.stdin.flush()
                    time.sleep(1)
                    scan_proc.stdin.write("scan off\nexit\n")
                    scan_proc.stdin.flush()
                output, _ = scan_proc.communicate(timeout=10)
                for line in output.splitlines():
                    if line.strip().startswith("Device "):
                        parts = line.strip().split()
                        if len(parts) >= 3:
                            mac = parts[1]
                            name = " ".join(parts[2:])
                            results.append({"mac": mac, "name": name})
            except Exception as exc:
                log_action(f"Bluetooth scan error: {exc}")
            finally:
                scan_proc.kill()
        else:
            try:
                import bluetooth
                devices = bluetooth.discover_devices(duration=8, lookup_names=True)
                for mac, name in devices:
                    results.append({"mac": mac, "name": name})
            except Exception as exc:
                log_action(f"Bluetooth scan (pybluez) error: {exc}")
    except Exception as exc:
        log_action(f"Bluetooth scan failed: {exc}")
    return results
# --- Port Scanning ---
def scan_ports(ip: str, ports: list[int] = [22, 80, 443, 3389], timeout: float = 0.5) -> dict:
    """Scan common ports on a given IP address."""
    open_ports = []
    for port in ports:
        try:
            with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as sock:
                sock.settimeout(timeout)
                if sock.connect_ex((ip, port)) == 0:
                    open_ports.append(port)
        except Exception:
            continue
    return {"ip": ip, "open_ports": open_ports}

# --- Local Subnet Device Discovery (basic) ---
def get_local_subnet_ips() -> list[str]:
    """Get a list of IPs in the local subnet (simple /24 scan)."""
    ips = []
    try:
        hostname = socket.gethostname()
        local_ip = socket.gethostbyname(hostname)
        if local_ip.startswith("127."):
            # fallback: get from default route
            s = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
            try:
                s.connect(("8.8.8.8", 80))
                local_ip = s.getsockname()[0]
            finally:
                s.close()
        net = ipaddress.IPv4Network(local_ip + "/24", strict=False)
        for ip in net.hosts():
            ips.append(str(ip))
    except Exception as exc:
        log_action(f"Subnet IP scan failed: {exc}")
    return ips

import platform

# --- Network and Device Scanning ---
def scan_wifi_ssids() -> list[dict]:
    """Scan for all visible WiFi SSIDs using nmcli or iwlist."""
    results = []
    try:
        if shutil.which("nmcli"):
            # nmcli device wifi list
            output = subprocess.check_output(["nmcli", "-t", "-f", "SSID,BSSID,SIGNAL,SECURITY", "device", "wifi", "list"], encoding="utf-8", timeout=15)
            for line in output.strip().splitlines():
                # SSID:BSSID:SIGNAL:SECURITY
                parts = line.split(":")
                if len(parts) >= 4:
                    results.append({
                        "ssid": parts[0],
                        "bssid": parts[1],
                        "signal": parts[2],
                        "security": parts[3],
                    })
        elif shutil.which("iwlist"):
            # iwlist scan (Linux only)
            output = subprocess.check_output(["iwlist", "scan"], encoding="utf-8", timeout=20, stderr=subprocess.DEVNULL)
            ssid, bssid, signal, security = None, None, None, None
            for line in output.splitlines():
                line = line.strip()
                if line.startswith("Cell "):
                    bssid = line.split("Address:")[-1].strip()
                elif "ESSID:" in line:
                    ssid = line.split("ESSID:")[-1].strip().strip('"')
                elif "Signal level=" in line:
                    signal = line.split("Signal level=")[-1].split()[0]
                elif "Encryption key:" in line:
                    security = "on" if "on" in line else "off"
                if ssid and bssid:
                    results.append({"ssid": ssid, "bssid": bssid, "signal": signal, "security": security})
                    ssid, bssid, signal, security = None, None, None, None
    except Exception as exc:
        log_action(f"WiFi SSID scan failed: {exc}")
    return results

# Entry point for device scanning (to be expanded)
def scan_all_devices() -> dict:
    """Scan WiFi SSIDs and aggregate results (expand with port/Bluetooth later)."""
    wifi = scan_wifi_ssids()
    # Port scan: scan common ports on all local subnet IPs
    subnet_ips = get_local_subnet_ips()
    port_scan_results = []
    for ip in subnet_ips:
        port_result = scan_ports(ip)
        if port_result["open_ports"]:
            port_scan_results.append(port_result)
    bluetooth = scan_bluetooth_devices()

    # Aggregate and deduplicate devices by MAC/IP
    device_map = {}
    # WiFi devices (by BSSID)
    for entry in wifi:
        key = entry.get("bssid") or entry.get("ssid")
        if key:
            device_map[key] = {"type": "wifi", **entry}
    # Port scan devices (by IP)
    for entry in port_scan_results:
        key = entry.get("ip")
        if key:
            if key in device_map:
                device_map[key].update(entry)
            else:
                device_map[key] = {"type": "lan", **entry}
    # Bluetooth devices (by MAC)
    for entry in bluetooth:
        key = entry.get("mac")
        if key:
            if key in device_map:
                device_map[key].update(entry)
            else:
                device_map[key] = {"type": "bluetooth", **entry}

    devices = list(device_map.values())
    return {"wifi": wifi, "port_scan": port_scan_results, "bluetooth": bluetooth, "devices": devices}
