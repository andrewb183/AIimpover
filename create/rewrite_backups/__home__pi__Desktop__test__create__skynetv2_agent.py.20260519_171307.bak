def _strip_html_text(html_text: str, max_chars: int = 12000) -> str:
    text = re.sub(r"<script[\\s\\S]*?</script>", " ", str(html_text or ""), flags=re.IGNORECASE)
    text = re.sub(r"<style[\\s\\S]*?</style>", " ", text, flags=re.IGNORECASE)
    text = re.sub(r"<[^>]+>", " ", text)
    text = re.sub(r"&nbsp;", " ", text)
    text = re.sub(r"\\s+", " ", text).strip()
    if max_chars > 0:
        return text[:max_chars]
    return text

def _fetch_dom_observation(url: str, timeout_sec: float, max_chars: int) -> dict:
    target = str(url or "").strip()
    if not target:
        return {"source": "dom", "url": "", "ok": False, "error": "empty url", "text": ""}
    try:
        req = urllib.request.Request(target, headers={"User-Agent": "skynetv2-screen-learn/1.0"})
        with urllib.request.urlopen(req, timeout=float(max(1.0, timeout_sec))) as resp:
            body = resp.read(max(4096, int(max_chars) * 3)).decode("utf-8", errors="replace")
        text = _strip_html_text(body, max_chars=max_chars)
        return {
            "source": "dom",
            "url": target,
            "ok": True,
            "error": "",
            "text": text,
            "text_chars": len(text),
            "captured_at": datetime.now().isoformat(),
        }
    except Exception as exc:
        return {
            "source": "dom",
            "url": target,
            "ok": False,
            "error": str(exc)[:200],
            "text": "",
            "captured_at": datetime.now().isoformat(),
        }

def _capture_ocr_screen_text(policy: dict) -> dict:
    if not os.environ.get("DISPLAY") and not os.environ.get("WAYLAND_DISPLAY"):
        return {"source": "ocr", "ok": False, "error": "no desktop display session", "text": ""}
    if not shutil.which("tesseract"):
        return {"source": "ocr", "ok": False, "error": "tesseract not installed", "text": ""}

    capture_cmd = None
    with NamedTemporaryFile("wb", suffix=".png", delete=False) as tmp:
        screenshot_path = Path(tmp.name)

    if shutil.which("import"):
        capture_cmd = ["import", "-window", "root", str(screenshot_path)]
    elif shutil.which("scrot"):
        capture_cmd = ["scrot", str(screenshot_path)]
    elif shutil.which("grim"):
        capture_cmd = ["grim", str(screenshot_path)]
    else:
        try:
            screenshot_path.unlink(missing_ok=True)
        except Exception:
            pass
        return {"source": "ocr", "ok": False, "error": "no screenshot tool available", "text": ""}

    capture_timeout = max(2, int(policy.get("screen_learning_capture_timeout_sec", 10)))
    ocr_timeout = max(2, int(policy.get("screen_learning_ocr_timeout_sec", 25)))
    max_chars = max(256, int(policy.get("screen_learning_max_chars", 12000)))
    try:
        capture_result = subprocess.run(capture_cmd, capture_output=True, text=True, timeout=capture_timeout, check=False)
        if capture_result.returncode != 0:
            return {
                "source": "ocr",
                "ok": False,
                "error": (capture_result.stderr or capture_result.stdout or "screen capture failed")[:200],
                "text": "",
            }
        ocr_result = subprocess.run(
            ["tesseract", str(screenshot_path), "stdout"],
            capture_output=True,
            text=True,
            timeout=ocr_timeout,
            check=False,
        )
        if ocr_result.returncode != 0:
            return {
                "source": "ocr",
                "ok": False,
                "error": (ocr_result.stderr or ocr_result.stdout or "ocr failed")[:200],
                "text": "",
            }
        text = re.sub(r"\s+", " ", (ocr_result.stdout or "")).strip()[:max_chars]
        return {
            "source": "ocr",
            "ok": True,
            "error": "",
            "text": text,
            "text_chars": len(text),
            "captured_at": datetime.now().isoformat(),
        }
    except Exception as exc:
        return {"source": "ocr", "ok": False, "error": str(exc)[:200], "text": ""}
    finally:
        try:
            screenshot_path.unlink(missing_ok=True)
        except Exception:
            pass

def _extract_screen_cues(text_blocks: list[str]) -> dict:
    merged = "\n".join(block for block in text_blocks if block).strip()
    lower = merged.lower()
    tokens = set(_tokenize(merged))
    cues = {
        "keywords": sorted(
            token
            for token in tokens
            if token
            in {
                "error",
                "exception",
                "traceback",
                "deploy",
                "deployment",
                "website",
                "feedback",
                "request",
                "todo",
                "bug",
                "fix",
                "create",
                "file",
                "update",
                "append",
            }
        )[:24],
        "has_error": any(marker in lower for marker in ["error", "exception", "traceback", "failed"]),
        "needs_deployment": any(marker in lower for marker in ["deploy", "deployment", "bundle"]),
        "website_signal": any(marker in lower for marker in ["website", "feedback", "request", "story", "video", "design"]),
        "create_file_signal": ("create" in tokens and "file" in tokens) or ("new" in tokens and "file" in tokens),
        "text_excerpt": merged[:500],
    }
    return cues

def _attempt_refresh_skynetv1_runtime(reason: str = "screen_learning") -> dict:
    if not SKYNETV1_AGENT_FILE.exists():
        return {"status": "missing", "reason": "skynetv1 agent file not found"}
    try:
        spec = importlib.util.spec_from_file_location("skynetv1_agent_runtime", str(SKYNETV1_AGENT_FILE))
        if spec is None or spec.loader is None:
            return {"status": "error", "reason": "unable to load skynetv1 module spec"}
        module = importlib.util.module_from_spec(spec)
        spec.loader.exec_module(module)
        refresh_fn = getattr(module, "refresh_live_site_template", None)
        if callable(refresh_fn):
            ok = bool(refresh_fn(reason=reason))
            return {"status": "ok" if ok else "error", "reason": "runtime refresh failed" if not ok else ""}
        return {"status": "missing", "reason": "refresh_live_site_template not available"}
    except Exception as exc:
        return {"status": "error", "reason": str(exc)[:200]}

def _apply_autonomous_website_mutation(cues: dict, policy: dict) -> dict:
    template_path = Path(str(policy.get("screen_learning_target_website_template", SKYNETV1_TEMPLATE_FILE))).expanduser().resolve()
    state_path = Path(str(policy.get("screen_learning_target_website_state", SKYNETV1_WEBSITE_STATE_FILE))).expanduser().resolve()
    timestamp = datetime.now().isoformat()
    marker = f"<!-- skynetv2-autonomous:{datetime.now().strftime('%Y%m%d%H%M%S')} -->"
    keywords = cues.get("keywords", []) if isinstance(cues.get("keywords", []), list) else []
    section_html = (
        "\n"
        f"{marker}\n"
        "<section class=\"card\" id=\"skynetv2-autonomous-updates\">\n"
        "  <h2>Autonomous Update</h2>\n"
        f"  <p>Generated at {xml_escape(timestamp)} from live screen/page observations.</p>\n"
        f"  <p>Detected cues: {xml_escape(', '.join(keywords) or 'none')}</p>\n"
        f"  <p>Summary: {xml_escape(str(cues.get('text_excerpt', ''))[:240])}</p>\n"
        "</section>\n"
    )

    result = {"status": "ok", "mutated_files": [], "runtime_refresh": {"status": "skipped", "reason": ""}}
    try:
        if template_path.exists() and template_path.is_file():
            original = template_path.read_text(encoding="utf-8")
            if marker not in original:
                if "</body>" in original:
                    updated = original.replace("</body>", section_html + "\n</body>")
                else:
                    updated = original + section_html
                template_path.write_text(updated, encoding="utf-8")
                result["mutated_files"].append(str(template_path))

        state_payload = read_json(state_path)
        if not isinstance(state_payload, dict):
            state_payload = {}
        updates = state_payload.get("autonomous_updates", []) if isinstance(state_payload.get("autonomous_updates", []), list) else []
        updates.append(
            {
                "at": timestamp,
                "source": "screen_learning",
                "keywords": keywords,
                "summary": str(cues.get("text_excerpt", ""))[:300],
            }
        )
        state_payload["autonomous_updates"] = updates[-400:]
        state_payload["updated_at"] = timestamp
        write_json(state_path, state_payload)
        result["mutated_files"].append(str(state_path))
    except Exception as exc:
        return {"status": "error", "reason": str(exc)[:200], "mutated_files": result.get("mutated_files", [])}

    if bool(policy.get("screen_learning_runtime_refresh_enabled", True)):
        result["runtime_refresh"] = _attempt_refresh_skynetv1_runtime(reason="screen_learning_mutation")
    return result

def _create_autonomous_observation_file(cues: dict, policy: dict) -> dict:
    if not bool(policy.get("screen_learning_create_files_enabled", True)):
        return {"status": "skipped", "reason": "disabled"}
    target_dir = Path(str(policy.get("screen_learning_autonomous_generated_dir", BASE_DIR / "autonomous_generated" / "screen"))).expanduser().resolve()
    target_dir.mkdir(parents=True, exist_ok=True)
    stamp = datetime.now().strftime("%Y%m%d_%H%M%S")
    out_path = target_dir / f"screen_observation_{stamp}.md"
    lines = [
        "# Autonomous Screen Observation",
        "",
        f"- at: {datetime.now().isoformat()}",
        f"- keywords: {', '.join(cues.get('keywords', []))}",
        "",
        "## Summary",
        str(cues.get("text_excerpt", "")),
        "",
    ]
    out_path.write_text("\n".join(lines), encoding="utf-8")
    return {"status": "created", "file": str(out_path)}

def run_autonomous_screen_learning_cycle(policy: dict, force: bool = False) -> dict:
    global _last_screen_learning_at
    if not bool(policy.get("screen_learning_enabled", True)):
        return {"status": "disabled"}

    now = time.time()
    interval_sec = max(10, int(policy.get("screen_learning_interval_sec", 120)))
    if not force and (now - _last_screen_learning_at) < interval_sec:
        return {"status": "skipped", "reason": "interval", "next_in_sec": int(interval_sec - (now - _last_screen_learning_at))}

    max_chars = max(512, int(policy.get("screen_learning_max_chars", 12000)))
    timeout_sec = max(2.0, float(policy.get("web_timeout_sec", 12)))
    observations = []
    text_blocks = []

    if bool(policy.get("screen_learning_dom_enabled", True)):
        dom_urls = policy.get("screen_learning_dom_urls", ["http://127.0.0.1:5050/"])
        if not isinstance(dom_urls, list):
            dom_urls = ["http://127.0.0.1:5050/"]
        for raw_url in dom_urls[:8]:
            obs = _fetch_dom_observation(str(raw_url), timeout_sec=timeout_sec, max_chars=max_chars)
            observations.append(obs)
            if obs.get("ok") and obs.get("text"):
                text_blocks.append(str(obs.get("text")))

    if bool(policy.get("screen_learning_ocr_enabled", True)):
        ocr_obs = _capture_ocr_screen_text(policy)
        observations.append(ocr_obs)
        if ocr_obs.get("ok") and ocr_obs.get("text"):
            text_blocks.append(str(ocr_obs.get("text")))

    if not text_blocks:
        _last_screen_learning_at = now
        return {"status": "no_data", "observations": observations}

    cues = _extract_screen_cues(text_blocks)
    observation_record = {
        "at": datetime.now().isoformat(),
        "observations": observations,
        "cues": cues,
        "text_chars": sum(len(block) for block in text_blocks),
    }
    history_path = Path(str(policy.get("screen_learning_history_file", SCREEN_OBSERVATION_FILE))).expanduser().resolve()
    history = load_screen_observations(history_path)
    runs = history.get("observations", []) if isinstance(history.get("observations", []), list) else []
    runs.append(observation_record)
    history["observations"] = runs[-500:]
    history["last_run"] = observation_record
    history["updated_at"] = datetime.now().isoformat()
    save_screen_observations(history, history_path)

    memory = load_agent_memory()
    memory["facts"] = _append_limited(
        memory.get("facts", []),
        {
            "at": datetime.now().isoformat(),
            "screen_learning": {
                "keywords": cues.get("keywords", []),
                "has_error": cues.get("has_error", False),
                "needs_deployment": cues.get("needs_deployment", False),
                "website_signal": cues.get("website_signal", False),
            },
        },
        1000,
    )
    memory["updated_at"] = datetime.now().isoformat()
    save_agent_memory(memory)

    if bool(cues.get("has_error", False)):
        queue_code_rewrite(
            reason=f"screen_learning observed runtime/UI error markers: {cues.get('text_excerpt', '')[:120]}",
            source="screen_learning",
            severity="high",
        )
    if bool(cues.get("needs_deployment", False)):
        enqueue_kernel_command("prepare_deployment", source="screen_learning", metadata={"from": "screen_observation"})

    mutation_result = {"status": "skipped", "reason": "not_requested"}
    if bool(policy.get("screen_learning_mutation_enabled", True)) and bool(cues.get("website_signal", False)):
        mutation_result = _apply_autonomous_website_mutation(cues, policy)

    generated_file = {"status": "skipped", "reason": "no_create_signal"}
    if bool(cues.get("create_file_signal", False)):
        generated_file = _create_autonomous_observation_file(cues, policy)

    _last_screen_learning_at = now
    return {
        "status": "ok",
        "cues": cues,
        "observations": observations,
        "mutation": mutation_result,
        "generated_file": generated_file,
    }

def transcribe_voice_audio_file(audio_path: Path, policy: dict) -> str:
    path = Path(audio_path)
    if not path.exists() or not path.is_file():
        return ""

    transcriber = str(policy.get("kernel_voice_transcriber_command", "")).strip()
    model_name = str(policy.get("kernel_voice_model", "base")).strip() or "base"

    if transcriber:
        command = transcriber.replace("{audio}", str(path)).replace("{model}", model_name)
        try:
            result = subprocess.run(
                shlex.split(command),
                capture_output=True,
                text=True,
                timeout=max(30, int(policy.get("kernel_voice_transcriber_timeout_sec", 120))),
                check=False,
            )
            if result.returncode == 0 and (result.stdout or "").strip():
                return (result.stdout or "").strip()
        except Exception as exc:
            log_action(f"Voice transcriber command failed for {path}: {exc}")

    if shutil.which("whisper"):
        try:
            result = subprocess.run(
                [
                    "whisper",
                    str(path),
                    "--model",
                    model_name,
                    "--language",
                    "en",
                    "--task",
                    "transcribe",
                    "--output_format",
                    "txt",
                    "--output_dir",
                    str(path.parent),
                ],
                capture_output=True,
                text=True,
                timeout=max(30, int(policy.get("kernel_voice_transcriber_timeout_sec", 120))),
                check=False,
            )
            txt_path = path.with_suffix(".txt")
            if result.returncode == 0 and txt_path.exists():
                return txt_path.read_text(encoding="utf-8", errors="replace").strip()
        except Exception as exc:
            log_action(f"Whisper transcription failed for {path}: {exc}")
    return ""

def queue_user_request(message: str, source: str = "system", context: dict | None = None, request_type: str = "question") -> dict:
    text = str(message or "").strip()
    if not text:
        return {"status": "ignored_empty_message"}

    state = load_user_dialog_state()
    queue = state.get("queue", []) if isinstance(state.get("queue", []), list) else []
    active = state.get("active_request", {}) if isinstance(state.get("active_request", {}), dict) else {}

    signature = hashlib.sha256(f"{source}|{request_type}|{text}".encode("utf-8")).hexdigest()[:20]
    for item in queue:
        if isinstance(item, dict) and item.get("signature") == signature and item.get("status") == "queued":
            return {"status": "already_queued", "request_id": item.get("id", "")}
    if active and active.get("signature") == signature and active.get("status") == "waiting_user_reply":
        return {"status": "already_active", "request_id": active.get("id", "")}

    request_id = hashlib.sha256(f"{time.time()}|{source}|{text}".encode("utf-8")).hexdigest()[:16]
    entry = {
        "id": request_id,
        "signature": signature,
        "message": text,
        "source": str(source or "system"),
        "request_type": str(request_type or "question"),
        "context": context if isinstance(context, dict) else {},
        "created_at": datetime.now().isoformat(),
        "status": "queued",
    }
    queue.append(entry)
    state["queue"] = queue[-200:]
    state["updated_at"] = datetime.now().isoformat()
    save_user_dialog_state(state)
    return {"status": "queued", "request_id": request_id}

def _try_capture_popup_reply(request: dict, policy: dict, full_text: str) -> str:
    timeout_sec = max(30, int(policy.get("user_dialog_popup_entry_timeout_sec", 600)))

    if shutil.which("zenity"):
        result = subprocess.run(
            [
                "zenity",
                "--entry",
                "--title",
                "Skynetv2 Request",
                "--width",
                "620",
                "--text",
                full_text,
                "--timeout",
                str(timeout_sec),
            ],
            capture_output=True,
            text=True,
            timeout=timeout_sec + 5,
            check=False,
        )
        if result.returncode == 0:
            return (result.stdout or "").strip()
        return ""

    if shutil.which("kdialog"):
        result = subprocess.run(
            ["kdialog", "--title", "Skynetv2 Request", "--inputbox", full_text],
            capture_output=True,
            text=True,
            timeout=timeout_sec,
            check=False,
        )
        if result.returncode == 0:
            return (result.stdout or "").strip()
    return ""

def _submit_popup_reply_if_still_active(request_id: str, reply_text: str) -> bool:
    state = load_user_dialog_state()
    active = state.get("active_request", {}) if isinstance(state.get("active_request", {}), dict) else {}
    if not active:
        return False
    if str(active.get("id", "")).strip() != str(request_id or "").strip():
        return False
    if active.get("status") != "waiting_user_reply":
        return False

    result = submit_user_reply(reply_text)
    return result.get("status") == "reply_recorded"

def _popup_user_request(request: dict, policy: dict):
    message = str(request.get("message", "")).strip()
    if not message:
        return
    request_id = str(request.get("id", "")).strip()
    cmd_hint = "python3 cnt.pyynetv2_agent.py --user-reply \"your response\""
    full_text = (
        "Skynetv2 needs your input:\n\n"
        f"{message}\n\n"
        "Type your reply below and press OK.\n"
        "(If you close this window, use the CLI reply command.)\n\n"
        "Reply command:\n"
        f"{cmd_hint}"
    )

    if not bool(policy.get("user_dialog_popup_enabled", True)):
        log_action(f"USER INPUT NEEDED: {message} | reply with: {cmd_hint}")
        return

    def worker():
        try:
            reply = _try_capture_popup_reply(request, policy, full_text)
            if reply and _submit_popup_reply_if_still_active(request_id, reply):
                log_action(f"Captured popup reply for request {request_id}.")
                return

            if shutil.which("notify-send"):
                subprocess.Popen(
                    ["notify-send", "Skynetv2 Request", f"{message}\nReply with --user-reply"],
                    stdout=subprocess.DEVNULL,
                    stderr=subprocess.DEVNULL,
                )
            log_action(f"USER INPUT NEEDED: {message} | reply with: {cmd_hint}")
        except Exception as exc:
            log_action(f"Failed to display popup notification: {exc}")
        finally:
            if request_id:
                with _user_popup_lock:
                    _active_popup_request_ids.discard(request_id)

    if request_id:
        with _user_popup_lock:
            if request_id in _active_popup_request_ids:
                return
            _active_popup_request_ids.add(request_id)

    thread = threading.Thread(target=worker, daemon=True)
    thread.start()

def _queue_periodic_user_checkin(policy: dict):
    global _last_user_talk_at
    if not bool(policy.get("user_dialog_enabled", True)):
        return
    now = time.time()
    interval = max(300, int(policy.get("user_dialog_talk_interval_sec", 3600)))
    if now - _last_user_talk_at < interval:
        return
    _last_user_talk_at = now
    queue_user_request(
        message="Quick check-in: do you want me to prioritize speed, stability, or new features right now?",
        source="periodic_checkin",
        context={"kind": "talk"},
        request_type="checkin",
    )

def maybe_process_user_dialog(policy: dict) -> dict:
    if not bool(policy.get("user_dialog_enabled", True)):
        return {"status": "disabled"}

    state = load_user_dialog_state()
    active = state.get("active_request", {}) if isinstance(state.get("active_request", {}), dict) else {}
    queue = state.get("queue", []) if isinstance(state.get("queue", []), list) else []

    # One-at-a-time gate: never ask another question until active one is answered.
    if active and active.get("status") == "waiting_user_reply":
        remind_sec = max(120, int(policy.get("user_dialog_reminder_interval_sec", 1200)))
        asked_at = _parse_iso_timestamp(active.get("asked_at", ""))
        if asked_at and (time.time() - asked_at.timestamp()) >= remind_sec and not bool(active.get("reminder_sent", False)):
            _popup_user_request(active, policy)
            active["reminder_sent"] = True
            active["reminded_at"] = datetime.now().isoformat()
            state["active_request"] = active
            state["updated_at"] = datetime.now().isoformat()
            save_user_dialog_state(state)
        return {"status": "waiting_user_reply", "active_request_id": active.get("id", "")}

    _queue_periodic_user_checkin(policy)
    state = load_user_dialog_state()
    queue = state.get("queue", []) if isinstance(state.get("queue", []), list) else []
    if not queue:
        return {"status": "idle"}

    next_item = None
    remaining = []
    for item in queue:
        if next_item is None and isinstance(item, dict) and item.get("status") == "queued":
            next_item = item
            continue
        remaining.append(item)

    if not isinstance(next_item, dict):
        state["queue"] = remaining[-200:]
        state["updated_at"] = datetime.now().isoformat()
        save_user_dialog_state(state)
        return {"status": "idle"}

    next_item["status"] = "waiting_user_reply"
    next_item["asked_at"] = datetime.now().isoformat()
    next_item["reminder_sent"] = False
    state["active_request"] = next_item
    state["queue"] = remaining[-200:]
    state["updated_at"] = datetime.now().isoformat()
    save_user_dialog_state(state)

    _popup_user_request(next_item, policy)
    log_action(f"Asked user request {next_item.get('id','')}: {next_item.get('message','')}")
    return {"status": "asked", "request_id": next_item.get("id", "")}

def submit_user_reply(reply_text: str) -> dict:
    text = str(reply_text or "").strip()
    if not text:
        return {"status": "empty_reply"}

    state = load_user_dialog_state()
    active = state.get("active_request", {}) if isinstance(state.get("active_request", {}), dict) else {}
    if not active or active.get("status") != "waiting_user_reply":
        return {"status": "no_pending_request"}

    active["status"] = "answered"
    active["answered_at"] = datetime.now().isoformat()
    active["user_reply"] = text
    history = state.get("history", []) if isinstance(state.get("history", []), list) else []
    history.append(active)
    state["history"] = history[-400:]
    state["active_request"] = {}
    state["updated_at"] = datetime.now().isoformat()
    save_user_dialog_state(state)

    log_action(f"Received user reply for request {active.get('id','')}: {text[:180]}")
    return {
        "status": "reply_recorded",
        "request_id": active.get("id", ""),
        "source": active.get("source", ""),
        "request_type": active.get("request_type", ""),
    }

def _append_limited(records: list[dict], item: dict, max_items: int) -> list[dict]:
    if not isinstance(records, list):
        records = []
    if isinstance(item, dict):
        records.append(item)
    return records[-max_items:]

def update_memory_and_skill_adaptation(policy: dict) -> dict:
    rewrite_log = load_auto_rewrite_log()
    last_run = rewrite_log.get("last_test_run", {}) if isinstance(rewrite_log, dict) else {}
    self_heal = load_self_heal_outcomes()
    web_data = read_json(WEB_INTELLIGENCE_FILE)
    if not isinstance(web_data, dict):
        web_data = {"visits": [], "queries": []}

    scanned_files = int(last_run.get("scanned_files", 0) or 0)
    attempted_rewrites = int(last_run.get("attempted_rewrites", 0) or 0)
    kept = int(last_run.get("kept", 0) or 0)
    rolled_back = int(last_run.get("rolled_back", 0) or 0)
    canary_tripped = bool(last_run.get("canary_tripped", False))
    visits_count = len(web_data.get("visits", [])) if isinstance(web_data.get("visits", []), list) else 0
    queries_count = len(web_data.get("queries", [])) if isinstance(web_data.get("queries", []), list) else 0
    stats = self_heal.get("stats", {}) if isinstance(self_heal, dict) else {}

    memory = load_agent_memory()
    snapshot = {
        "at": datetime.now().isoformat(),
        "scanned_files": scanned_files,
        "attempted_rewrites": attempted_rewrites,
        "kept": kept,
        "rolled_back": rolled_back,
        "canary_tripped": canary_tripped,
        "web_visits": visits_count,
        "web_queries": queries_count,
        "self_heal_evaluated": int(stats.get("evaluated_total", 0) or 0),
        "self_heal_success": int(stats.get("success_total", 0) or 0),
        "self_heal_failure": int(stats.get("failure_total", 0) or 0),
    }
    memory["facts"] = _append_limited(memory.get("facts", []), snapshot, 1000)

    issues = []
    if scanned_files > 0 and attempted_rewrites == 0:
        issues.append("rewrite_stall_no_transform_candidates")
    if rolled_back > kept and (rolled_back + kept) >= 4:
        issues.append("rewrite_validation_failures_high")
    if visits_count == 0:
        issues.append("web_learning_not_started")
    if canary_tripped:
        issues.append("canary_failure_threshold_exceeded")

    if issues:
        memory["issues"] = _append_limited(
            memory.get("issues", []),
            {
                "at": datetime.now().isoformat(),
                "issues": issues,
                "context": {
                    "scanned_files": scanned_files,
                    "attempted_rewrites": attempted_rewrites,
                    "kept": kept,
                    "rolled_back": rolled_back,
                    "web_visits": visits_count,
                },
            },
            400,
        )

    memory["updated_at"] = datetime.now().isoformat()
    save_agent_memory(memory)

    skill_payload = load_skill_adaptation()
    skills = []
    recommendations = []
    gaps = []

    if "rewrite_stall_no_transform_candidates" in issues:
        gaps.append("rewrite_candidate_generation")
        skills.append("safe_text_normalization_transforms")
        recommendations.append("Add additional safe transforms so rewrite pass can produce candidate edits.")
    if "rewrite_validation_failures_high" in issues:
        gaps.append("test_safe_rewrites")
        skills.append("risk_scored_refactoring")
        recommendations.append("Tighten rewrite scope and improve transform risk scoring to reduce rollbacks.")
    if visits_count > 0:
        skills.append("web_signal_ingestion")
    else:
        gaps.append("web_context_learning")
        recommendations.append("Enable web lookup and run synthesis loop to collect learning signals.")

    skill_payload["skills"] = sorted(set((skill_payload.get("skills", []) if isinstance(skill_payload.get("skills", []), list) else []) + skills))[-200:]
    skill_payload["gaps"] = _append_limited(
        skill_payload.get("gaps", []),
        {
            "at": datetime.now().isoformat(),
            "items": sorted(set(gaps)),
        },
        300,
    )
    skill_payload["recommendations"] = _append_limited(
        skill_payload.get("recommendations", []),
        {
            "at": datetime.now().isoformat(),
            "items": sorted(set(recommendations)),
        },
        300,
    )
    skill_payload["updated_at"] = datetime.now().isoformat()
    save_skill_adaptation(skill_payload)

    return {
        "updated_at": datetime.now().isoformat(),
        "issues": issues,
        "skills_added": sorted(set(skills)),
        "recommendations": sorted(set(recommendations)),
        "snapshot": snapshot,
    }

def maybe_update_memory_and_skill_adaptation(policy: dict) -> dict:
    global _last_memory_skill_update_at
    if not bool(policy.get("memory_skill_autoupdate_enabled", True)):
        return {"status": "disabled"}

    interval = max(60, int(policy.get("memory_skill_update_interval_sec", 600)))
    now = time.time()
    if now - _last_memory_skill_update_at < interval:
        return {"status": "backoff"}

    _last_memory_skill_update_at = now
    result = update_memory_and_skill_adaptation(policy)
    return {"status": "ok", "result": result}

def _max_change_size_bytes_from_policy(policy):
    gb_value = policy.get("max_change_size_gb")
    if gb_value is not None:
        try:
            gb_float = max(0.0, float(gb_value))
            return max(1, int(gb_float * float(1024 ** 3)))
        except Exception:
            pass
    try:
        return max(1, int(policy.get("max_change_size_bytes", 1048576)))
    except Exception:
        return 1048576

def _max_change_size_bytes_for_path(path: Path, policy: dict) -> int:
    by_ext = policy.get("max_change_size_gb_by_extension", {})
    if isinstance(by_ext, dict):
        gb_value = by_ext.get(path.suffix.lower())
        if gb_value is not None:
            try:
                return max(1, int(max(0.0, float(gb_value)) * float(1024 ** 3)))
            except Exception:
                pass
    return _max_change_size_bytes_from_policy(policy)

def _module_status_from_runtime(module_key):
    if module_key == "database_storage":
        return "active"
    if module_key == "task_scheduling":
        return "active" if LOOP_INTERVAL > 0 else "degraded"
    if module_key == "monitoring":
        return "active" if psutil is not None else "degraded"
    if module_key == "security_monitoring":
        return "active"
    if module_key == "agent_swarm":
        return "active"
    if module_key == "replication_scaling":
        # Swarm discovery/remediation is built in, so mark as active capability.
        return "active"
    if module_key == "web_scraping":
        # Web intelligence uses urllib-based collection in this runtime.
        return "active"
    if module_key == "notifications":
        smtp_user = os.environ.get("GMAIL_USER") or os.environ.get("SMTP_USER")
        smtp_password = os.environ.get("GMAIL_APP_PASSWORD") or os.environ.get("SMTP_PASSWORD") or os.environ.get("SMTP_PASS")
        return "configured" if smtp_user and smtp_password else "stubbed"
    if module_key == "llm_ai":
        ollama_healthy = bool(_last_ollama_health_snapshot.get("healthy", False)) if isinstance(_last_ollama_health_snapshot, dict) else False
        backup_healthy = bool(_last_local_neural_health_snapshot.get("healthy", False)) if isinstance(_last_local_neural_health_snapshot, dict) else False
        if ollama_healthy:
            return "active"
        if backup_healthy:
            return "configured"
        return "degraded" if OLLAMA_URL else "stubbed"
    if module_key == "external_apis":
        key_count = 0
        for name in ["WEATHER_API_KEY", "NEWS_API_KEY", "GITHUB_TOKEN", "FINANCE_API_KEY"]:
            if os.environ.get(name):
                key_count += 1
        if key_count >= 1:
            return "implemented"
        # Public endpoint integrations are still available without paid API keys.
        return "configured" if importlib.util.find_spec("requests") else "stubbed"
    if module_key == "user_auth":
        jwt_key = os.environ.get("JWT_SECRET")
        oauth_client = os.environ.get("OAUTH_CLIENT_ID")
        return "implemented" if jwt_key or oauth_client else "stubbed"
    if module_key == "voice_audio":
        whisper_installed = bool(importlib.util.find_spec("whisper"))
        faster_whisper_installed = bool(importlib.util.find_spec("faster_whisper"))
        return "implemented" if (whisper_installed or faster_whisper_installed) else "stubbed"
    return "stubbed"

def _module_completion_criteria(module_key):
    criteria = {
        "required": [],
        "passed": [],
        "complete": False,
        "ratio": 0.0,
    }
    if module_key == "llm_ai":
        criteria["required"] = ["OLLAMA_URL configured", "local neural backup available"]
        if OLLAMA_URL:
            criteria["passed"].append("OLLAMA_URL configured")
        backup_healthy = bool(_last_local_neural_health_snapshot.get("healthy", False)) if isinstance(_last_local_neural_health_snapshot, dict) else False
        if backup_healthy:
            criteria["passed"].append("local neural backup available")
    elif module_key == "notifications":
        criteria["required"] = ["SMTP user configured", "SMTP password configured"]
        if os.environ.get("GMAIL_USER") or os.environ.get("SMTP_USER"):
            criteria["passed"].append("SMTP user configured")
        if os.environ.get("GMAIL_APP_PASSWORD") or os.environ.get("SMTP_PASSWORD") or os.environ.get("SMTP_PASS"):
            criteria["passed"].append("SMTP password configured")
    elif module_key == "external_apis":
        criteria["required"] = ["At least one external API key or HTTP API client"]
        for name in ["WEATHER_API_KEY", "NEWS_API_KEY", "GITHUB_TOKEN", "FINANCE_API_KEY"]:
            if os.environ.get(name):
                criteria["passed"].append("At least one external API key or HTTP API client")
                break
        if not criteria["passed"] and importlib.util.find_spec("requests"):
            criteria["passed"].append("At least one external API key or HTTP API client")
    elif module_key == "user_auth":
        criteria["required"] = ["JWT secret or OAuth client id"]
        if os.environ.get("JWT_SECRET") or os.environ.get("OAUTH_CLIENT_ID"):
            criteria["passed"].append("JWT secret or OAuth client id")
    elif module_key == "voice_audio":
        criteria["required"] = ["whisper or faster_whisper package installed"]
        if importlib.util.find_spec("whisper") or importlib.util.find_spec("faster_whisper"):
            criteria["passed"].append("whisper or faster_whisper package installed")
    else:
        criteria["required"] = ["runtime heartbeat"]
        criteria["passed"].append("runtime heartbeat")

    required_count = len(criteria["required"])
    passed_count = len(criteria["passed"])
    criteria["complete"] = required_count > 0 and passed_count >= required_count
    criteria["ratio"] = round(float(passed_count) / float(required_count), 3) if required_count else 1.0
    return criteria

def refresh_module_statuses():
    def mutate(state):
        modules = state.get("modules", {})
        if not isinstance(modules, dict):
            return
        for key, module in modules.items():
            if not isinstance(module, dict):
                continue
            module["status"] = _module_status_from_runtime(key)
            module["completion"] = _module_completion_criteria(key)
            module["last_status_refresh"] = datetime.now().isoformat()
        state["last_updated"] = datetime.now().isoformat()

    update_registry_state(mutate)

def evaluate_progress_milestones():
    def mutate(state):
        modules = state.get("modules", {})
        active_count = 0
        total_modules = 0
        for module in modules.values() if isinstance(modules, dict) else []:
            total_modules += 1
            status = str(module.get("status", "")).lower()
            if status in {"active", "configured"}:
                active_count += 1

        rewrite_log = load_auto_rewrite_log()
        file_rewrites = len(rewrite_log.get("rewrites", []))
        rewrite_history = load_rewrite_history()

        stats = state.setdefault("synthesis_stats", {})
        stats["active_or_configured_modules"] = active_count
        stats["rewrite_history_entries"] = len(rewrite_history)
        stats["file_rewrites_logged"] = file_rewrites
        stats["last_progress_check"] = datetime.now().isoformat()

        milestones = stats.setdefault("milestones", {})
        milestones["framework_operational"] = bool(active_count >= 3)
        milestones["rewrite_rules_learning"] = bool(len(rewrite_history) > 0)
        milestones["workspace_file_rewrites"] = bool(file_rewrites > 0)

        rewrite_counts = state.get("rewrite_counts", {}) if isinstance(state.get("rewrite_counts"), dict) else {}
        rolled_back = int(rewrite_counts.get("rolled_back", 0) or 0)
        rewrite_quality = max(0.0, min(1.0, 1.0 - min(0.8, rolled_back / 20.0)))

        web_data = read_json(WEB_INTELLIGENCE_FILE)
        web_visits = 0
        recent_web_signal = 0.0
        if isinstance(web_data, dict):
            visits = web_data.get("visits", [])
            if isinstance(visits, list):
                web_visits = len(visits)
                recent_web_signal = min(1.0, web_visits / 30.0)

        service_data = load_service_registry()
        swarm_summary = service_data.get("swarm_scan_summary", {}) if isinstance(service_data, dict) else {}
        swarm_issues = int(swarm_summary.get("issue_signatures", 0) or 0)
        swarm_scanned = int(swarm_summary.get("services_scanned", 0) or 0)
        if swarm_scanned <= 0:
            swarm_health = 0.5
        else:
            issue_density = float(swarm_issues) / float(max(1, swarm_scanned))
            swarm_health = max(0.0, min(1.0, 1.0 - min(1.0, issue_density / 5.0)))

        module_health = float(active_count) / float(max(1, total_modules)) if total_modules else 1.0
        rewrite_health = max(0.0, min(1.0, min(1.0, len(rewrite_history) / 25.0) * rewrite_quality))
        web_health = recent_web_signal
        total_score = (
            module_health * 0.35
            + rewrite_health * 0.25
            + web_health * 0.15
            + swarm_health * 0.25
        )

        stats["ai_os_health_score"] = round(total_score * 100.0, 2)
        stats["ai_os_health_components"] = {
            "module_health": round(module_health, 3),
            "rewrite_health": round(rewrite_health, 3),
            "web_health": round(web_health, 3),
            "swarm_health": round(swarm_health, 3),
            "swarm_issue_signatures": swarm_issues,
            "swarm_services_scanned": swarm_scanned,
            "rolled_back_rewrites": rolled_back,
            "web_visits": web_visits,
        }
        stats["ai_os_health_updated_at"] = datetime.now().isoformat()

        if milestones["framework_operational"] and milestones["rewrite_rules_learning"] and milestones["workspace_file_rewrites"]:
            if not state.get("last_goal_met_at"):
                state["last_goal_met_at"] = datetime.now(SITE_TIMEZONE).isoformat()

    update_registry_state(mutate)

def _device_fingerprint(ip_address, mac_address):
    raw = f"{ip_address}|{mac_address}".encode("utf-8")
    return hashlib.sha256(raw).hexdigest()[:24]

def _parse_approved_networks(policy):
    networks = []
    for raw_value in policy.get("approved_subnets", []):
        try:
            networks.append(ipaddress.ip_network(str(raw_value).strip(), strict=False))
        except Exception:
            log_action(f"Skipping invalid approved subnet: {raw_value}")
    return networks

def _ip_allowed(ip_address, networks):
    if not networks:
        return False
    try:
        ip_obj = ipaddress.ip_address(ip_address)
    except Exception:
        return False
    return any(ip_obj in network for network in networks)

def _arp_candidates(networks):
    arp_path = Path("/proc/net/arp")
    if not arp_path.exists():
        return []
    try:
        lines = arp_path.read_text(encoding="utf-8").splitlines()
    except Exception as exc:
        log_action(f"Failed reading ARP table: {exc}")
        return []

    candidates = []
    seen = set()
    for line in lines[1:]:
        parts = line.split()
        if len(parts) < 4:
            continue
        ip_address = parts[0]
        mac_address = parts[3].lower()
        if mac_address == "00:00:00:00:00:00":
            continue
        if not _ip_allowed(ip_address, networks):
            continue
        key = (ip_address, mac_address)
        if key in seen:
            continue
        seen.add(key)
        candidates.append(
            {
                "ip": ip_address,
                "mac": mac_address,
                "discovered_at": datetime.now().isoformat(),
                "source": "arp",
            }
        )
    return candidates

def discover_devices():
    if not DEVICE_DISCOVERY_ENABLED:
        return []

    policy = load_network_scan_policy()
    if not policy.get("enabled", True):
        return []
    if not policy.get("enable_wifi_scans", False):
        return []

    current_ssid = _current_ssid()
    seen_ssids, changed = _sync_known_ssids_into_policy(policy)
    if _try_non_active_ssid_probe_once(policy, current_ssid, seen_ssids):
        changed = True
    if _normalize_stale_probe_attempts(policy, current_ssid):
        changed = True

    approved_ssids = set(str(item).strip() for item in policy.get("approved_ssids", []) if str(item).strip())
    require_ssid = bool(policy.get("require_approved_ssid", True))
    if require_ssid and approved_ssids:
        if current_ssid not in approved_ssids:
            log_action(f"Scan skipped; current SSID '{current_ssid or 'unknown'}' is not approved.")
            return []
    elif require_ssid and not approved_ssids:
        log_action("Scan skipped; SSID approval required but approved_ssids is empty.")
        return []

    networks = _known_scan_networks(policy)
    if _attempt_non_active_connect_probe_once(policy, current_ssid, seen_ssids, networks):
        changed = True

    networks = _known_scan_networks(policy)
    require_subnet = bool(policy.get("require_approved_subnet", True))
    if require_subnet and not networks:
        log_action("Scan skipped; subnet approval required but no approved or observed networks are available.")
        return []

    if changed:
        policy["updated_at"] = datetime.now().isoformat()
        write_json(NETWORK_SCAN_POLICY_FILE, policy)

    candidates = _arp_candidates(networks)
    return _queue_discovered_candidates(candidates, "approved_ssid_and_subnet_scan")

def _prompt_yes_no(prompt_text):
    while True:
        try:
            reply = input(f"\n{prompt_text}").strip().lower()
            if reply in {"y", "yes"}:
                return True
            if reply in {"n", "no", ""}:
                return False
            print("  ❌ Please enter y or n.")
        except EOFError:
            print("  ❌ No input available (not a TTY). Skipping.")
            return False
        except KeyboardInterrupt:
            print("\n  ❌ Interrupted by user.")
            return False

def process_device_enrollment_queue(force_non_interactive=False):
    if not force_non_interactive and not sys.stdin.isatty():
        return
    queue = load_device_enrollment_queue()
    pending_count = sum(1 for item in queue if item.get("status") == "pending")
    if pending_count == 0:
        print("No pending devices to review.")
        return

    print(f"\n{'='*70}")
    print(f"Device Enrollment Review ({pending_count} pending)")
    print(f"{'='*70}")

    registry = load_device_registry()
    enrolled = registry.setdefault("enrolled_devices", [])
    enrolled_ids = {item.get("fingerprint") for item in enrolled}
    changed = False

    for idx, entry in enumerate(queue, 1):
        if entry.get("status") != "pending":
            continue

        ip = entry.get("ip", "unknown")
        mac = entry.get("mac", "unknown")
        source = entry.get("source", "unknown")
        fingerprint = entry.get("fingerprint", "")
        discovered_at = entry.get("discovered_at", "")

        print(f"\n[Device {idx}]")
        print(f"  IP Address:  {ip}")
        print(f"  MAC Address: {mac}")
        print(f"  Source:      {source}")
        print(f"  Fingerprint: {fingerprint}")
        print(f"  Discovered:  {discovered_at}")

        prompt_text = f"  ➜ Approve enrollment for {ip} ({mac})? [y/N]: "
        approved = _prompt_yes_no(prompt_text)
        entry["reviewed_at"] = datetime.now().isoformat()
        entry["reviewed_by"] = "cli_prompt"
        if approved:
            entry["status"] = "approved"
            if fingerprint not in enrolled_ids:
                enrolled.append(
                    {
                        "fingerprint": fingerprint,
                        "ip": ip,
                        "mac": mac,
                        "source": source,
                        "enrolled_at": datetime.now().isoformat(),
                        "last_heartbeat_at": "",
                        "status": "active",
                    }
                )
                enrolled_ids.add(fingerprint)
            print(f"  ✅ APPROVED: {ip} is now enrolled.")
            registry["events"].append(
                {
                    "event": "device_enrolled",
                    "fingerprint": fingerprint,
                    "at": datetime.now().isoformat(),
                }
            )
        else:
            entry["status"] = "rejected"
            print(f"  ⛔ REJECTED: {ip} was rejected.")
            registry["events"].append(
                {
                    "event": "device_rejected",
                    "fingerprint": fingerprint,
                    "at": datetime.now().isoformat(),
                }
            )
        changed = True

    if changed:
        registry["events"] = registry["events"][-500:]
        save_device_enrollment_queue(queue)
        save_device_registry(registry)
        print(f"\n{'='*70}")
        print("Review complete. Changes saved.")
        print(f"{'='*70}\n")

def _popup_yes_no(title: str, message: str, default: bool = False) -> bool:
    title = str(title or "Skynetv2").strip() or "Skynetv2"
    message = str(message or "").strip()

    # Try desktop popup tools first.
    if shutil.which("zenity"):
        cmd = ["zenity", "--question", "--title", title, "--text", message]
        try:
            completed = subprocess.run(cmd, capture_output=True, text=True, timeout=15, check=False)
            return completed.returncode == 0
        except Exception:
            pass

    if shutil.which("kdialog"):
        cmd = ["kdialog", "--yesno", message, "--title", title]
        try:
            completed = subprocess.run(cmd, capture_output=True, text=True, timeout=15, check=False)
            return completed.returncode == 0
        except Exception:
            pass

    # Fallback to tkinter popup if available.
    try:
        import tkinter as tk
        from tkinter import messagebox

        root = tk.Tk()
        root.withdraw()
        value = bool(messagebox.askyesno(title, message))
        root.destroy()
        return value
    except Exception:
        pass

    # Final fallback: terminal prompt when popup tooling is unavailable.
    if sys.stdin.isatty():
        prompt = f"{title}\n{message}\nApprove? [y/N]: "
        return _prompt_yes_no(prompt)
    return bool(default)

def _run_popup_command_with_displays(command: list[str], timeout_sec: int = 15) -> tuple[bool, str]:
    """Try popup command across likely displays so desktop prompts are reliably visible."""
    displays = []
    for candidate in [
        os.environ.get("DISPLAY", "").strip(),
        ":10.0",
        ":10",
        ":0",
        ":1",
    ]:
        if candidate and candidate not in displays:
            displays.append(candidate)

    attempted = []
    for display in displays:
        env = os.environ.copy()
        env["DISPLAY"] = display
        if "XAUTHORITY" not in env or not str(env.get("XAUTHORITY", "")).strip():
            env["XAUTHORITY"] = str(Path.home() / ".Xauthority")
        try:
            completed = subprocess.run(
                command,
                capture_output=True,
                text=True,
                timeout=max(1, int(timeout_sec)),
                check=False,
                env=env,
            )
            # For timed/info popups we accept process launch as success.
            if completed.returncode in {0, 5}:
                return True, display
            attempted.append(f"{display}:{(completed.stderr or completed.stdout or '').strip()[:80]}")
        except Exception as exc:
            attempted.append(f"{display}:{str(exc)[:80]}")

    return False, " | ".join(attempted)[:240]

def _popup_info(title: str, message: str, is_error: bool = False):
    title = str(title or "Skynetv2").strip() or "Skynetv2"
    message = str(message or "").strip()

    if shutil.which("zenity"):
        mode = "--error" if is_error else "--info"
        cmd = ["zenity", mode, "--title", title, "--text", message]
        try:
            subprocess.run(cmd, capture_output=True, text=True, timeout=30, check=False)
            return
        except Exception:
            pass

    if shutil.which("kdialog"):
        mode = "--error" if is_error else "--msgbox"
        cmd = ["kdialog", mode, message, "--title", title]
        try:
            subprocess.run(cmd, capture_output=True, text=True, timeout=30, check=False)
            return
        except Exception:
            pass

    try:
        import tkinter as tk
        from tkinter import messagebox

        root = tk.Tk()
        root.withdraw()
        if is_error:
            messagebox.showerror(title, message)
        else:
            messagebox.showinfo(title, message)
        root.destroy()
        return
    except Exception:
        pass

    print(f"[{title}] {message}")

def _popup_timed_notice(title: str, message: str, timeout_sec: int = 5, is_error: bool = False) -> bool:
    title = str(title or "Skynetv2").strip() or "Skynetv2"
    message = str(message or "").strip()
    timeout_value = max(1, int(timeout_sec or 1))

    if shutil.which("zenity"):
        mode = "--error" if is_error else "--warning"
        cmd = ["zenity", mode, "--title", title, "--text", message, "--timeout", str(timeout_value)]
        ok, detail = _run_popup_command_with_displays(cmd, timeout_sec=timeout_value + 2)
        if ok:
            return True
        log_action(f"Popup backend zenity failed: {detail}")

    if shutil.which("kdialog"):
        try:
            if is_error:
                cmd = ["kdialog", "--error", message, "--title", title]
                ok, detail = _run_popup_command_with_displays(cmd, timeout_sec=timeout_value + 2)
            else:
                cmd = ["kdialog", "--title", title, "--passivepopup", message, str(timeout_value)]
                ok, detail = _run_popup_command_with_displays(cmd, timeout_sec=timeout_value + 2)
            if ok:
                return True
            log_action(f"Popup backend kdialog failed: {detail}")
        except Exception:
            pass

    if shutil.which("xmessage"):
        cmd = ["xmessage", "-center", "-timeout", str(timeout_value), f"{title}\n\n{message}"]
        ok, detail = _run_popup_command_with_displays(cmd, timeout_sec=timeout_value + 3)
        if ok:
            return True
        log_action(f"Popup backend xmessage failed: {detail}")

    if shutil.which("notify-send"):
        # Desktop notifications are best-effort and non-blocking; still count as visible attempt.
        cmd = ["notify-send", title, message, "-t", str(timeout_value * 1000)]
        ok, detail = _run_popup_command_with_displays(cmd, timeout_sec=5)
        if ok:
            return True
        log_action(f"Popup backend notify-send failed: {detail}")

    try:
        import tkinter as tk

        root = tk.Tk()
        root.title(title)
        root.attributes("-topmost", True)
        root.geometry("520x180")
        label = tk.Label(root, text=message, justify="left", wraplength=480)
        label.pack(fill="both", expand=True, padx=16, pady=16)
        root.after(timeout_value * 1000, root.destroy)
        root.mainloop()
        return True
    except Exception:
        pass

    print(f"[{title}] {message}")
    return False

def _resolve_progress_window_geometry(policy: dict) -> str:
    explicit = str(policy.get("local_input_progress_window_geometry", "")).strip()
    if explicit:
        return explicit

    width = max(280, int(policy.get("local_input_progress_window_width", 420) or 420))
    height = max(160, int(policy.get("local_input_progress_window_height", 220) or 220))
    margin_x = max(0, int(policy.get("local_input_progress_window_margin_x", 24) or 24))
    margin_y = max(0, int(policy.get("local_input_progress_window_margin_y", 40) or 40))
    screen_width = max(width + margin_x, int(policy.get("local_input_progress_window_screen_width", 1280) or 1280))
    screen_height = max(height + margin_y, int(policy.get("local_input_progress_window_screen_height", 800) or 800))
    edge = str(policy.get("local_input_progress_window_edge", "right")).strip().lower() or "right"

    x = margin_x
    y = margin_y
    if edge in {"right", "top-right"}:
        x = max(0, screen_width - width - margin_x)
        y = margin_y
    elif edge == "bottom-right":
        x = max(0, screen_width - width - margin_x)
        y = max(0, screen_height - height - margin_y)
    elif edge == "bottom-left":
        x = margin_x
        y = max(0, screen_height - height - margin_y)
    elif edge in {"left", "top-left"}:
        x = margin_x
        y = margin_y

    return f"{width}x{height}+{x}+{y}"

def _infer_ui_action_phase(action: dict) -> str:
    explicit = str(action.get("phase", "")).strip()
    if explicit:
        return explicit

    text = " ".join(
        str(action.get(key, ""))
        for key in ["label", "text", "key", "type"]
        if str(action.get(key, "")).strip()
    ).lower()

    phase_rules = [
        ("starting", ["ctrl+grave", "activate_window", "opening terminal"]),
        ("scanning workspace", ["ls -lah create", "find create -name", "du -sh create", "pwd &&"]),
        ("validating python", ["python --version", "pip list", "py_compile", "compilation ok"]),
        ("summarizing state", ["workspace_summary", "agent_memory", "workspace_policy", "jq '.policy_version'", "jq '.allow_auto_rewrite'"]),
        ("scanning logs", ["error tracking", "traceback", "tail -30", "grep -c 'exception", "failure_digest"]),
        ("prioritizing fixes", ["prioritized_fix_queue", "rewrite backlog", "pending rewrites"]),
        ("testing", ["pytest", "running tests"]),
        ("reviewing git", ["git status", "git log", "git diff"]),
        ("checking containers", ["docker status", "docker ps", "docker configs"]),
        ("scanning network", ["network status", "ip addr", "netstat"]),
        ("reviewing dependencies", ["project dependencies", "grep -h import", "pip list"]),
        ("writing report", ["status_report", "writing report", "ui_cycle_reports", "mkdir -p create/autonomous_generated/ui_cycle_reports"]),
        ("collecting metrics", ["workspace metrics", "total python files", "total json configs"]),
        ("planning next fixes", ["optimization queue", "profile hot paths", "document api interfaces"]),
    ]
    for phase_name, markers in phase_rules:
        if any(marker in text for marker in markers):
            return phase_name
    return "running workspace review"

def _generate_autonomous_ui_workspace_artifacts(policy: dict, pending_count: int) -> dict:
    artifact_dir = Path(
        str(policy.get("autonomous_ui_output_dir", BASE_DIR / "autonomous_generated" / "ui_cycle_reports"))
    ).expanduser().resolve()
    artifact_dir.mkdir(parents=True, exist_ok=True)

    # NEW: Use comprehensive workspace analysis instead of just reading existing files
    workspace_analysis = analyze_workspace_comprehensive(WORKSPACE_ROOT)

    backlog = _sort_backlog_by_priority(load_rewrite_backlog())
    rewrite_log = load_auto_rewrite_log()
    last_test_run = rewrite_log.get("last_test_run", {}) if isinstance(rewrite_log, dict) else {}
    memory = load_agent_memory()
    self_heal = load_self_heal_outcomes()

    backlog_items = []
    for item in backlog[:25]:
        if not isinstance(item, dict):
            continue
        backlog_items.append(
            {
                "source": str(item.get("source", "")),
                "severity": str(item.get("severity", "")),
                "status": str(item.get("status", "")),
                "priority_score": int(item.get("priority_score", 0) or 0),
                "reason": _compact_text(str(item.get("reason", "")))[:220],
            }
        )

    recent_failures = []
    try:
        if LOG_FILE.exists():
            log_lines = LOG_FILE.read_text(encoding="utf-8", errors="ignore").splitlines()
            for line in reversed(log_lines[-400:]):
                lowered = line.lower()
                if any(marker in lowered for marker in ["error", "exception", "traceback", "failed"]):
                    recent_failures.append(line[-280:])
                if len(recent_failures) >= 12:
                    break
    except Exception:
        recent_failures = []

    workspace_summary = {
        "generated_at": datetime.now().isoformat(),
        "pending_rewrites": pending_count,
        "rewrite_backlog_total": len(backlog),
        "rewrite_backlog_status_counts": {
            status: sum(1 for item in backlog if str(item.get("status", "")) == status)
            for status in sorted({str(item.get("status", "")) for item in backlog if isinstance(item, dict)})
        },
        "auto_rewrite_last_test_run": last_test_run,
        "policy_flags": {
            "autonomous_ui_worker_enabled": bool(policy.get("autonomous_ui_worker_enabled", False)),
            "workspace_runtime_checks_enabled": bool(policy.get("workspace_runtime_checks_enabled", False)),
            "enable_packet_capture": bool(policy.get("enable_packet_capture", False)),
        },
        "memory_facts_count": len(memory.get("facts", [])) if isinstance(memory.get("facts", []), list) else 0,
        "self_heal_stats": self_heal.get("stats", {}) if isinstance(self_heal, dict) else {},
        "workspace_analysis": workspace_analysis,  # NEW: Comprehensive workspace health data
    }

    registry_data = read_json(REGISTRY_FILE) or {}
    failure_digest = {
        "generated_at": datetime.now().isoformat(),
        "recent_failure_lines": list(reversed(recent_failures)),
        "top_backlog_failures": backlog_items[:10],
        "last_rewrite_execution": registry_data.get("last_rewrite_execution", {}) if isinstance(registry_data, dict) else {},
    }

    prioritized_fix_queue = {
        "generated_at": datetime.now().isoformat(),
        "items": [
            {
                "rank": index + 1,
                **item,
            }
            for index, item in enumerate(backlog_items)
        ],
    }

    status_report_lines = [
        "SKYNETV2 AUTONOMOUS REVIEW REPORT",
        f"generated_at: {datetime.now().isoformat()}",
        f"pending_rewrites: {pending_count}",
        f"backlog_total: {len(backlog)}",
        "",
        "top_fix_queue:",
    ]
    for item in backlog_items[:8]:
        status_report_lines.append(
            f"- [{item['severity']}/{item['status']}] score={item['priority_score']} source={item['source']} :: {item['reason']}"
        )
    if recent_failures:
        status_report_lines.extend(["", "recent_failures:"])
        status_report_lines.extend(f"- {line}" for line in list(reversed(recent_failures[:6])))

    outputs = {
        "workspace_summary": artifact_dir / "workspace_summary.json",
        "failure_digest": artifact_dir / "failure_digest.json",
        "prioritized_fix_queue": artifact_dir / "prioritized_fix_queue.json",
        "status_report": artifact_dir / "status_report.txt",
    }
    outputs["workspace_summary"].write_text(json.dumps(workspace_summary, indent=2), encoding="utf-8")
    outputs["failure_digest"].write_text(json.dumps(failure_digest, indent=2), encoding="utf-8")
    outputs["prioritized_fix_queue"].write_text(json.dumps(prioritized_fix_queue, indent=2), encoding="utf-8")
    outputs["status_report"].write_text("\n".join(status_report_lines) + "\n", encoding="utf-8")

    return {key: str(value) for key, value in outputs.items()}

def _estimate_ui_action_runtime_sec(actions: list[dict], policy: dict) -> float:
    pause_sec = max(0.0, float(int(policy.get("local_input_safety_pause_ms", 120))) / 1000.0)
    total_sec = 0.0
    for action in list(actions or []):
        if not isinstance(action, dict):
            continue
        action_type = str(action.get("type", "")).strip().lower()
        if action_type in {"sleep", "wait"}:
            total_sec += max(0.0, float(action.get("seconds", 0.5) or 0.5))
            continue
        if action_type in {"type", "type_text"}:
            text = str(action.get("text", ""))
            delay_ms = max(0, int(action.get("delay_ms", 20)))
            total_sec += (len(text) * delay_ms) / 1000.0
            total_sec += 0.25
        elif action_type in {"key", "keypress", "hotkey", "click", "mouse_click", "double_click", "dblclick", "move", "move_mouse", "activate_window"}:
            total_sec += 0.2
        else:
            total_sec += 0.1
        total_sec += pause_sec
    return round(total_sec, 2)

def _write_ui_progress_payload(status_path: Path, payload: dict) -> None:
    try:
        status_path.parent.mkdir(parents=True, exist_ok=True)
        with NamedTemporaryFile("w", dir=status_path.parent, delete=False, suffix=".tmp", encoding="utf-8") as tmp:
            json.dump(payload, tmp)
            temp_name = tmp.name
        os.replace(temp_name, status_path)
    except Exception:
        pass

def _start_persistent_ui_progress_window(actions: list[dict], policy: dict) -> dict | None:
    if not bool(policy.get("local_input_progress_window_enabled", True)):
        return None
    estimated_sec = _estimate_ui_action_runtime_sec(actions, policy)
    threshold_sec = max(60, int(policy.get("local_input_progress_window_threshold_sec", 60) or 60))
    if estimated_sec < threshold_sec or not _is_desktop_session_available():
        return None

    title = str(policy.get("local_input_progress_window_title", "Skynetv2 Active Workflow")).strip() or "Skynetv2 Active Workflow"
    geometry = _resolve_progress_window_geometry(policy)
    try:
        with NamedTemporaryFile("w", dir=BASE_DIR, delete=False, suffix="_ui_progress.json", encoding="utf-8") as handle:
            status_path = Path(handle.name)
    except Exception:
        return None

    initial_payload = {
        "title": title,
        "status": "running",
        "phase": "Starting workflow",
        "detail": "Preparing autonomous UI sequence",
        "processed": 0,
        "total": len(actions),
        "estimated_sec": estimated_sec,
        "started_at": datetime.now().isoformat(),
    }
    _write_ui_progress_payload(status_path, initial_payload)

    script = """
import json
import pathlib
import tkinter as tk
from tkinter import ttk

status_path = pathlib.Path(__STATUS_PATH__)
window_title = __WINDOW_TITLE__
window_geometry = __WINDOW_GEOMETRY__

root = tk.Tk()
root.title(window_title)
root.geometry(window_geometry)
root.resizable(False, False)
root.attributes('-topmost', True)

frame = ttk.Frame(root, padding=12)
frame.pack(fill='both', expand=True)

title_var = tk.StringVar(value=window_title)
phase_var = tk.StringVar(value='Starting workflow')
detail_var = tk.StringVar(value='Preparing autonomous UI sequence')
step_var = tk.StringVar(value='0 / 0')
eta_var = tk.StringVar(value='ETA: calculating')

ttk.Label(frame, textvariable=title_var, font=('TkDefaultFont', 11, 'bold')).pack(anchor='w')
ttk.Label(frame, textvariable=phase_var).pack(anchor='w', pady=(8, 0))
ttk.Label(frame, textvariable=detail_var, wraplength=380, justify='left').pack(anchor='w', pady=(4, 0))
progress = ttk.Progressbar(frame, orient='horizontal', mode='determinate', length=380)
progress.pack(fill='x', pady=(10, 4))
ttk.Label(frame, textvariable=step_var).pack(anchor='w')
ttk.Label(frame, textvariable=eta_var).pack(anchor='w', pady=(2, 0))

close_after_id = None

def schedule_close(delay_ms):
    global close_after_id
    if close_after_id is None:
        close_after_id = root.after(delay_ms, root.destroy)

def refresh():
    try:
        payload = json.loads(status_path.read_text(encoding='utf-8'))
    except Exception:
        payload = {}
    total = max(1, int(payload.get('total', 1) or 1))
    processed = max(0, int(payload.get('processed', 0) or 0))
    progress['maximum'] = total
    progress['value'] = min(processed, total)
    title_var.set(str(payload.get('title', window_title)))
    phase_var.set(str(payload.get('phase', 'Running workflow')))
    detail_var.set(str(payload.get('detail', 'Working...'))[:180])
    step_var.set(f"{processed} / {total}")
    eta_var.set(str(payload.get('eta_text', 'ETA: calculating')))
    status = str(payload.get('status', 'running')).lower()
    if status in {'complete', 'failed', 'blocked'}:
        schedule_close(3500)
    else:
        root.after(400, refresh)

root.after(100, refresh)
root.mainloop()
""".replace("__STATUS_PATH__", json.dumps(str(status_path))).replace("__WINDOW_TITLE__", json.dumps(title)).replace("__WINDOW_GEOMETRY__", json.dumps(geometry))

    try:
        process = subprocess.Popen(
            [sys.executable, "-c", script],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            env=dict(os.environ),
        )
    except Exception:
        try:
            status_path.unlink(missing_ok=True)
        except Exception:
            pass
        return None

    return {
        "status_path": status_path,
        "process": process,
        "estimated_sec": estimated_sec,
        "total": len(actions),
        "title": title,
    }

def _update_persistent_ui_progress_window(handle: dict | None, processed: int, total: int, action: dict, step_result: dict) -> None:
    if not handle:
        return
    status_path = handle.get("status_path")
    if not isinstance(status_path, Path):
        return
    detail = str(action.get("label") or action.get("text") or action.get("key") or action.get("type") or "working")
    detail = re.sub(r"\s+", " ", detail).strip()[:180]
    remaining = max(0.0, float(handle.get("estimated_sec", 0.0)) * max(0, total - processed) / max(1, total))
    phase_name = _infer_ui_action_phase(action)
    payload = {
        "title": str(handle.get("title", "Skynetv2 Active Workflow")),
        "status": "running",
        "phase": phase_name,
        "detail": detail or "Working...",
        "processed": processed,
        "total": total,
        "eta_text": f"ETA: about {int(math.ceil(remaining))} sec",
        "last_result": str(step_result.get("status", "")),
    }
    _write_ui_progress_payload(status_path, payload)

def _finish_persistent_ui_progress_window(handle: dict | None, result: dict) -> None:
    if not handle:
        return
    status_path = handle.get("status_path")
    if isinstance(status_path, Path):
        payload = {
            "title": str(handle.get("title", "Skynetv2 Active Workflow")),
            "status": "complete" if result.get("status") in {"ok", "partial"} else "failed",
            "phase": "Workflow complete",
            "detail": f"Processed {result.get('processed', 0)} actions with status {result.get('status', 'unknown')}",
            "processed": int(result.get("processed", 0) or 0),
            "total": int(handle.get("total", result.get("processed", 0)) or 1),
            "eta_text": "ETA: complete",
        }
        _write_ui_progress_payload(status_path, payload)

def _local_ui_diagnostics_summary() -> dict:
    issues = []
    try:
        compile_check = subprocess.run(
            [sys.executable, "-m", "py_compile", str(Path(__file__).resolve())],
            capture_output=True,
            text=True,
            timeout=20,
            check=False,
        )
        if compile_check.returncode != 0:
            message = (compile_check.stderr or compile_check.stdout or "python compile check failed").strip()
            issues.append(message[:200])
    except Exception as exc:
        issues.append(f"diagnostic check failed: {str(exc)[:160]}")
    return {
        "status": "issues" if issues else "ok",
        "issues": issues,
    }

def _confirm_ui_takeover(policy: dict, actions: list[dict]) -> dict:
    global _last_ui_takeover_at
    if not bool(policy.get("local_input_takeover_popup_enabled", False)):
        _last_ui_takeover_at = time.time()
        return {"status": "ok", "countdown_sec": 0}

    reconfirm_sec = max(0, int(policy.get("local_input_reconfirm_interval_sec", 120) or 120))
    if reconfirm_sec > 0 and (time.time() - _last_ui_takeover_at) < reconfirm_sec:
        return {"status": "ok", "countdown_sec": 0, "reconfirm_skipped": True}

    diagnostics = _local_ui_diagnostics_summary()
    action_types = []
    for action in list(actions or [])[:8]:
        if isinstance(action, dict):
            action_types.append(str(action.get("type", "unknown")))
    action_preview = ", ".join(action_types) if action_types else "no actions"

    message_lines = [
        "Skynetv2 is about to take over keyboard and mouse control.",
        "",
        f"Planned actions: {action_preview}",
        f"Action count: {len(list(actions or []))}",
    ]
    if diagnostics.get("issues"):
        message_lines.append("")
        message_lines.append("Diagnostics found potential issues:")
        for issue in diagnostics.get("issues", [])[:3]:
            message_lines.append(f"- {issue}")
    countdown_sec = max(0, int(policy.get("local_input_takeover_countdown_sec", 3)))
    requires_approval = bool(policy.get("local_input_takeover_requires_approval", False))
    if requires_approval:
        message_lines.append("")
        message_lines.append("Approve takeover?")
        approved = _popup_yes_no(
            "Skynetv2 UI Takeover",
            "\n".join(message_lines),
            default=False,
        )
        if not approved:
            return {
                "status": "blocked",
                "reason": "user denied keyboard/mouse takeover",
                "diagnostics": diagnostics,
            }
    else:
        notice_timeout = max(countdown_sec, int(policy.get("local_input_takeover_notice_timeout_sec", countdown_sec or 3)))
        require_visible = bool(policy.get("local_input_takeover_require_visible_popup", True))
        message_lines.append("")
        message_lines.append("No approval is required. Countdown is starting now.")
        try:
            shown = _popup_timed_notice(
                "Skynetv2 UI Takeover",
                "\n".join(message_lines),
                timeout_sec=notice_timeout,
                is_error=False,
            )
            if not shown:
                log_action("UI takeover popup was not visibly shown on any backend.")
                if require_visible:
                    return {
                        "status": "blocked",
                        "reason": "takeover popup could not be displayed",
                        "diagnostics": diagnostics,
                    }
            else:
                log_action("UI takeover popup displayed successfully.")
        except Exception:
            # Popup rendering is best-effort; never block takeover on UI toolkit issues.
            if bool(policy.get("local_input_takeover_require_visible_popup", True)):
                return {
                    "status": "blocked",
                    "reason": "takeover popup raised an exception",
                    "diagnostics": diagnostics,
                }

    for remaining in range(countdown_sec, 0, -1):
        note = f"Taking over keyboard/mouse in {remaining} second(s)..."
        log_action(note)
        print(note)
        time.sleep(1)

    _last_ui_takeover_at = time.time()

    return {
        "status": "ok",
        "countdown_sec": countdown_sec,
        "diagnostics": diagnostics,
    }

def _is_desktop_session_available() -> bool:
    if os.environ.get("DISPLAY") or os.environ.get("WAYLAND_DISPLAY"):
        return True
    for candidate in [":10.0", ":10", ":0", ":1"]:
        if Path(f"/tmp/.X11-unix/X{candidate.split(':')[-1].split('.')[0]}").exists():
            return True
    return False

def _xdotool_button_code(button_name: str) -> str:
    value = str(button_name or "left").strip().lower()
    mapping = {
        "left": "1",
        "middle": "2",
        "right": "3",
        "wheel_up": "4",
        "wheel_down": "5",
    }
    return mapping.get(value, "1")

def _run_xdotool(args: list[str], timeout_sec: int = 20) -> dict:
    global _last_ui_display
    if shutil.which("xdotool") is None:
        return {"status": "error", "reason": "xdotool not installed"}
    command = ["xdotool", *args]
    displays = []
    display_override = ""
    display_candidates = []
    try:
        policy = load_workspace_policy()
        display_override = str(policy.get("local_input_display", "")).strip()
        raw_candidates = policy.get("local_input_display_candidates", [])
        if isinstance(raw_candidates, list):
            display_candidates = [str(item).strip() for item in raw_candidates if str(item).strip()]
    except Exception:
        display_override = ""
        display_candidates = []

    for candidate in [
        os.environ.get("DISPLAY", "").strip(),
        _last_ui_display,
        display_override,
        ":0",
        ":1",
        ":10.0",
        ":10",
        *display_candidates,
    ]:
        if candidate and candidate not in displays:
            displays.append(candidate)

    attempted = []
    for display in displays:
        env = os.environ.copy()
        env["DISPLAY"] = display
        if "XAUTHORITY" not in env or not str(env.get("XAUTHORITY", "")).strip():
            env["XAUTHORITY"] = str(Path.home() / ".Xauthority")
        try:
            result = subprocess.run(
                command,
                capture_output=True,
                text=True,
                timeout=max(1, int(timeout_sec)),
                check=False,
                env=env,
            )
            if result.returncode == 0:
                _last_ui_display = display
                return {
                    "status": "ok",
                    "command": command,
                    "stdout": (result.stdout or "").strip(),
                    "display": display,
                }
            reason = (result.stderr or result.stdout or "xdotool command failed").strip()
            attempted.append(f"{display}: {reason[:120]}")
        except Exception as exc:
            attempted.append(f"{display}: {str(exc)[:120]}")

    return {
        "status": "error",
        "reason": (" | ".join(attempted) or "xdotool command failed")[:240],
        "command": command,
        "attempted_displays": displays,
    }

def _get_active_window_title(timeout_sec: int = 5) -> str:
    if shutil.which("xdotool") is None:
        return ""
    try:
        proc = subprocess.run(
            ["xdotool", "getactivewindow", "getwindowname"],
            capture_output=True,
            text=True,
            timeout=max(1, int(timeout_sec)),
            check=False,
        )
        if proc.returncode != 0:
            return ""
        return (proc.stdout or "").strip()
    except Exception:
        return ""

def _window_title_matches_target(title: str, target_window_name: str) -> bool:
    title_value = str(title or "").strip().lower()
    target_value = str(target_window_name or "").strip().lower()
    if not title_value or not target_value:
        return False
    if target_value in title_value:
        return True
    safe_aliases = {
        "visual studio code": ["visual studio code", "vscode", "code"],
        "code": ["visual studio code", "vscode", "code"],
        "terminal": ["terminal", "bash", "shell"],
    }
    for needle in safe_aliases.get(target_value, []):
        if needle in title_value:
            return True
    return False

def _window_title_is_terminal_like(title: str) -> bool:
    title_value = str(title or "").strip().lower()
    if not title_value:
        return False
    return any(token in title_value for token in {"terminal", "bash", "shell", "konsole", "xterm", "cmd", "powershell"})

def _run_xdotool_with_retry(args: list[str], timeout_sec: int = 20, retries: int = 2) -> dict:
    """Retry transient xdotool failures so takeover does not break mid-cycle."""
    attempts = max(1, int(retries) + 1)
    last = {"status": "error", "reason": "not attempted", "command": ["xdotool", *args]}
    for i in range(attempts):
        last = _run_xdotool(args, timeout_sec=timeout_sec)
        if last.get("status") == "ok":
            return last
        if i < attempts - 1:
            time.sleep(min(0.5, 0.12 * (i + 1)))
    return last

def _resolve_display_for_window(window_name: str, timeout_sec: int = 5) -> str:
    """Return the first display where target window can be activated."""
    name = str(window_name or "").strip()
    if not name:
        return ""
    trial_displays = [
        os.environ.get("DISPLAY", "").strip(),
        ":0",
        ":1",
        ":10.0",
        ":10",
    ]
    seen = set()
    for display in trial_displays:
        if not display or display in seen:
            continue
        seen.add(display)
        env = os.environ.copy()
        env["DISPLAY"] = display
        if "XAUTHORITY" not in env or not str(env.get("XAUTHORITY", "")).strip():
            env["XAUTHORITY"] = str(Path.home() / ".Xauthority")
        try:
            result = subprocess.run(
                ["xdotool", "search", "--name", name, "windowactivate", "--sync"],
                capture_output=True,
                text=True,
                timeout=max(1, int(timeout_sec)),
                check=False,
                env=env,
            )
            if result.returncode == 0:
                return display
        except Exception:
            continue
    return ""

def _sanitize_ui_actions(actions: list[dict]) -> list[dict]:
    """Drop malformed UI actions and normalize fields to keep execution resilient.

    CRITICAL: Sanitize text for xdotool to prevent garbled character injection.
    xdotool 'type' command can misbehave with UTF-8, escape sequences, or special chars.
    """
    allowed = {
        "activate_window",
        "focus_window",
        "move",
        "move_mouse",
        "move_relative",
        "click",
        "mouse_click",
        "double_click",
        "dblclick",
        "key",
        "keypress",
        "hotkey",
        "type",
        "type_text",
        "sleep",
        "wait",
        "run_shell",
    }
    sanitized: list[dict] = []
    for raw in list(actions or []):
        if not isinstance(raw, dict):
            continue
        action_type = str(raw.get("type", "")).strip().lower()
        if action_type not in allowed:
            continue
        item = dict(raw)
        item["type"] = action_type

        if action_type in {"move", "move_mouse"}:
            try:
                item["x"] = int(item.get("x", 0))
                item["y"] = int(item.get("y", 0))
            except Exception:
                item["x"] = 0
                item["y"] = 0

        if action_type in {"move_relative"}:
            try:
                item["dx"] = int(item.get("dx", 0))
                item["dy"] = int(item.get("dy", 0))
            except Exception:
                item["dx"] = 0
                item["dy"] = 0

        if action_type in {"type", "type_text"}:
            raw_text = str(item.get("text", ""))
            # SAFETY: Remove control characters and problematic UTF-8 sequences
            # Keep only printable ASCII and common safe characters
            cleaned_text = ""
            for char in raw_text:
                code = ord(char)
                # Allow: printable ASCII (32-126), common whitespace, forward/back slashes
                if 32 <= code <= 126 or code in {9, 10, 13}:  # tab, LF, CR
                    cleaned_text += char
                elif char in "_/-":  # explicitly allow path separators and underscores
                    cleaned_text += char
            item["text"] = cleaned_text
            try:
                item["delay_ms"] = max(0, int(item.get("delay_ms", 20)))
            except Exception:
                item["delay_ms"] = 20

        if action_type in {"sleep", "wait"}:
            try:
                item["seconds"] = max(0.0, float(item.get("seconds", 0.5) or 0.5))
            except Exception:
                item["seconds"] = 0.5

        sanitized.append(item)

    # Always keep at least one harmless action so cycle state still updates.
    if not sanitized:
        sanitized = [{"type": "sleep", "seconds": 0.1}]
    return sanitized

def _validate_file_exists(filepath: str, base_dir=None) -> bool:
    """Check if a file exists before attempting to open it. Handles relative paths."""
    if base_dir is None:
        base_dir = WORKSPACE_ROOT
    full_path = (base_dir / filepath) if not Path(filepath).is_absolute() else Path(filepath)
    return full_path.exists() and full_path.is_file()

def _get_safe_files_for_operations(max_count: int = 2) -> list[str]:
    """Return a list of files that actually exist for safe file operations in Phase 27."""
    candidates = [
        "create/skynetv2_agent.py",
        "create/workspace_policy_v2.json",
        "create/network_scan_policy.json",
        ".github/copilot-instructions.md",
        "README.md",
    ]
    safe_files = [f for f in candidates if _validate_file_exists(f)]
    return safe_files[:max_count] if safe_files else ["create/skynetv2_agent.py"]

def _score_high_impact_edit_candidate(file_path: Path) -> float:
    """Score how likely a file is to benefit from a visible code improvement pass."""
    if not file_path.exists() or not file_path.is_file():
        return 0.0

    try:
        text = file_path.read_text(encoding="utf-8", errors="ignore")
    except Exception:
        return 0.0

    lines = text.splitlines()
    total_lines = max(1, len(lines))
    trailing_ws = sum(1 for line in lines if line.rstrip() != line)
    blank_runs = 0
    current_blank = 0
    for line in lines:
        if not line.strip():
            current_blank += 1
            continue
        if current_blank > 1:
            blank_runs += current_blank - 1
        current_blank = 0
    if current_blank > 1:
        blank_runs += current_blank - 1

    import_hits = sum(1 for line in lines if line.lstrip().startswith(("import ", "from ")))
    func_hits = sum(1 for line in lines if line.lstrip().startswith(("def ", "imp")))
    todo_hits = sum(1 for line in lines if any(token in line for token in ("TODO", "FIXME", "XXX", "HACK")))
    comment_block_hits = sum(1 for line in lines if line.lstrip().startswith("#"))
    docstring_hits = text.count('"""') + text.count("'''")

    # Bigger files with visible cleanup opportunities are more attractive.
    size_factor = min(4.0, len(text) / 12000.0)
    shape_factor = (trailing_ws * 2.5) + (blank_runs * 1.2) + (todo_hits * 2.2) + (comment_block_hits * 0.05)
    structure_factor = (import_hits * 0.35) + (func_hits * 0.25) + (max(0, func_hits - docstring_hits) * 0.6)
    path_text = str(file_path.as_posix())
    directory_bias = 0.0
    if "/create/" in path_text:
        directory_bias += 3.0
    if "/docker/create/" in path_text:
        directory_bias += 3.5
    if "/.github/" in path_text:
        directory_bias += 2.0
    if "/scripts/" in path_text:
        directory_bias += 1.5
    if "/frontend/" in path_text or "/backend/" in path_text:
        directory_bias += 1.0
    if "/deployment_bundles/" in path_text:
        directory_bias -= 4.0
    if "/rewrite_backups/" in path_text or "/autonomous_generated/" in path_text:
        directory_bias -= 5.0
    if "backup" in file_path.name.lower():
        directory_bias -= 3.0

    score = size_factor + shape_factor + structure_factor + directory_bias
    return round(score, 3)

def _is_high_value_workspace_candidate(path_obj: Path) -> bool:
    """Restrict selection to workspace files that are likely to be meaningful edit targets."""
    path_text = str(path_obj.as_posix())
    excluded_fragments = {
        "/node_modules/",
        "/rewrite_backups/",
        "/autonomous_generated/",
        "/__pycache__/",
        "/.git/",
        "/deployment_bundles/",
        "/client_deliveries/",
        "/review_videos/",
        "/review_segments/",
        "/tmp/",
        "/dist/",
        "/build/",
        "/.venv/",
    }
    if any(fragment in path_text for fragment in excluded_fragments):
        return False
    if "backup" in path_obj.name.lower() or path_obj.name.endswith(".bak"):
        return False
    if path_obj.suffix.lower() not in {".py", ".js", ".ts", ".json", ".md", ".yaml", ".yml", ".sh"}:
        return False
    return True

def _select_workspace_review_files(policy: dict, max_count: int | None = None) -> list[str]:
    """Pick existing workspace files for UI review/open-close actions.
    This prevents stale/non-existent file paths from halting takeover cycles.
    """
    limit = int(max_count or policy.get("autonomous_ui_review_max_files", 12) or 12)
    limit = max(1, min(50, limit))
    allowed_suffixes = {
        ".py",
        ".js",
        ".ts",
        ".json",
        ".md",
        ".yaml",
        ".yml",
        ".sh",
    }
    selected: list[str] = []
    seen: set[str] = set()

    # Prioritize rewrite-eligible workspace roots.
    priority_names = {
        "skynetv2_agent.py",
        "autonomous_code_improver.py",
        "nlp_code_trainer.py",
        "skynetv1_agent.py",
        "test_autonomous_code_improver.py",
        "test_rewrite_transforms.py",
        "test_improver_unit.py",
    }
    for root in _workspace_root_paths(policy):
        if not root.exists() or not root.is_dir():
            continue
        candidate_paths = list(root.glob("**/*"))
        scored_paths: list[tuple[float, Path]] = []
        for path_obj in candidate_paths:
            if not path_obj.is_file():
                continue
            if not _is_high_value_workspace_candidate(path_obj):
                continue
            if not path_allowed_for_rewrite(path_obj, policy):
                continue
            if not _path_selected_for_rewrite(path_obj, policy):
                continue
            score = _score_high_impact_edit_candidate(path_obj)
            if path_obj.name in priority_names:
                score += 10.0
            elif path_obj.suffix.lower() == ".py":
                score += 2.0
            elif path_obj.suffix.lower() in {".js", ".ts", ".json", ".md", ".yaml", ".yml", ".sh"}:
                score += 1.0
            if score < 1.25:
                continue
            scored_paths.append((score, path_obj))
        scored_paths.sort(key=lambda item: (-item[0], len(str(item[1]))))
        for _score, file_path in scored_paths:
            if len(selected) >= limit:
                break
            rel = str(file_path.resolve().relative_to(WORKSPACE_ROOT.resolve()))
            if rel in seen:
                continue
            seen.add(rel)
            selected.append(rel)
        if len(selected) >= limit:
            break

    # Always provide a safe fallback list.
    if not selected:
        selected = _get_safe_files_for_operations(max_count=min(limit, 6))
    return selected[:limit]

def _launch_or_focus_vscode_workspace(policy: dict) -> dict:
    workspace = str(policy.get("vscode_workspace_path", WORKSPACE_ROOT)).strip() or str(WORKSPACE_ROOT)
    window_name = str(policy.get("local_input_target_window_name", "Visual Studio Code") or "Visual Studio Code").strip()
    display = _resolve_display_for_window(window_name)
    if display:
        return {"status": "already_visible", "display": display, "workspace": workspace}

    if shutil.which("code") is None:
        return {"status": "missing_code_cli", "workspace": workspace}

    launch = _run_bash_command(f"code --reuse-window {shlex.quote(workspace)}", cwd=WORKSPACE_ROOT, timeout_sec=15)
    if launch.get("status") == "ok":
        time.sleep(1.5)
        display = _resolve_display_for_window(window_name)
        if display:
            launch["display"] = display
            launch["workspace"] = workspace
            return launch
    launch["workspace"] = workspace
    return launch

def _build_vscode_file_review_actions(
    file_paths: list[str],
    search_term: str = "def ",
    repeat_passes: int = 2,
) -> list[dict]:
    """Build open/view/find/close actions for each file path in VSCode.

    CRITICAL FIX: Use Ctrl+P (Quick Open) instead of Ctrl+O to avoid file dialog corruption.
    Ctrl+O opens OS file dialog where xdotool typing gets garbled with special characters.
    Ctrl+P uses VSCode's built-in quick open which handles paths more reliably.
    """
    actions: list[dict] = []
    search_terms = [search_term, "class ", "import "]
    repeat_passes = max(1, int(repeat_passes or 1))
    for fp in file_paths:
        if not _validate_file_exists(fp):
            continue

        # Normalize path: convert to absolute, then to relative from workspace root
        abs_path = Path(fp).resolve()
        try:
            rel_path = abs_path.relative_to(WORKSPACE_ROOT.resolve())
        except ValueError:
            # Path is outside workspace; skip it
            continue

        # Use forward slashes for consistency
        normalized_path = str(rel_path).replace("\\", "/")

        # Sanitize for xdotool: remove or escape problematic characters
        # Only allow alphanumeric, dots, slashes, hyphens, underscores
        if not all(c.isalnum() or c in "./-_" for c in normalized_path):
            log_action(f"[VSCode Review] Skipping path with problematic chars: {normalized_path}")
            continue

        # Build actions for this file
        file_actions = [
            # Use Ctrl+P (Quick Open) instead of Ctrl+O (OS file dialog)
            {"type": "key", "key": "ctrl+p"},
            {"type": "sleep", "seconds": 0.35},
        ]
        for chunk in _chunk_text_for_typing(normalized_path, chunk_size=28):
            file_actions.extend(
                [
                    {"type": "type", "text": chunk, "delay_ms": 90},
                    {"type": "sleep", "seconds": 0.10},
                ]
            )
        file_actions.extend(
            [
                {"type": "key", "key": "Return"},
                {"type": "sleep", "seconds": 0.55},
                {"type": "key", "key": "ctrl+Home"},
                {"type": "sleep", "seconds": 0.12},
            ]
        )
        for _ in range(repeat_passes):
            for term in search_terms:
                file_actions.extend(
                    [
                        {"type": "key", "key": "ctrl+f"},
                        {"type": "sleep", "seconds": 0.15},
                        {"type": "type", "text": term, "delay_ms": 75},
                        {"type": "sleep", "seconds": 0.12},
                        {"type": "key", "key": "Return"},
                        {"type": "sleep", "seconds": 0.12},
                        {"type": "key", "key": "Escape"},
                        {"type": "sleep", "seconds": 0.12},
                    ]
                )
            file_actions.extend(
                [
                    {"type": "key", "key": "Page_Down"},
                    {"type": "sleep", "seconds": 0.14},
                    {"type": "key", "key": "Page_Up"},
                    {"type": "sleep", "seconds": 0.14},
                    {"type": "move", "x": 220, "y": 180},
                    {"type": "sleep", "seconds": 0.08},
                ]
            )
        file_actions.extend(
            [
                {"type": "key", "key": "ctrl+w"},
                {"type": "sleep", "seconds": 0.22},
            ]
        )
        actions.extend(file_actions)

    return actions

def _run_autonomous_validation_suite(policy: dict) -> dict:
    """Run smoke, primary, and negative boundary checks after takeover actions."""
    if not bool(policy.get("autonomous_validation_enabled", True)):
        return {"status": "disabled"}

    timeout_sec = max(30, int(policy.get("autonomous_validation_timeout_sec", 180) or 180))
    pytest_target = str(policy.get("autonomous_validation_pytest_target", "create/") or "create/").strip()
    coverage_enabled = bool(policy.get("autonomous_validation_enable_coverage", True))
    coverage_fail_under = max(0.0, min(100.0, float(policy.get("autonomous_validation_coverage_fail_under", 70.0) or 70.0)))
    coverage_sources = policy.get("autonomous_validation_coverage_source", ["create"])
    if not isinstance(coverage_sources, list) or not coverage_sources:
        coverage_sources = ["create"]

    report: dict[str, Any] = {
        "status": "ok",
        "smoke": {},
        "pytest": {},
        "coverage": {},
        "negative": {},
        "negative_matrix": {},
    }

    # Smoke: verify key module imports and can initialize policy/runtime state.
    smoke_cmd = [
        sys.executable,
        "-c",
        (
            "import importlib; "
            "m=importlib.import_module('create.skynetv2_agent'); "
            "p=m.load_workspace_policy(); "
            "print('smoke_ok', bool(p), hasattr(m, 'run_controlled_algorithmic_synthesis'))"
        ),
    ]
    try:
        smoke = subprocess.run(smoke_cmd, capture_output=True, text=True, timeout=timeout_sec, check=False)
        report["smoke"] = {
            "returncode": int(smoke.returncode),
            "stdout": (smoke.stdout or "")[:500],
            "stderr": (smoke.stderr or "")[:500],
            "passed": smoke.returncode == 0,
        }
    except subprocess.TimeoutExpired as exc:
        report["smoke"] = {
            "returncode": 124,
            "stdout": str((exc.stdout or "")[:500]),
            "stderr": str((exc.stderr or "")[:500]),
            "passed": False,
            "timed_out": True,
        }
    except Exception as exc:
        report["smoke"] = {
            "returncode": 1,
            "stdout": "",
            "stderr": str(exc)[:500],
            "passed": False,
        }

    # Primary test/smoke run.
    pytest_cmd = [sys.executable, "-m", "pytest", pytest_target, "-q", "--maxfail=5"]
    try:
        pytest_run = subprocess.run(pytest_cmd, capture_output=True, text=True, timeout=timeout_sec, check=False)
        report["pytest"] = {
            "returncode": int(pytest_run.returncode),
            "stdout": (pytest_run.stdout or "")[:2000],
            "stderr": (pytest_run.stderr or "")[:1200],
            "passed": pytest_run.returncode == 0,
        }
    except subprocess.TimeoutExpired as exc:
        report["pytest"] = {
            "returncode": 124,
            "stdout": str((exc.stdout or "")[:2000]),
            "stderr": str((exc.stderr or "")[:1200]),
            "passed": False,
            "timed_out": True,
        }
    except Exception as exc:
        report["pytest"] = {
            "returncode": 1,
            "stdout": "",
            "stderr": str(exc)[:1200],
            "passed": False,
        }

    if coverage_enabled:
        source_arg = ",".join(str(item).strip() for item in coverage_sources if str(item).strip())
        coverage_run_cmd = [
            sys.executable,
            "-m",
            "coverage",
            "run",
            "--branch",
            "--source",
            source_arg or "create",
            "-m",
            "pytest",
            pytest_target,
            "-q",
            "--maxfail=5",
        ]
        coverage_report_cmd = [
            sys.executable,
            "-m",
            "coverage",
            "report",
            "-m",
            "--fail-under",
            f"{coverage_fail_under:.1f}",
        ]
        try:
            cov_run = subprocess.run(coverage_run_cmd, capture_output=True, text=True, timeout=timeout_sec, check=False)
            cov_rep = subprocess.run(coverage_report_cmd, capture_output=True, text=True, timeout=max(20, timeout_sec // 2), check=False)
            report["coverage"] = {
                "returncode": int(cov_rep.returncode),
                "run_returncode": int(cov_run.returncode),
                "stdout": (cov_rep.stdout or "")[:2400],
                "stderr": ((cov_run.stderr or "") + "\n" + (cov_rep.stderr or ""))[:1800],
                "threshold": coverage_fail_under,
                "source": source_arg or "create",
                "passed": cov_run.returncode == 0 and cov_rep.returncode == 0,
            }
        except subprocess.TimeoutExpired as exc:
            report["coverage"] = {
                "returncode": 124,
                "run_returncode": 124,
                "stdout": str((exc.stdout or "")[:1200]),
                "stderr": str((exc.stderr or "")[:1200]),
                "threshold": coverage_fail_under,
                "source": source_arg or "create",
                "passed": False,
                "timed_out": True,
            }
        except Exception as exc:
            report["coverage"] = {
                "returncode": 1,
                "run_returncode": 1,
                "stdout": "",
                "stderr": str(exc)[:1200],
                "threshold": coverage_fail_under,
                "source": source_arg or "create",
                "passed": False,
            }

    # Negative boundary test: path outside workspace must remain blocked.
    if bool(policy.get("autonomous_negative_test_enabled", True)):
        negative_cmd = [
            sys.executable,
            "-c",
            (
                "from pathlib import Path; "
                "import importlib; "
                "m=importlib.import_module('create.skynetv2_agent'); "
                "pol=m.load_workspace_policy(); "
                "ok=(m.path_allowed_for_rewrite(Path('/tmp/skynetv2_outside_boundary_probe.py'), pol) is False); "
                "print('negative_boundary_passed', ok); "
                "raise SystemExit(0 if ok else 2)"
            ),
        ]
        try:
            neg = subprocess.run(negative_cmd, capture_output=True, text=True, timeout=max(20, timeout_sec // 2), check=False)
            report["negative"] = {
                "returncode": int(neg.returncode),
                "stdout": (neg.stdout or "")[:500],
                "stderr": (neg.stderr or "")[:500],
                "passed": neg.returncode == 0,
            }
        except subprocess.TimeoutExpired as exc:
            report["negative"] = {
                "returncode": 124,
                "stdout": str((exc.stdout or "")[:500]),
                "stderr": str((exc.stderr or "")[:500]),
                "passed": False,
                "timed_out": True,
            }
        except Exception as exc:
            report["negative"] = {
                "returncode": 1,
                "stdout": "",
                "stderr": str(exc)[:500],
                "passed": False,
            }

    if bool(policy.get("autonomous_negative_matrix_enabled", True)):
        negative_matrix_cmd = [
            sys.executable,
            "-c",
            (
                "import json,importlib; "
                "from pathlib import Path; "
                "m=importlib.import_module('create.skynetv2_agent'); "
                "pol=m.load_workspace_policy(); "
                "cases={}; "
                "cases['outside_workspace_blocked']=not m.path_allowed_for_rewrite(Path('/tmp/skynetv2_outside_boundary_probe.py'), pol); "
                "cases['deny_path_blocked']=not m.path_allowed_for_rewrite(Path('/etc/passwd'), pol); "
                "cases['venv_path_blocked']=not m.path_allowed_for_rewrite(Path('/home/pi/Desktop/test/.venv/bin/python3'), pol); "
                "print(json.dumps(cases, sort_keys=True)); "
                "raise SystemExit(0 if all(cases.values()) else 3)"
            ),
        ]
        try:
            neg_matrix = subprocess.run(
                negative_matrix_cmd,
                capture_output=True,
                text=True,
                timeout=max(20, timeout_sec // 2),
                check=False,
            )
            report["negative_matrix"] = {
                "returncode": int(neg_matrix.returncode),
                "stdout": (neg_matrix.stdout or "")[:1200],
                "stderr": (neg_matrix.stderr or "")[:500],
                "passed": neg_matrix.returncode == 0,
            }
        except subprocess.TimeoutExpired as exc:
            report["negative_matrix"] = {
                "returncode": 124,
                "stdout": str((exc.stdout or "")[:1200]),
                "stderr": str((exc.stderr or "")[:500]),
                "passed": False,
                "timed_out": True,
            }
        except Exception as exc:
            report["negative_matrix"] = {
                "returncode": 1,
                "stdout": "",
                "stderr": str(exc)[:500],
                "passed": False,
            }

    all_passed = (
        bool(report["smoke"].get("passed"))
        and bool(report["negative"].get("passed", True))
        and bool(report["negative_matrix"].get("passed", True))
        and bool(report["coverage"].get("passed", True))
    )
    if not all_passed:
        report["status"] = "failed"
        queue_code_rewrite(
            reason="autonomous validation suite reported smoke/negative test failure",
            source="autonomous_validation",
            severity="high",
        )
    elif not bool(report["pytest"].get("passed")):
        report["status"] = "partial"
        queue_code_rewrite(
            reason="autonomous validation pytest run reported failures",
            source="autonomous_validation",
            severity="medium",
        )

    return report

def _validate_and_sanitize_terminal_actions(actions: list[dict], policy: dict) -> list[dict]:
    """
    Validate that terminal is active before allowing shell command typing.
    Remove dangerous 'type' actions that contain shell commands if terminal not confirmed.
    This prevents corrupting VS Code editor with shell commands when terminal fails to open.
    """
    if not actions:
        return actions

    # Check if we have any "type" actions that look like shell commands
    has_shell_commands = any(
        action.get("type") in {"type", "type_text"} and
        any(cmd in str(action.get("text", "")).lower() for cmd in ["echo", "pwd", "ls ", "grep", "cat ", "find ", "du ", "git ", "python"])
        for action in actions
    )

    if not has_shell_commands:
        # No shell commands, all safe
        return actions

    # We have shell commands. Verify terminal activation exists in the action list.
    terminal_window_activation = [
        a for a in actions
        if a.get("type") in {"activate_window", "focus_window"}
        and any(token in str(a.get("name", "")).lower() for token in {"terminal", "bash", "visual studio code", "vscode"})
    ]
    terminal_toggle_key = [
        a for a in actions
        if a.get("type") in {"key", "keypress", "hotkey"}
        and "ctrl+grave" in str(a.get("key", "")).lower()
    ]

    if not terminal_window_activation and not terminal_toggle_key:
        # Shell commands present but no explicit terminal activation - DANGEROUS
        # Filter out all shell command typing to prevent corruption
        filtered = []
        for action in actions:
            if action.get("type") in {"type", "type_text"}:
                text = str(action.get("text", "")).lower()
                # Remove if it contains shell keywords
                if any(cmd in text for cmd in ["echo ", "pwd", "ls ", "grep", "cat ", "find ", "du ", "git ", "python", "pip "]):
                    # Log this action as blocked
                    filtered.append({
                        "type": "sleep",
                        "seconds": 0.1,
                        "_blocked_shell_command": action.get("text", "")[:100],
                        "_reason": "terminal not confirmed active - blocked to prevent editor corruption"
                    })
                    continue
            filtered.append(action)
        return filtered

    # Terminal activation present - actions are safer
    return actions

def _execute_local_ui_actions(actions: list[dict], policy: dict) -> dict:
    if not bool(policy.get("local_input_control_enabled", False)):
        return {"status": "blocked", "reason": "local input control disabled by policy"}
    if not _is_desktop_session_available() and bool(policy.get("local_input_fail_on_missing_display", True)):
        return {"status": "blocked", "reason": "no desktop display session available"}

    all_actions = _sanitize_ui_actions(list(actions or []))

    # SAFETY CHECK: Validate terminal is active before allowing shell command typing
    all_actions = _validate_and_sanitize_terminal_actions(all_actions, policy)

    takeover = _confirm_ui_takeover(policy, all_actions)
    if takeover.get("status") != "ok":
        return {
            "status": "blocked",
            "reason": takeover.get("reason", "takeover was not approved"),
            "takeover": takeover,
        }

    max_actions = max(1, int(policy.get("local_input_max_actions_per_command", 50000)))
    override_max_actions = max(0, int(policy.get("_local_input_max_actions_override", 0) or 0))
    if override_max_actions > 0:
        max_actions = max(max_actions, override_max_actions)
    pause_ms = max(0, int(policy.get("local_input_safety_pause_ms", 120)))
    pause_override = int(policy.get("_local_input_pause_ms_override", -1) or -1)
    if pause_override >= 0:
        pause_ms = pause_override
    processed = 0
    succeeded = 0
    failed = 0
    steps = []
    selected_actions = all_actions[:max_actions]
    progress_handle = _start_persistent_ui_progress_window(selected_actions, policy)

    max_consecutive_failures = max(3, int(policy.get("autonomous_ui_max_consecutive_failures", 25) or 25))
    consecutive_failures = 0
    enforce_focus_each_action = bool(policy.get("local_input_force_window_focus_each_action", True))
    target_window_name = str(policy.get("local_input_target_window_name", "Visual Studio Code") or "Visual Studio Code").strip()

    # Resolve the display where the target window actually exists; this avoids invisible off-screen control.
    resolved_display = _resolve_display_for_window(target_window_name)
    if resolved_display:
        os.environ["DISPLAY"] = resolved_display
    elif bool(policy.get("local_input_require_target_window", False)):
        return {
            "status": "blocked",
            "reason": f"target window not found: {target_window_name}",
            "takeover": takeover,
        }

    if bool(policy.get("local_input_require_target_window", True)):
        active_title = _get_active_window_title()
        if not (_window_title_matches_target(active_title, target_window_name) or _window_title_is_terminal_like(active_title)):
            return {
                "status": "blocked",
                "reason": f"active window mismatch: {active_title or 'unknown'}",
                "target_window_name": target_window_name,
                "takeover": takeover,
            }

    for action in selected_actions:
        if not isinstance(action, dict):
            continue
        action_type = str(action.get("type", "")).strip().lower()
        step_result = {"type": action_type, "status": "error", "reason": "unsupported action"}
        try:
            if enforce_focus_each_action and target_window_name and action_type in {
                "key",
                "keypress",
                "hotkey",
                "type",
                "type_text",
                "click",
                "mouse_click",
                "double_click",
                "dblclick",
            }:
                focus_result = _run_xdotool_with_retry(["search", "--name", target_window_name, "windowactivate", "--sync"], retries=1)
                if focus_result.get("status") != "ok":
                    step_result = {
                        "type": action_type,
                        "status": "error",
                        "reason": "target window focus failed",
                        "focus": focus_result,
                    }
                    processed += 1
                    failed += 1
                    consecutive_failures += 1
                    steps.append(step_result)
                    _update_persistent_ui_progress_window(progress_handle, processed, len(selected_actions), action, step_result)
                    continue

            if action_type in {"key", "keypress", "hotkey", "type", "type_text"} and bool(policy.get("local_input_require_target_window", True)):
                active_title = _get_active_window_title()
                active_ok = _window_title_matches_target(active_title, target_window_name) or _window_title_is_terminal_like(active_title)
                if not active_ok:
                    return {
                        "status": "blocked",
                        "reason": f"refusing to type into non-target window: {active_title or 'unknown'}",
                        "target_window_name": target_window_name,
                        "takeover": takeover,
                    }

            if action_type in {"activate_window", "focus_window"}:
                window_name = str(action.get("name", "")).strip()
                if window_name:
                    step_result = _run_xdotool_with_retry(["search", "--name", window_name, "windowactivate", "--sync"], retries=2)
                else:
                    step_result = {"type": action_type, "status": "error", "reason": "missing window name"}
            elif action_type in {"move", "move_mouse"}:
                step_result = _run_xdotool_with_retry(["mousemove", str(int(action.get("x", 0))), str(int(action.get("y", 0)))], retries=1)
            elif action_type in {"move_relative"}:
                step_result = _run_xdotool_with_retry(["mousemove_relative", "--", str(int(action.get("dx", 0))), str(int(action.get("dy", 0)))], retries=1)
            elif action_type in {"click", "mouse_click"}:
                step_result = _run_xdotool_with_retry(["click", _xdotool_button_code(str(action.get("button", "left")))], retries=1)
            elif action_type in {"double_click", "dblclick"}:
                step_result = _run_xdotool_with_retry(["click", "--repeat", "2", "--delay", "120", _xdotool_button_code(str(action.get("button", "left")))], retries=1)
            elif action_type in {"key", "keypress", "hotkey"}:
                key_spec = str(action.get("key", "")).strip()
                if key_spec:
                    step_result = _run_xdotool_with_retry(["key", "--clearmodifiers", key_spec], retries=2)
                else:
                    step_result = {"type": action_type, "status": "error", "reason": "missing key spec"}
            elif action_type in {"type", "type_text"}:
                text = str(action.get("text", ""))
                delay_ms = max(0, int(action.get("delay_ms", 20)))
                step_result = _run_xdotool_with_retry(["type", "--clearmodifiers", "--delay", str(delay_ms), text], retries=2) if text else {"type": action_type, "status": "error", "reason": "missing text"}
            elif action_type in {"sleep", "wait"}:
                seconds = max(0.0, float(action.get("seconds", 0.5) or 0.5))
                time.sleep(seconds)
                step_result = {"type": action_type, "status": "ok", "seconds": seconds}
            elif action_type == "run_shell":
                shell_cmd = str(action.get("command", "")).strip()
                if shell_cmd:
                    try:
                        completed = subprocess.run(
                            ["bash", "-lc", shell_cmd],
                            cwd=str(WORKSPACE_ROOT),
                            capture_output=True,
                            text=True,
                            timeout=max(5, int(action.get("timeout_sec", 60) or 60)),
                            check=False,
                        )
                        step_result = {
                            "type": action_type,
                            "status": "ok" if completed.returncode == 0 else "error",
                            "returncode": int(completed.returncode),
                            "stdout": (completed.stdout or "")[:300],
                            "stderr": (completed.stderr or "")[:300],
                            "command": shell_cmd[:180],
                        }
                    except Exception as exc:
                        step_result = {
                            "type": action_type,
                            "status": "error",
                            "reason": f"run_shell exception: {str(exc)[:140]}",
                            "command": shell_cmd[:180],
                        }
                else:
                    step_result = {"type": action_type, "status": "error", "reason": "missing command"}
        except Exception as exc:
            step_result = {"type": action_type, "status": "error", "reason": f"action exception: {str(exc)[:140]}"}

        processed += 1
        if step_result.get("status") == "ok":
            succeeded += 1
            consecutive_failures = 0
        else:
            failed += 1
            consecutive_failures += 1
        steps.append(step_result)
        _update_persistent_ui_progress_window(progress_handle, processed, len(selected_actions), action, step_result)

        # Recovery guard: if we hit many failures in a row, send ESC and continue.
        if consecutive_failures >= max_consecutive_failures:
            _run_xdotool_with_retry(["key", "Escape"], retries=1)
            consecutive_failures = 0

        if pause_ms > 0 and action_type not in {"sleep", "wait"}:
            time.sleep(float(pause_ms) / 1000.0)

    status = "ok" if failed == 0 else ("partial" if succeeded > 0 else "failed")
    result = {
        "status": status,
        "processed": processed,
        "succeeded": succeeded,
        "failed": failed,
        "steps": steps,
        "takeover": takeover,
    }
    _finish_persistent_ui_progress_window(progress_handle, result)
    return result

def _expand_workspace_operator_actions(base_actions: list[dict], policy: dict) -> list[dict]:
    desired = int(policy.get("autonomous_ui_target_actions_per_cycle", 5000) or 5000)
    desired = max(5000, min(50000, desired))
    cap = max(1, int(policy.get("local_input_max_actions_per_command", 50000) or 50000))
    target = min(desired, cap)
    if len(base_actions) >= target:
        return base_actions[:target]

    # Use visible relative sweeps so takeover is clearly noticeable on screen.
    filler_template = [
        {"type": "move_relative", "dx": 160, "dy": 90},
        {"type": "move_relative", "dx": -160, "dy": -90},
        {"type": "move_relative", "dx": 120, "dy": -60},
        {"type": "move_relative", "dx": -120, "dy": 60},
    ]
    expanded = list(base_actions)
    idx = 0
    while len(expanded) < target:
        expanded.append(dict(filler_template[idx % len(filler_template)]))
        idx += 1
    return expanded[:target]

def _parse_ui_action_from_args(args: list[str]) -> list[dict]:
    if not args:
        return []
    action = str(args[0]).strip().lower()
    rest = args[1:]
    if action in {"move", "move_mouse"} and len(rest) >= 2:
        return [{"type": "move", "x": int(rest[0]), "y": int(rest[1])}]
    if action in {"click", "mouse_click"}:
        return [{"type": "click", "button": rest[0] if rest else "left"}]
    if action in {"double_click", "dblclick"}:
        return [{"type": "double_click", "button": rest[0] if rest else "left"}]
    if action in {"key", "keypress", "hotkey"}:
        return [{"type": "key", "key": " ".join(rest).strip()}]
    if action in {"type", "type_text"}:
        return [{"type": "type", "text": " ".join(rest)}]
    if action in {"sleep", "wait"}:
        return [{"type": "sleep", "seconds": float(rest[0]) if rest else 0.5}]
    return []

def _guess_os_type_for_device(ip_address: str, mac_address: str) -> str:
    ip = str(ip_address or "").strip()
    mac = str(mac_address or "").strip().lower()
    if ip.endswith(".1"):
        return "router"
    if mac.startswith(("b8:27:eb", "dc:a6:32", "e4:5f:01")):
        return "raspbian"
    return "linux"

def approve_pending_enrollment_devices(auto_prepare_bundles: bool = False) -> dict:
    queue = load_device_enrollment_queue()
    registry = load_device_registry()
    enrolled = registry.setdefault("enrolled_devices", [])
    enrolled_ids = {item.get("fingerprint") for item in enrolled if isinstance(item, dict)}

    approved_entries = []
    changed = False
    now_iso = datetime.now().isoformat()

    for entry in queue:
        if not isinstance(entry, dict):
            continue
        if str(entry.get("status", "")).strip().lower() != "pending":
            continue

        fingerprint = str(entry.get("fingerprint", "")).strip()
        ip = str(entry.get("ip", "")).strip()
        mac = str(entry.get("mac", "")).strip()
        source = str(entry.get("source", "unknown")).strip() or "unknown"

        entry["status"] = "approved"
        entry["reviewed_at"] = now_iso
        entry["reviewed_by"] = "auto_cli"
        changed = True

        if fingerprint and fingerprint not in enrolled_ids:
            enrolled.append(
                {
                    "fingerprint": fingerprint,
                    "ip": ip,
                    "mac": mac,
                    "source": source,
                    "enrolled_at": now_iso,
                    "last_heartbeat_at": "",
                    "status": "active",
                }
            )
            enrolled_ids.add(fingerprint)

        device_name = f"auto-{ip.replace('.', '-') or 'unknown'}"
        os_type = _guess_os_type_for_device(ip, mac)
        add_result = add_device_to_deployment_approvals(device_name, ip, os_type, mac)
        approve_result = approve_device_for_deployment(device_name)

        registry.setdefault("events", []).append(
            {
                "event": "device_enrolled",
                "fingerprint": fingerprint,
                "at": now_iso,
                "reviewed_by": "auto_cli",
            }
        )

        approved_entries.append(
            {
                "fingerprint": fingerprint,
                "ip": ip,
                "mac": mac,
                "device_name": device_name,
                "os_type": os_type,
                "deployment_add": add_result,
                "deployment_approve": approve_result,
            }
        )

    if changed:
        registry["events"] = registry.get("events", [])[-500:]
        save_device_enrollment_queue(queue)
        save_device_registry(registry)

    result = {
        "status": "ok",
        "pending_found": len(approved_entries),
        "approved_devices": approved_entries,
        "bundles": {"status": "not_requested"},
    }

    if auto_prepare_bundles:
        policy = load_workspace_policy()
        result["bundles"] = prepare_install_bundle_for_approved_devices(policy)

    return result

def approve_pending_enrollment_devices_with_popup(auto_prepare_bundles: bool = True) -> dict:
    queue = load_device_enrollment_queue()
    registry = load_device_registry()
    enrolled = registry.setdefault("enrolled_devices", [])
    enrolled_ids = {item.get("fingerprint") for item in enrolled if isinstance(item, dict)}

    pending_entries = [
        entry for entry in queue
        if isinstance(entry, dict) and str(entry.get("status", "")).strip().lower() == "pending"
    ]

    if not pending_entries:
        result = {
            "status": "ok",
            "pending_found": 0,
            "approved_devices": [],
            "skipped_devices": [],
            "bundles": {"status": "not_requested"},
        }
        _popup_info("Skynetv2 Device Approval", "No pending devices found.")
        return result

    approved_entries = []
    skipped_entries = []
    changed = False

    for entry in pending_entries:
        fingerprint = str(entry.get("fingerprint", "")).strip()
        ip = str(entry.get("ip", "")).strip()
        mac = str(entry.get("mac", "")).strip()
        source = str(entry.get("source", "unknown")).strip() or "unknown"
        discovered_at = str(entry.get("discovered_at", "")).strip()

        prompt_msg = (
            f"Pending device detected:\n\n"
            f"IP: {ip}\n"
            f"MAC: {mac}\n"
            f"Source: {source}\n"
            f"Discovered: {discovered_at}\n\n"
            f"Approve this device for enrollment and deployment?"
        )
        approved = _popup_yes_no("Skynetv2 Device Approval", prompt_msg, default=False)
        now_iso = datetime.now().isoformat()
        entry["reviewed_at"] = now_iso
        entry["reviewed_by"] = "popup_review"
        changed = True

        if not approved:
            entry["status"] = "rejected"
            registry.setdefault("events", []).append(
                {
                    "event": "device_rejected",
                    "fingerprint": fingerprint,
                    "at": now_iso,
                    "reviewed_by": "popup_review",
                }
            )
            skipped_entries.append({
                "fingerprint": fingerprint,
                "ip": ip,
                "mac": mac,
                "reason": "user_rejected_via_popup",
            })
            continue

        entry["status"] = "approved"
        if fingerprint and fingerprint not in enrolled_ids:
            enrolled.append(
                {
                    "fingerprint": fingerprint,
                    "ip": ip,
                    "mac": mac,
                    "source": source,
                    "enrolled_at": now_iso,
                    "last_heartbeat_at": "",
                    "status": "active",
                }
            )
            enrolled_ids.add(fingerprint)

        device_name = f"auto-{ip.replace('.', '-') or 'unknown'}"
        os_type = _guess_os_type_for_device(ip, mac)
        add_result = add_device_to_deployment_approvals(device_name, ip, os_type, mac)
        approve_result = approve_device_for_deployment(device_name)

        registry.setdefault("events", []).append(
            {
                "event": "device_enrolled",
                "fingerprint": fingerprint,
                "at": now_iso,
                "reviewed_by": "popup_review",
            }
        )

        approved_entries.append(
            {
                "fingerprint": fingerprint,
                "ip": ip,
                "mac": mac,
                "device_name": device_name,
                "os_type": os_type,
                "deployment_add": add_result,
                "deployment_approve": approve_result,
            }
        )

    if changed:
        registry["events"] = registry.get("events", [])[-500:]
        save_device_enrollment_queue(queue)
        save_device_registry(registry)

    result = {
        "status": "ok",
        "pending_found": len(pending_entries),
        "approved_devices": approved_entries,
        "skipped_devices": skipped_entries,
        "bundles": {"status": "not_requested"},
    }

    bundle_lines = []
    if auto_prepare_bundles and approved_entries:
        policy = load_workspace_policy()
        bundle_result = prepare_install_bundle_for_approved_devices(policy)
        result["bundles"] = bundle_result

        approved_names = {item.get("device_name", "") for item in approved_entries}
        for bundle in bundle_result.get("bundles", []):
            if bundle.get("device_name") not in approved_names:
                continue
            status = str(bundle.get("status", "unknown")).strip().lower()
            icon = "SUCCESS" if status == "prepared" else "FAILED"
            bundle_lines.append(
                f"{icon}: {bundle.get('device_name')} ({bundle.get('ip_address')}) - {status}"
            )

    summary_lines = [
        f"Pending reviewed: {len(pending_entries)}",
        f"Approved: {len(approved_entries)}",
        f"Rejected: {len(skipped_entries)}",
    ]
    if bundle_lines:
        summary_lines.append("")
        summary_lines.append("Deployment results:")
        summary_lines.extend(bundle_lines)

    _popup_info("Skynetv2 Deployment Summary", "\n".join(summary_lines), is_error=False)
    return result

def explain_rejected_enrollment_devices() -> dict:
    queue = load_device_enrollment_queue()
    rejected = []

    for entry in queue:
        if not isinstance(entry, dict):
            continue
        if str(entry.get("status", "")).strip().lower() != "rejected":
            continue

        ip = str(entry.get("ip", "")).strip()
        mac = str(entry.get("mac", "")).strip()
        reviewed_at = str(entry.get("reviewed_at", "")).strip()
        source = str(entry.get("source", "unknown")).strip() or "unknown"

        reasons = [
            "manual denial during previous approval prompt",
            "device may have failed reachability or credential checks at review time",
        ]
        if ip.endswith(".1"):
            reasons.append("appears to be network gateway/router; often intentionally blocked from agent install")

        rejected.append(
            {
                "fingerprint": str(entry.get("fingerprint", "")).strip(),
                "ip": ip,
                "mac": mac,
                "source": source,
                "discovered_at": str(entry.get("discovered_at", "")).strip(),
                "reviewed_at": reviewed_at,
                "likely_reasons": reasons,
            }
        )

    return {
        "status": "ok",
        "count": len(rejected),
        "rejected_devices": rejected,
    }

def run_device_discovery_cycle():
    global _last_device_discovery_at
    with _device_lock:
        now = time.time()
        if now - _last_device_discovery_at < max(30, DEVICE_DISCOVERY_INTERVAL_SEC):
            return
        _last_device_discovery_at = now
    discover_devices()
    try:
        run_network_port_scan_and_email_report(load_network_scan_policy())
    except Exception as exc:
        log_action(f"Network port scan/report failed: {exc}")

@dataclass
class SynthesisReport:
    problem: str
    source: str
    severity: str
    pattern_family: str
    hybrid_strategy: str
    steps: list[str] = field(default_factory=list)
    scores: dict[str, int] = field(default_factory=dict)
    big_o: dict[str, str] = field(default_factory=dict)
    notes: list[str] = field(default_factory=list)

    def as_dict(self):
        return {
            "problem": self.problem,
            "source": self.source,
            "severity": self.severity,
            "pattern_family": self.pattern_family,
            "hybrid_strategy": self.hybrid_strategy,
            "steps": list(self.steps),
            "scores": dict(self.scores),
            "big_o": dict(self.big_o),
            "notes": list(self.notes),
        }

class AlgorithmicSynthesizer:
    """
    Lightweight local synthesis engine inspired by the algorithmic-synthesis brief.

    The goal here is not research automation. It is to turn a failure signature
    into a compact, testable remediation plan with a few scored dimensions:
    latency, robustness, maintainability, and parallelability.
    """

    PATTERN_LIBRARY = {
        "trainer": {
            "family": "process_liveness",
            "strategy": "guard the trainer process with PID verification and restart escalation",
            "keywords": {"trainer", "pid", "process", "running", "alive"},
            "steps": ["verify_pid", "queue_restart", "record_history"],
        },
        "download": {
            "family": "ingestion_throughput",
            "strategy": "combine throughput monitoring with backoff and retry-aware queueing",
            "keywords": {"download", "dataset", "rate", "bandwidth", "ingest"},
            "steps": ["measure_throughput", "queue_restart", "record_history"],
        },
        "cort": {
            "family": "dependency_stability",
            "strategy": "classify dependency failures before they cascade into retry storms",
            "keywords": {"import", "module", "dependency", "missing", "notfound"},
            "steps": ["classify_dependency_issue", "record_history", "surface_to_registry"],
        },
        "timeout": {
            "family": "latency_control",
            "strategy": "merge timeout detection with bounded retries and degraded-mode fallback",
            "keywords": {"timeout", "slow", "latency", "hang", "blocked"},
            "steps": ["detect_timeout", "fallback_route", "record_history"],
        },
        "error": {
            "family": "error_learning",
            "strategy": "turn observed errors into compact rewrite rules and replayable signatures",
            "keywords": {"error", "traceback", "exception", "failure", "crash"},
            "steps": ["capture_signature", "learn_rule", "record_history"],
        },
        "disk": {
            "family": "capacity_management",
            "strategy": "merge space pressure detection with cleanup and downstream throttling",
            "keywords": {"disk", "space", "full", "storage", "capacity"},
            "steps": ["measure_capacity", "cleanup", "record_history"],
        },
        "memory": {
            "family": "resource_pressure",
            "strategy": "combine memory trending with compaction hints and workload reduction",
            "keywords": {"memory", "ram", "leak", "oom", "pressure"},
            "steps": ["measure_memory", "reduce_load", "record_history"],
        },
    }

    def research(self, reason, source, severity):
        tokens = set(_tokenize(reason)) | set(_tokenize(source))
        matched = []
        for key, spec in self.PATTERN_LIBRARY.items():
            if tokens.intersection(spec["keywords"]):
                matched.append((key, spec))
        if not matched:
            matched = [("generic", {
                "family": "general_resilience",
                "strategy": "pair observability with a conservative retry-and-record plan",
                "steps": ["log", "monitor", "record_history"],
            })]
        return matched[:3]

    def synthesize(self, reason, source, severity):
        matches = self.research(reason, source, severity)
        primary_key, primary = matches[0]
        secondary = matches[1][1] if len(matches) > 1 else primary

        steps = []
        for candidate_steps in [primary.get("steps", []), secondary.get("steps", []), ["surface_to_registry"]]:
            for step in candidate_steps:
                if step not in steps:
                    steps.append(step)

        hybrid_strategy = (
            f"{primary['strategy']} "
            f"Hybridized with {secondary.get('strategy', primary['strategy'])}."
        )

        score_seed = len(set(_tokenize(reason)))
        scores = {
            "latency": max(1, 10 - min(8, score_seed)),
            "robustness": 8 if severity in {"high", "critical"} else 6,
            "maintainability": 9 if primary_key != "generic" else 7,
            "parallelability": 7 if len(steps) > 2 else 5,
        }

        big_o = {
            "time": "O(k + n)",
            "space": "O(k)",
            "notes": "k is the number of matched local patterns; n is token count in the failure signature.",
        }

        notes = [
            f"Matched pattern families: {', '.join(spec['family'] for _, spec in matches)}",
            "Designed for local execution and deterministic rule generation.",
            "No network calls are required for synthesis.",
        ]

        return SynthesisReport(
            problem=_compact_text(reason),
            source=_compact_text(source),
            severity=_compact_text(severity),
            pattern_family=primary.get("family", "general_resilience"),
            hybrid_strategy=hybrid_strategy,
            steps=steps,
            scores=scores,
            big_o=big_o,
            notes=notes,
        )

class BaseModule:
    def __init__(self, blueprint):
        self.blueprint = blueprint
        self.name = blueprint["key"]
        self.last_checked_at = ""

    def health_check(self):
        self.last_checked_at = datetime.now().isoformat()
        return True

    def self_heal(self):
        """Trigger healing via code rewrite, with safeguards to prevent cascading failures.
        DESIGN PRINCIPLE: Self-healing should be PROGRAMMATIC, not UI-based.
        This prevents infinite loops when file operations depend on file existence.
        Works across any workspace and code type without file-specific assumptions."""
        try:
            backlog = load_rewrite_backlog()
            # SAFEGUARD: Check if we already have pending rewrites for this module
            existing = [item for item in backlog
                       if item.get("source") == f"self_healing:{self.name}"
                       and item.get("status") in {"queued", "analyzing"}]
            if len(existing) < 2:  # Only queue if < 2 pending (prevent spam)
                queue_code_rewrite(
                    reason=f"Health check failed for {self.name}",
                    source=f"self_healing:{self.name}",
                    severity="warning",
                )
                log_action(f"[SelfHeal] Queued fix for {self.name}, pending={len(existing)+1}")
        except Exception as exc:
            log_action(f"[SelfHeal] Exception for {self.name}: {exc}")
        return True

class StateModule(BaseModule):
    def health_check(self):
        self.last_checked_at = datetime.now().isoformat()
        registry_ok = REGISTRY_FILE.parent.exists()
        queue_ok = REWRITE_QUEUE_FILE.parent.exists()
        return registry_ok and queue_ok

class RewriteEngineModule(BaseModule):
    def health_check(self):
        self.last_checked_at = datetime.now().isoformat()
        try:
            load_rewrite_backlog()
            load_rewrite_rules()
            load_rewrite_history()
            return True
        except Exception:
            return False

class SynthesisModule(BaseModule):
    def health_check(self):
        self.last_checked_at = datetime.now().isoformat()
        report = AlgorithmicSynthesizer().synthesize("synthetic health check", self.name, "info")
        return bool(report.steps and report.scores)

class MonitoringModule(BaseModule):
    def health_check(self):
        self.last_checked_at = datetime.now().isoformat()
        if psutil is None:
            return True
        try:
            psutil.cpu_percent(interval=0.1)
            psutil.virtual_memory()
            psutil.disk_usage("/")
            return True
        except Exception:
            return False

class SchedulerModule(BaseModule):
    def health_check(self):
        self.last_checked_at = datetime.now().isoformat()
        return LOOP_INTERVAL > 0

class OrchestrationModule(BaseModule):
    def health_check(self):
        self.last_checked_at = datetime.now().isoformat()
        state = read_json(REGISTRY_FILE)
        if not isinstance(state, dict):
            state = {}
        return "started_at" in state

class SelfHealingManager:
    def __init__(self):
        self.modules = {}
        self.failure_log = []

    def register(self, name, module):
        self.modules[name] = module

    def monitor_and_heal(self):
        module_health_updates = {}
        for name, module in self.modules.items():
            try:
                healthy = module.health_check()
                module_health_updates[name] = {
                    "healthy": bool(healthy),
                    "last_checked_at": getattr(module, "last_checked_at", datetime.now().isoformat()),
                }
                if not healthy:
                    self.log_failure(name, "Health check failed")
                    module.self_heal()
            except Exception as exc:
                self.log_failure(name, f"Exception: {exc}")
                try:
                    module.self_heal()
                except Exception as heal_exc:
                    self.log_failure(name, f"Self-heal failed: {heal_exc}")
        if module_health_updates:
            def mutate(state):
                state.setdefault("module_health", {}).update(module_health_updates)

            update_registry_state(mutate)

    def log_failure(self, name, message):
        timestamp = datetime.now().isoformat()
        self.failure_log.append((name, message, timestamp))
        self.failure_log = self.failure_log[-200:]
        log_action(f"[SelfHealingManager] {name} failure: {message}")
        _append_failure_entry(name, message)
        queue_code_rewrite(reason=message, source=f"self_healing:{name}", severity="warning")

    def email_report(self):
        if not self.failure_log or not ENABLE_EMAIL_REPORTS:
            return
        if not ADMIN_EMAIL:
            return
        summary = "\n".join(
            [
                f"Failures captured: {len(self.failure_log)}",
                "",
                *[f"{name}: {message} at {timestamp}" for name, message, timestamp in self.failure_log[-5:]],
            ]
        )
        send_email("skynetv2 Agent Self-Healing Report", summary, ADMIN_EMAIL)

def build_self_healing_manager():
    manager = SelfHealingManager()
    module_map = {
        "state_persistence": StateModule,
        "rewrite_engine": RewriteEngineModule,
        "synthesis_planner": SynthesisModule,
        "monitoring": MonitoringModule,
        "scheduler": SchedulerModule,
        "orchestration": OrchestrationModule,
    }
    module_blueprints = [
        {"key": "state_persistence", "title": "State Persistence", "integrations": ["json"], "capabilities": ["durable state"]},
        {"key": "rewrite_engine", "title": "Rewrite Engine", "integrations": ["local rules"], "capabilities": ["backlog processing"]},
        {"key": "synthesis_planner", "title": "Algorithmic Synthesis", "integrations": ["local heuristics"], "capabilities": ["hybrid plan generation"]},
        {"key": "monitoring", "title": "Monitoring", "integrations": ["psutil"], "capabilities": ["resource checks"]},
        {"key": "scheduler", "title": "Scheduler", "integrations": ["time"], "capabilities": ["loop timing"]},
        {"key": "orchestration", "title": "Orchestration", "integrations": ["registry"], "capabilities": ["agent coordination"]},
    ]
    for blueprint in module_blueprints:
        module_cls = module_map.get(blueprint["key"], BaseModule)
        manager.register(blueprint["key"], module_cls(blueprint))
    return manager

def start_self_healing_manager(manager):
    def loop():
        while True:
            manager.monitor_and_heal()
            manager.email_report()
            time.sleep(60)

    thread = threading.Thread(target=loop, daemon=True)
    thread.start()
    return thread

def estimate_project_amount(project_text):
    message = str(project_text or "").strip()
    lowered = message.lower()
    base = 150
    keyword_weights = {
        "api": 100,
        "backend": 180,
        "frontend": 140,
        "react": 160,
        "database": 180,
        "postgres": 170,
        "auth": 140,
        "payment": 220,
        "chatbot": 240,
        "ai": 220,
        "automation": 130,
        "scraper": 120,
        "deploy": 180,
        "docker": 150,
        "admin": 140,
        "dashboard": 160,
        "mobile": 180,
    }
    score = base
    for key, weight in keyword_weights.items():
        if key in lowered:
            score += weight
    score += min(450, max(0, len(message) // 8))
    rounded = int(round(score / 25.0) * 25)
    low = max(100, int(round(rounded * 0.85 / 25.0) * 25))
    high = int(round(rounded * 1.2 / 25.0) * 25)
    return {
        "estimate_usd": rounded,
        "range_low_usd": low,
        "range_high_usd": high,
    }

def check_training_goal():
    status = read_json(TRAINING_STATUS)
    if not status:
        return False
    dataset_progress = status.get("dataset_progress", {})
    training_progress = status.get("training_progress", {})
    if float(dataset_progress.get("total_size_gb", 0) or 0) < DATASET_TARGET_GB:
        return False
    if int(training_progress.get("current_epoch", 0) or 0) < EPOCH_TARGET and float(training_progress.get("loss", 1) or 1) > LOSS_TARGET:
        return False
    return True

def monitor_resources():
    if psutil is None:
        log_action("psutil unavailable; skipping resource snapshot.")
        return
    try:
        cpu = psutil.cpu_percent(interval=0.1)
        memory = psutil.virtual_memory().percent
        disk = psutil.disk_usage("/").percent
        log_action(f"Resource usage: CPU={cpu}%, MEM={memory}%, DISK={disk}%")
    except Exception as exc:
        log_action(f"Resource monitor failed: {exc}")

def _is_pid_running(pid):
    if not pid:
        return False
    if psutil is None:
        try:
            os.kill(int(pid), 0)
            return True
        except Exception:
            return False
    try:
        return psutil.pid_exists(int(pid))
    except Exception:
        return False

def maybe_restart_training(reason):
    global _last_training_restart_at
    now = time.time()
    if now - _last_training_restart_at < TRAINING_RESTART_COOLDOWN_SEC:
        return False
    _last_training_restart_at = now
    log_action(f"Training restart requested: {reason}")
    return True

def queue_code_rewrite(reason, source, severity="info"):
    with _rewrite_lock:
        backlog = load_rewrite_backlog()
        fingerprint = make_rewrite_fingerprint(reason, source)
        priority_score = _rewrite_priority_score(reason, source, severity)
        for item in backlog:
            if item.get("fingerprint") == fingerprint and item.get("status") in {"queued", "analyzing", "validated", "applied"}:
                existing = int(item.get("priority_score", 0) or 0)
                if priority_score > existing:
                    item["priority_score"] = priority_score
                    save_rewrite_backlog(_sort_backlog_by_priority(backlog))
                return item
        entry = {
            "created_at": datetime.now().isoformat(),
            "reason": _compact_text(reason),
            "source": _compact_text(source),
            "severity": _compact_text(severity),
            "status": "queued",
            "fingerprint": fingerprint,
            "priority_score": priority_score,
        }
        backlog.append(entry)
        save_rewrite_backlog(_sort_backlog_by_priority(backlog))
        return entry

def build_rewrite_candidate(entry):
    synthesizer = AlgorithmicSynthesizer()
    report = synthesizer.synthesize(entry.get("reason", ""), entry.get("source", ""), entry.get("severity", "info"))
    rule_id = hashlib.sha256(f"{entry.get('fingerprint')}|{report.pattern_family}".encode("utf-8")).hexdigest()[:24]
    candidate = {
        "rule_id": rule_id,
        "title": f"Auto fix for {entry.get('source', 'unknown')}",
        "source": entry.get("source", "unknown"),
        "match_terms": sorted(set(_tokenize(entry.get("reason", ""))))[:8],
        "action": f"synthesized_{report.pattern_family}",
        "site_response": "A synthesized local remediation rule has been added for this issue.",
        "remediation_steps": report.steps,
        "created_from": entry.get("created_at"),
        "fingerprint": entry.get("fingerprint") or make_rewrite_fingerprint(entry.get("reason", ""), entry.get("source", "")),
        "enabled": True,
        "synthesis_report": report.as_dict(),
    }

    reason_tokens = set(_tokenize(entry.get("reason", "")))
    create_file_markers = {"new", "file", "module", "adapter", "plugin", "scaffold", "create"}
    if reason_tokens.intersection(create_file_markers):
        source_slug = re.sub(r"[^a-z0-9]+", "_", str(entry.get("source", "unknown")).lower()).strip("_") or "unknown"
        target_path = BASE_DIR / "autonomous_generated" / f"auto_{source_slug}_{datetime.now().strftime('%Y%m%d_%H%M%S')}.py"
        candidate["action"] = "create_new_file_stub"
        candidate["target_file"] = str(target_path)
        candidate["new_file_contents"] = "\n".join(
            [
                '"""Auto-generated helper created by skynetv2 rewrite pipeline."""',
                "",
                f'SOURCE = {json.dumps(str(entry.get("source", "unknown")))}',
                f'REASON = {json.dumps(str(entry.get("reason", "")))}',
                "",
                "def run():",
                "    return {\"status\": \"generated\", \"source\": SOURCE}",
                "",
            ]
        )
    return candidate

def validate_rewrite_candidate(candidate):
    required = {"rule_id", "title", "source", "action", "site_response", "remediation_steps", "fingerprint"}
    missing = sorted(required - set(candidate))
    if missing:
        return False, f"Missing candidate fields: {', '.join(missing)}"
    if not isinstance(candidate.get("remediation_steps"), list) or not candidate["remediation_steps"]:
        return False, "Candidate must include remediation steps"
    if candidate.get("action") == "create_new_file_stub":
        target_file = str(candidate.get("target_file", "")).strip()
        new_file_contents = candidate.get("new_file_contents")
        if not target_file:
            return False, "create_new_file_stub requires target_file"
        if not isinstance(new_file_contents, str) or not new_file_contents.strip():
            return False, "create_new_file_stub requires non-empty new_file_contents"
    return True, "ok"

def _policy_allows_new_file(path: Path, policy: dict) -> tuple[bool, str]:
    suffix = path.suffix.lower()
    allowed_suffixes = {str(s).lower() for s in policy.get("allowed_file_types", [".py"]) if str(s).startswith(".")}
    if suffix not in allowed_suffixes:
        return False, f"suffix '{suffix}' not allowed by policy"
    if not path_allowed_for_rewrite(path, policy):
        return False, "path outside allowed workspace"
    if not _path_selected_for_rewrite(path, policy):
        return False, "path excluded by include/exclude filters"
    return True, "ok"

def _parse_ref_instruction(instruction: str) -> tuple[str, str, str]:
    text = str(instruction or "").strip()
    if not text:
        return "", "", ""

    normalized = text.replace("\r\n", "\n")
    command = "append"

    prefixed = re.match(r"^(append|create|write|update)\s+(.+)$", normalized, flags=re.IGNORECASE | re.DOTALL)
    if prefixed:
        command = prefixed.group(1).lower()
        normalized = prefixed.group(2).strip()

    if ">>" in normalized:
        left, right = normalized.split(">>", 1)
        return command if command else "append", left.strip(), right.strip()

    if "::" in normalized:
        left, right = normalized.split("::", 1)
        return command if command else "append", left.strip(), right.strip()

    if "\n" in normalized:
        first, rest = normalized.split("\n", 1)
        candidate_path = first.strip()
        if "/" in candidate_path or "\\" in candidate_path or "." in Path(candidate_path).name:
            return command if command else "append", candidate_path, rest.strip()

    return "", "", ""

def _apply_ref_instruction_to_file(instruction: str, policy: dict, source: str = "ref") -> dict:
    mode, target_raw, payload = _parse_ref_instruction(instruction)
    if not mode or not target_raw or not payload:
        return {"status": "unparsed", "reason": "expected format: ref <file> :: <code> or ref append <file> >> <code>"}

    target_path = Path(target_raw).expanduser()
    if not target_path.is_absolute():
        target_path = (BASE_DIR / target_path).resolve()
    else:
        target_path = target_path.resolve()

    allowed, reason = _policy_allows_new_file(target_path, policy)
    if not allowed:
        return {"status": "blocked", "file": str(target_path), "reason": reason}

    target_path.parent.mkdir(parents=True, exist_ok=True)
    exists = target_path.exists()

    if mode == "create" and exists:
        return {"status": "exists", "file": str(target_path), "reason": "target file already exists"}

    try:
        original = target_path.read_text(encoding="utf-8") if exists else ""
    except Exception as exc:
        return {"status": "error", "file": str(target_path), "reason": f"failed to read target: {exc}"}

    normalized_payload = payload if payload.endswith("\n") else payload + "\n"
    if mode == "write":
        updated = normalized_payload
    else:
        separator = "" if not original or original.endswith("\n") else "\n"
        updated = f"{original}{separator}{normalized_payload}"

    max_size = _max_change_size_bytes_for_path(target_path, policy)
    if len(updated.encode("utf-8")) > max_size:
        return {"status": "blocked", "file": str(target_path), "reason": "updated file exceeds policy size limit"}

    try:
        target_path.write_text(updated, encoding="utf-8")
        if target_path.suffix.lower() == ".py":
            ok, message = _test_python_file(target_path)
            if not ok:
                if exists:
                    target_path.write_text(original, encoding="utf-8")
                else:
                    try:
                        target_path.unlink()
                    except Exception:
                        pass
                return {"status": "rolled_back", "file": str(target_path), "reason": message}
    except Exception as exc:
        return {"status": "error", "file": str(target_path), "reason": str(exc)[:200]}

    action = "created" if not exists else "updated"
    if mode in {"append", "update"} and exists:
        action = "appended"
    return {
        "status": action,
        "file": str(target_path),
        "source": source,
        "mode": mode,
        "bytes": len(normalized_payload.encode("utf-8")),
    }

def _apply_candidate_side_effect(candidate: dict, policy: dict) -> dict | None:
    if candidate.get("action") != "create_new_file_stub":
        return None

    target_file_raw = str(candidate.get("target_file", "")).strip()
    content = str(candidate.get("new_file_contents", ""))
    if not target_file_raw or not content.strip():
        return {"status": "skipped", "reason": "missing target_file or new_file_contents"}

    target_path = Path(target_file_raw).expanduser()
    if not target_path.is_absolute():
        target_path = (BASE_DIR / target_path).resolve()
    else:
        target_path = target_path.resolve()

    allowed, reason = _policy_allows_new_file(target_path, policy)
    if not allowed:
        return {"status": "blocked", "file": str(target_path), "reason": reason}

    if target_path.exists():
        return {"status": "exists", "file": str(target_path), "reason": "target file already exists"}

    max_size = _max_change_size_bytes_for_path(target_path, policy)
    payload_bytes = len(content.encode("utf-8"))
    if payload_bytes > max_size:
        return {
            "status": "blocked",
            "file": str(target_path),
            "reason": "new file content exceeds policy size limit",
        }

    target_path.parent.mkdir(parents=True, exist_ok=True)
    target_path.write_text(content, encoding="utf-8")
    if target_path.suffix.lower() == ".py":
        ok, message = _test_python_file(target_path)
        if not ok:
            try:
                target_path.unlink()
            except Exception:
                pass
            return {
                "status": "rolled_back",
                "file": str(target_path),
                "reason": message,
            }

    return {
        "status": "created",
        "file": str(target_path),
        "bytes": payload_bytes,
    }

def apply_rewrite_candidate(entry, candidate):
    with _rewrite_lock:
        policy = load_workspace_policy()
        rules = load_rewrite_rules()
        history = load_rewrite_history()

        existing = next((rule for rule in rules if rule.get("fingerprint") == candidate["fingerprint"]), None)
        if existing:
            result = "reused_existing_rule"
            rule_id = existing["rule_id"]
        else:
            rules.append(candidate)
            save_rewrite_rules(rules)
            result = "created_new_rule"
            rule_id = candidate["rule_id"]

        side_effect_result = _apply_candidate_side_effect(candidate, policy)
        if isinstance(side_effect_result, dict) and side_effect_result.get("status") in {"created", "rolled_back", "blocked"}:
            log_action(
                "Rewrite candidate side effect: "
                f"status={side_effect_result.get('status')} "
                f"file={side_effect_result.get('file', '')} "
                f"reason={side_effect_result.get('reason', '')}"
            )

        history.append(
            {
                "processed_at": datetime.now().isoformat(),
                "entry": entry,
                "candidate": candidate,
                "candidate_side_effect": side_effect_result,
                "result": result,
            }
        )
        save_rewrite_history(history)

        def mutate(state):
            state["last_rewrite_execution"] = {
                "processed_at": datetime.now().isoformat(),
                "result": result,
                "rule_id": rule_id,
                "source": entry.get("source"),
                "candidate_side_effect": side_effect_result,
            }
            rewrite_counts = state.setdefault("rewrite_counts", {})
            rewrite_counts[result] = int(rewrite_counts.get(result, 0)) + 1

        update_registry_state(mutate)

        return {"result": result, "rule_id": rule_id, "candidate_side_effect": side_effect_result}

def run_staged_self_rewrite_executor():
    backlog = _sort_backlog_by_priority(load_rewrite_backlog())
    changed = False
    for entry in backlog:
        if entry.get("status") != "queued":
            continue

        entry["status"] = "analyzing"
        entry["analyzed_at"] = datetime.now().isoformat()
        changed = True
        save_rewrite_backlog(backlog)

        candidate = build_rewrite_candidate(entry)
        valid, validation_message = validate_rewrite_candidate(candidate)
        if not valid:
            entry["status"] = "rejected"
            entry["rejected_at"] = datetime.now().isoformat()
            entry["validation_error"] = validation_message
            save_rewrite_backlog(backlog)
            return

        entry["status"] = "validated"
        entry["validated_at"] = datetime.now().isoformat()
        entry["candidate_rule_id"] = candidate["rule_id"]
        save_rewrite_backlog(backlog)

        result = apply_rewrite_candidate(entry, candidate)
        entry["status"] = "applied"
        entry["applied_at"] = datetime.now().isoformat()
        entry["apply_result"] = result
        save_rewrite_backlog(backlog)
        return

    if changed:
        save_rewrite_backlog(backlog)

def _scan_workspace_for_error_markers(policy: dict) -> dict:
    markers = [str(m).strip() for m in policy.get("error_learning_markers", []) if str(m).strip()]
    if not markers:
        markers = ["Traceback", "Exception", "Error", "ModuleNotFoundError"]

    max_files = max(1, int(policy.get("error_learning_any_file_scan_max_files", 50000)))
    max_bytes = max(1024, int(policy.get("error_learning_any_file_scan_max_bytes_per_file", 1048576)))
    workspace_roots = [Path(p.replace("**", "").rstrip("/")).resolve() for p in policy.get("workspace_paths", [])]

    scanned = 0
    matches: list[dict[str, Any]] = []
    for root in workspace_roots:
        if not root.exists() or not root.is_dir():
            continue
        for path in root.glob("**/*"):
            if scanned >= max_files:
                break
            if not path.exists() or not path.is_file():
                continue
            if not path_allowed_for_rewrite(path, policy):
                continue
            if not _path_selected_for_rewrite(path, policy):
                continue

            scanned += 1
            try:
                if path.stat().st_size > max_bytes:
                    continue
                content = path.read_text(encoding="utf-8", errors="ignore")
            except Exception:
                continue

            hit_markers = [marker for marker in markers if marker in content]
            if hit_markers:
                matches.append(
                    {
                        "file": str(path),
                        "markers": hit_markers[:8],
                    }
                )
                if len(matches) >= 200:
                    break
        if scanned >= max_files or len(matches) >= 200:
            break

    return {
        "scanned_files": scanned,
        "matches": matches,
        "markers": markers,
    }

def run_error_learning_cycle():
    policy = load_workspace_policy()

    if bool(policy.get("error_learning_any_file_scan_enabled", True)):
        scan = _scan_workspace_for_error_markers(policy)
        matches = scan.get("matches", []) if isinstance(scan.get("matches", []), list) else []
        if matches:
            preview = ", ".join(str(item.get("file", "")) for item in matches[:5])
            queue_code_rewrite(
                reason=(
                    f"Detected error markers in {len(matches)} file(s) across workspace. "
                    f"Examples: {preview}"
                ),
                source="error_learning_cycle",
                severity="medium",
            )
            return

    if not ERROR_LOG_PATH.exists():
        return
    try:
        contents = ERROR_LOG_PATH.read_text(encoding="utf-8")
    except Exception as exc:
        log_action(f"Failed to read error log for learning cycle: {exc}")
        return

    fallback_markers = [str(m).strip() for m in policy.get("error_learning_markers", []) if str(m).strip()]
    if not fallback_markers:
        fallback_markers = ["Traceback", "Exception", "Error", "ModuleNotFoundError"]

    if any(marker in contents for marker in fallback_markers):
        queue_code_rewrite(
            reason="Detected error markers in implementation_outputs/error_log.json",
            source="error_learning_cycle",
            severity="medium",
        )

def detect_failures():
    global _last_training_issue_signature, _last_training_issue_logged_at
    policy = load_workspace_policy()
    is_swarm_mode = str(policy.get("trainer_runtime_target", "docker-swarm")).lower() == "docker-swarm"
    sync_result = _sync_training_status_from_swarm() if is_swarm_mode else {"swarm_running": False}
    status = read_json(TRAINING_STATUS)
    if not status:
        return
    trainer = status.get("processes", {}).get("nlp_trainer", {})
    trainer_pid = trainer.get("pid")
    trainer_flag = bool(trainer.get("running", False))
    trainer_alive = bool(sync_result.get("swarm_running", False)) if is_swarm_mode else _is_pid_running(trainer_pid)
    training_issue_signature = (trainer_flag, trainer_alive, trainer_pid)
    training_issue_message = None
    if trainer_flag and not trainer_alive and not is_swarm_mode:
        training_issue_message = "nlp_trainer status mismatch detected. PID is not alive even though running=true."
    if not trainer_flag or not trainer_alive:
        if not training_issue_message:
            training_issue_message = "nlp_trainer not running. Attempting restart."
        now = time.time()
        if (
            training_issue_signature != _last_training_issue_signature
            or now - _last_training_issue_logged_at >= max(60, TRAINING_RESTART_COOLDOWN_SEC)
        ):
            _last_training_issue_signature = training_issue_signature
            _last_training_issue_logged_at = now
            log_action(training_issue_message)
        queue_code_rewrite(
            reason="nlp_trainer not running according to training_status.json",
            source="training_monitor",
            severity="high",
        )
        if is_swarm_mode:
            import shutil as _shutil
            if not _shutil.which("docker"):
                # Docker not installed — silently switch to local mode to stop the crash loop
                log_action("Docker not found; swarm remediation skipped. Set trainer_runtime_target=local in policy to silence this.")
                maybe_restart_training("docker not available; using local trainer mode")
            else:
                try:
                    result = remediate_trainer_on_swarm(policy)
                    if result.get("status") not in {"healthy", "backoff"}:
                        log_action(f"Trainer swarm remediation: {result}")
                    if result.get("status") in {"trainer_service_not_found", "skipped_swarm_inactive"}:
                        maybe_restart_training("trainer swarm remediation unavailable")
                except Exception as _swarm_exc:
                    log_action(f"Swarm remediation error (non-fatal): {_swarm_exc!s:.180}")
        else:
            maybe_restart_training("trainer not running or stale PID")

def discover_system_services():
    try:
        result = subprocess.run(
            ["systemctl", "list-units", "--all", "--type=service", "--no-pager", "-o", "json"],
            capture_output=True,
            text=True,
            timeout=10,
            check=False,
        )
        if result.returncode != 0:
            return []
        services_data = json.loads(result.stdout) if result.stdout else []
    except Exception as exc:
        log_action(f"Service discovery failed: {exc}")
        return []

    policy = load_workspace_policy()
    modifiable = set(policy.get("modifiable_services", []))
    tracked_services = []
    for svc in services_data:
        name = svc.get("unit", "")
        if not name:
            continue
        tracked_services.append(
            {
                "name": name,
                "load": svc.get("load", ""),
                "active": svc.get("active", ""),
                "sub": svc.get("sub", ""),
                "description": svc.get("description", ""),
                "modifiable": name.rstrip(".service") in modifiable,
                "last_scan": datetime.now().isoformat(),
            }
        )

    registry = load_service_registry()
    registry["services"] = tracked_services
    registry["last_full_scan"] = datetime.now().isoformat()
    save_service_registry(registry)
    return tracked_services

def discover_packages():
    packages = []
    try:
        result = subprocess.run(
            [sys.executable, "-m", "pip", "list", "--format=json"],
            capture_output=True,
            text=True,
            timeout=20,
            check=False,
        )
        if result.returncode == 0 and result.stdout:
            for pkg in json.loads(result.stdout):
                packages.append({"name": pkg.get("name", ""), "version": pkg.get("version", ""), "type": "python", "manager": "pip"})
    except Exception as exc:
        log_action(f"Python package scan failed: {exc}")

    try:
        result = subprocess.run(["dpkg", "-l"], capture_output=True, text=True, timeout=20, check=False)
        if result.returncode == 0 and result.stdout:
            for line in result.stdout.splitlines():
                parts = line.split()
                if len(parts) >= 3 and parts[0] == "ii":
                    packages.append({"name": parts[1], "version": parts[2], "type": "system", "manager": "apt"})
    except Exception as exc:
        log_action(f"System package scan failed: {exc}")

    registry = load_package_registry()
    registry["packages"] = packages
    registry["last_full_scan"] = datetime.now().isoformat()
    save_package_registry(registry)
    return packages

def path_allowed_for_rewrite(file_path: Path, policy: dict) -> bool:
    path_value = str(file_path.resolve())
    blocked_subpaths = ["/.venv/", "/site-packages/", "/dist-packages/", "/{venv_dir}/"]
    if any(token in path_value for token in blocked_subpaths):
        return False
    for pattern in policy.get("deny_paths", []):
        prefix = pattern.replace("**", "").rstrip("/")
        if prefix and path_value.startswith(prefix):
            return False
    for pattern in policy.get("workspace_paths", []):
        prefix = pattern.replace("**", "").rstrip("/")
        if prefix and path_value.startswith(prefix):
            return True
    return False

def _path_selected_for_rewrite(file_path: Path, policy: dict) -> bool:
    includes = policy.get("include_paths", ["**"]) or ["**"]
    excludes = policy.get("exclude_paths", []) or []
    path_str = str(file_path.resolve())

    include_match = False
    for pattern in includes:
        p = str(pattern or "").strip()
        if not p:
            continue
        if fnmatch.fnmatch(path_str, p) or fnmatch.fnmatch(file_path.name, p):
            include_match = True
            break
    if not include_match:
        return False

    for pattern in excludes:
        p = str(pattern or "").strip()
        if not p:
            continue
        if fnmatch.fnmatch(path_str, p) or fnmatch.fnmatch(file_path.name, p):
            return False
    return True

def _rewrite_bare_except(content: str) -> tuple[str, bool]:
    updated = re.sub(r"(^|\n)([ \t]*)except:\s*(\n)", r"\1\2except Exception:\3", content)
    return updated, updated != content

def _rewrite_debug_prints_python(content: str) -> tuple[str, bool]:
    updated = re.sub(r"(?m)^[ \t]*print\((?:f)?[\"'](?:DEBUG|TRACE|TEMP)[^\n]*\)\s*$\n?", "", content)
    return updated, updated != content

def _rewrite_python_import_hygiene(content: str) -> tuple[str, bool]:
    lines = content.splitlines()
    seen = set()
    changed = False
    out = []
    for line in lines:
        stripped = line.strip()
        if stripped.startswith("import ") or stripped.startswith("from "):
            key = stripped
            if key in seen:
                changed = True
                continue
            seen.add(key)
        out.append(line)
    updated = "\n".join(out)
    if content.endswith("\n"):
        updated += "\n"
    return updated, changed

def _rewrite_obvious_noop_lines(content: str, suffix: str) -> tuple[str, bool]:
    if suffix in {".py", ".js", ".ts", ".tsx", ".jsx", ".sh"}:
        # Remove placeholder no-op markers generated by templating/edit loops.
        updated = re.sub(r"(?m)^[ \t]*(?:pass\s*#\s*noop|//\s*noop|#\s*noop|;\s*)$\n?", "", content)
        return updated, updated != content
    return content, False

def _rewrite_trailing_whitespace(content: str) -> tuple[str, bool]:
    # Conservative cleanup: strip only trailing spaces/tabs at line ends.
    lines = content.splitlines(keepends=True)
    updated_lines = []
    changed = False
    for line in lines:
        if line.endswith("\r\n"):
            newline = "\r\n"
            body = line[:-2]
        elif line.endswith("\n"):
            newline = "\n"
            body = line[:-1]
        else:
            newline = ""
            body = line
        trimmed = body.rstrip(" \t")
        if trimmed != body:
            changed = True
        updated_lines.append(trimmed + newline)
    return "".join(updated_lines), changed

def _rewrite_duplicate_blank_lines(content: str) -> tuple[str, bool]:
    # Conservative compaction: collapse 3+ consecutive blank lines down to 2.
    updated = re.sub(r"\n{3,}", "\n\n", content)
    return updated, updated != content

def _score_rewrite_candidate(path: Path, transforms_applied: list[str], content_changed: bool) -> dict:
    if not content_changed:
        return {"risk": 0.0, "confidence": 0.0}

    risk = 0.25
    confidence = 0.65
    ext = path.suffix.lower()

    if ext == ".py":
        confidence += 0.15
        risk -= 0.05
    if "rewrite_import_hygiene" in transforms_applied:
        risk += 0.08
        confidence += 0.03
    if "rewrite_bare_except" in transforms_applied:
        confidence += 0.05
    if "rewrite_obvious_noop" in transforms_applied:
        risk -= 0.05
    if "rewrite_trailing_whitespace" in transforms_applied:
        risk -= 0.03
        confidence += 0.02
    if "rewrite_duplicate_blank_lines" in transforms_applied:
        risk -= 0.02
        confidence += 0.01

    risk = max(0.0, min(1.0, round(risk, 3)))
    confidence = max(0.0, min(1.0, round(confidence, 3)))
    return {"risk": risk, "confidence": confidence}

def _test_python_file(path: Path) -> tuple[bool, str]:
    result = subprocess.run([sys.executable, "-m", "py_compile", str(path)], capture_output=True, text=True, check=False)
    if result.returncode == 0:
        return True, "ok"
    return False, (result.stderr or result.stdout or "py_compile failed").strip()

def _apply_transforms_for_file(path: Path, original: str) -> tuple[str, list[str]]:
    updated = original
    applied = []
    suffix = path.suffix.lower()

    if suffix == ".py":
        for name, transform in [
            ("rewrite_bare_except", _rewrite_bare_except),
            ("rewrite_debug_prints", _rewrite_debug_prints_python),
            ("rewrite_import_hygiene", _rewrite_python_import_hygiene),
            ("rewrite_trailing_whitespace", _rewrite_trailing_whitespace),
            ("rewrite_duplicate_blank_lines", _rewrite_duplicate_blank_lines),
        ]:
            candidate, changed = transform(updated)
            if changed:
                updated = candidate
                applied.append(name)

    # Apply text-safe transforms to common code/document files as well.
    if suffix in {".js", ".ts", ".tsx", ".jsx", ".sh", ".md", ".txt", ".yaml", ".yml", ".json", ".html", ".css", ".go", ".rs", ".java", ".cpp", ".c", ".h"}:
        for name, transform in [
            ("rewrite_trailing_whitespace", _rewrite_trailing_whitespace),
            ("rewrite_duplicate_blank_lines", _rewrite_duplicate_blank_lines),
        ]:
            candidate, changed = transform(updated)
            if changed:
                updated = candidate
                applied.append(name)

    candidate, changed = _rewrite_obvious_noop_lines(updated, suffix)
    if changed:
        updated = candidate
        applied.append("rewrite_obvious_noop")

    return updated, applied

def apply_safe_rewrite_with_rollback(path: Path, policy: dict, canary_mode: bool = False) -> dict[str, Any]:
    original = path.read_text(encoding="utf-8")
    updated, transforms_applied = _apply_transforms_for_file(path, original)
    changed = updated != original
    if not changed:
        return {
            "status": "noop",
            "file": str(path),
            "reason": "no safe transforms applied",
            "transforms_applied": transforms_applied,
        }

    score = _score_rewrite_candidate(path, transforms_applied, changed)
    min_conf = float(policy.get("rewrite_min_confidence", 0.55) or 0.55)
    max_risk = float(policy.get("rewrite_max_risk", 0.65) or 0.65)
    if score["confidence"] < min_conf:
        return {
            "status": "skipped",
            "file": str(path),
            "reason": f"confidence too low ({score['confidence']} < {min_conf})",
            "risk": score["risk"],
            "confidence": score["confidence"],
            "transforms_applied": transforms_applied,
        }
    if score["risk"] > max_risk:
        return {
            "status": "skipped",
            "file": str(path),
            "reason": f"risk too high ({score['risk']} > {max_risk})",
            "risk": score["risk"],
            "confidence": score["confidence"],
            "transforms_applied": transforms_applied,
        }

    max_bytes = _max_change_size_bytes_for_path(path, policy)
    if len(updated.encode("utf-8")) > max_bytes:
        return {
            "status": "rejected",
            "file": str(path),
            "reason": f"changed file exceeds limit ({len(updated.encode('utf-8'))} > {max_bytes})",
            "risk": score["risk"],
            "confidence": score["confidence"],
            "transforms_applied": transforms_applied,
        }

    prechange: dict[str, Any] = _create_prechange_backup_and_git_push(path, original, policy)
    backup_path = Path("")
    try:
        if bool(policy.get("auto_backup", True)):
            backup_dir = Path(str(policy.get("backup_dir", BASE_DIR / "rewrite_backups"))).expanduser()
            backup_dir.mkdir(parents=True, exist_ok=True)
            backup_path = backup_dir / f"{path.name}.{datetime.now().strftime('%Y%m%d_%H%M%S')}.bak"
            backup_path.write_text(original, encoding="utf-8")

        path.write_text(updated, encoding="utf-8")
        if path.suffix.lower() == ".py":
            ok, detail = _test_python_file(path)
            if not ok:
                path.write_text(original, encoding="utf-8")
                return {
                    "status": "rolled_back",
                    "file": str(path),
                    "reason": f"validation failed: {detail[:180]}",
                    "risk": score["risk"],
                    "confidence": score["confidence"],
                    "transforms_applied": transforms_applied,
                    "backup_path": str(backup_path) if str(backup_path) else "",
                    "prechange_backup_path": str(prechange.get("backup_path", "")),
                    "prechange_git_pushed": bool(prechange.get("git_pushed", False)),
                    "prechange_git_error": str(prechange.get("git_error", "")),
                }

        return {
            "status": "kept",
            "file": str(path),
            "reason": "validation passed",
            "risk": score["risk"],
            "confidence": score["confidence"],
            "transforms_applied": transforms_applied,
            "backup_path": str(backup_path) if str(backup_path) else "",
            "prechange_backup_path": str(prechange.get("backup_path", "")),
            "prechange_git_pushed": bool(prechange.get("git_pushed", False)),
            "prechange_git_error": str(prechange.get("git_error", "")),
        }
    except Exception as exc:
        try:
            path.write_text(original, encoding="utf-8")
        except Exception:
            pass
        return {
            "status": "error",
            "file": str(path),
            "reason": str(exc)[:180],
            "risk": score["risk"],
            "confidence": score["confidence"],
            "transforms_applied": transforms_applied,
            "backup_path": str(backup_path) if str(backup_path) else "",
            "prechange_backup_path": str(prechange.get("backup_path", "")),
            "prechange_git_pushed": bool(prechange.get("git_pushed", False)),
            "prechange_git_error": str(prechange.get("git_error", "")),
        }

def _sync_training_status_from_swarm() -> dict:
    result = {"synced": False, "swarm_running": False, "summary_loaded": False}
    policy = load_workspace_policy()
    service_name = str(policy.get("trainer_swarm_service_name", "") or "codegen_nlp-trainer-cpu").strip() or "codegen_nlp-trainer-cpu"
    try:
        import shutil as _shutil
        if not _shutil.which("docker"):
            return result

        proc = subprocess.run(
            ["docker", "service", "ps", "--filter", "desired-state=running", "--format", "{{.CurrentState}}", service_name],
            capture_output=True,
            text=True,
            timeout=10,
            check=False,
        )
        swarm_running = bool(proc.returncode == 0 and "Running" in (proc.stdout or ""))
        result["swarm_running"] = swarm_running

        status = read_json(TRAINING_STATUS)
        if not isinstance(status, dict):
            status = {}
        processes = status.setdefault("processes", {})
        trainer_proc = processes.setdefault("nlp_trainer", {})
        trainer_proc["running"] = swarm_running
        trainer_proc["note"] = (
            f"running via {service_name} swarm service" if swarm_running else f"swarm service not running: {service_name}"
        )
        trainer_proc["last_verified_at"] = datetime.now(timezone.utc).isoformat()

        summary_path = Path("/mnt/dataset_storage/skynetv1/nlp_training_summary_cpu.json")
        if not summary_path.exists():
            summary_path = Path("/mnt/dataset_storage/skynetv1/nlp_training_summary.json")
        if summary_path.exists():
            try:
                summary = json.loads(summary_path.read_text(encoding="utf-8", errors="replace"))
                top = summary.get("result", {}) if isinstance(summary.get("result", {}), dict) else {}
                progress = status.setdefault("training_progress", {})
                if "loss" in top:
                    progress["loss"] = float(top["loss"])
                if "epochs_completed" in top:
                    progress["current_epoch"] = int(top["epochs_completed"])
                if "status" in top:
                    progress["status"] = str(top["status"])
                result["summary_loaded"] = True
            except Exception:
                pass

        write_json(TRAINING_STATUS, status)
        result["synced"] = True
    except Exception as exc:
        result["synced"] = False
        # Only assign string if result expects string, not bool
        if isinstance(result, dict):
            result["error"] = str(exc)[:180]
    return result

def learn_from_nlp_code():
    nlp_path = BASE_DIR / "nlp_code_trainer.py"
    if not nlp_path.exists():
        return
    try:
        content = nlp_path.read_text(encoding="utf-8")
    except Exception as exc:
        log_action(f"Failed reading nlp_code_trainer.py: {exc}")
        return
    if "except:" in content:
        queue_code_rewrite(
            reason="nlp_code_trainer.py contains bare except blocks",
            source="nlp_code_learning",
            severity="medium",
        )

def trigger_auto_apply_rewrites():
    global _last_rewrite_stall_alert_at
    policy = load_workspace_policy()
    if not policy.get("allow_auto_rewrite", False):
        return []

    registry = load_device_registry()
    enrolled = [d for d in registry.get("enrolled_devices", []) if d.get("status") == "active"]
    allow_without_devices = bool(policy.get("allow_auto_rewrite_without_enrolled_devices", True))
    if not enrolled and not allow_without_devices:
        return []

    results = []
    allowed_suffixes = {str(s).lower() for s in policy.get("allowed_file_types", [".py"]) if str(s).startswith(".")}
    excluded_suffixes = {str(s).lower() for s in policy.get("rewrite_excluded_suffixes", [".json"]) if str(s).startswith(".")}
    scan_all_non_json = bool(policy.get("rewrite_scan_all_non_json", True))
    max_files = int(policy.get("max_auto_rewrite_files_per_cycle", 50000))
    canary_size = max(1, int(policy.get("canary_batch_size", 8)))
    canary_max_failure_rate = float(policy.get("canary_max_failure_rate", 0.34))
    workspace_roots = [Path(p.replace("**", "").rstrip("/")).resolve() for p in policy.get("workspace_paths", [])]
    scanned_files = 0
    eligible_files = 0
    attempted_rewrites = 0
    candidate_generation_count = 0
    canary_attempts = 0
    canary_failures = 0
    canary_kept = []
    canary_tripped = False
    status_counts: dict[str, int] = {}

    for root in workspace_roots:
        if not root.exists():
            continue
        for path in root.glob("**/*"):
            if scanned_files >= max_files:
                break
            if not path.exists() or not path.is_file():
                continue
            suffix = path.suffix.lower()
            if scan_all_non_json:
                if suffix in excluded_suffixes:
                    continue
            else:
                if suffix not in allowed_suffixes:
                    continue
            if not path_allowed_for_rewrite(path, policy):
                continue
            if not _path_selected_for_rewrite(path, policy):
                continue
            try:
                max_size = _max_change_size_bytes_for_path(path, policy)
                if path.stat().st_size > max_size:
                    continue
                eligible_files += 1
                scanned_files += 1
                canary_mode = canary_attempts < canary_size
                result = apply_safe_rewrite_with_rollback(path, policy, canary_mode=canary_mode)
                status_key = str(result.get("status", "unknown"))
                status_counts[status_key] = int(status_counts.get(status_key, 0)) + 1
                if status_key != "no_change":
                    candidate_generation_count += 1
                if result.get("status") in {"kept", "rolled_back"}:
                    results.append(result)
                    attempted_rewrites += 1
                if canary_mode and result.get("status") in {"kept", "rolled_back"}:
                    canary_attempts += 1
                    if result.get("status") == "rolled_back":
                        canary_failures += 1
                    elif result.get("status") == "kept":
                        canary_kept.append(result)
                    if canary_attempts > 0 and (float(canary_failures) / float(canary_attempts)) > canary_max_failure_rate:
                        canary_tripped = True
                        for kept in canary_kept:
                            backup_path = kept.get("backup_path")
                            file_path = kept.get("file")
                            if not backup_path or not file_path:
                                continue
                            try:
                                p = Path(file_path)
                                b = Path(backup_path)
                                if b.exists():
                                    p.write_text(b.read_text(encoding="utf-8"), encoding="utf-8")
                                    b.unlink()
                                    results.append(
                                        {
                                            "status": "canary_rolled_back",
                                            "file": str(p),
                                            "reason": "canary failure rate exceeded threshold",
                                        }
                                    )
                            except Exception as exc:
                                log_action(f"Canary rollback failed for {file_path}: {exc}")
                        break
            except Exception as exc:
                log_action(f"Auto-rewrite scan skipped {path}: {exc}")
        if canary_tripped:
            break
        if scanned_files >= max_files:
            break

    if not canary_tripped:
        for kept in canary_kept:
            backup_path = kept.get("backup_path")
            if not backup_path:
                continue
            try:
                b = Path(backup_path)
                if b.exists():
                    b.unlink()
            except Exception:
                pass

    kept_count = sum(1 for item in results if item.get("status") == "kept")
    rolled_back_count = sum(1 for item in results if item.get("status") == "rolled_back")

    log_data = load_auto_rewrite_log()
    log_data["rewrites"].extend(
        {
            "file": item.get("file"),
            "status": item.get("status"),
            "reason": item.get("reason", ""),
            "at": datetime.now().isoformat(),
            "source": "auto_apply_runtime",
        }
        for item in results
    )
    log_data["last_rewrite_at"] = datetime.now().isoformat()
    log_data["last_test_run"] = {
        "ran_at": datetime.now().isoformat(),
        "scanned_files": scanned_files,
        "eligible_files": eligible_files,
        "results_count": len(results),
        "attempted_rewrites": attempted_rewrites,
        "candidate_generation_count": candidate_generation_count,
        "status_counts": status_counts,
        "kept": kept_count,
        "rolled_back": rolled_back_count,
        "allow_without_enrolled_devices": allow_without_devices,
        "active_enrolled_devices": len(enrolled),
        "canary_batch_size": canary_size,
        "canary_attempts": canary_attempts,
        "canary_failures": canary_failures,
        "canary_tripped": canary_tripped,
        "rewrite_min_confidence": float(policy.get("rewrite_min_confidence", 0.55)),
        "rewrite_max_risk": float(policy.get("rewrite_max_risk", 0.65)),
    }

    if scanned_files > 0 and candidate_generation_count == 0:
        now_ts = time.time()
        if now_ts - _last_rewrite_stall_alert_at >= 300:
            _last_rewrite_stall_alert_at = now_ts
            queue_code_rewrite(
                reason="rewrite scan found files but produced zero transform candidates",
                source="auto_rewrite_runtime",
                severity="medium",
            )
            log_action(
                "Auto-rewrite stall: scanned files with zero candidates. "
                "Querying web for additional fix strategies."
            )
            # Actively look up what kinds of improvements can be made
            try:
                web_result = lookup_web_context(
                    query="python code quality improvements safe refactoring patterns 2024",
                    policy=policy,
                )
                hints = str(web_result.get("summary", "") or web_result.get("content", ""))[:300]
                if hints:
                    queue_code_rewrite(
                        reason=f"Web-sourced improvement strategy: {hints[:200]}",
                        source="auto_rewrite_web_research",
                        severity="medium",
                    )
                    log_action(f"Web research queued new rewrite strategy ({len(hints)} chars).")
            except Exception as _web_stall_exc:
                log_action(f"Rewrite stall web lookup error (non-fatal): {_web_stall_exc!s:.120}")

            # Ask user only if web lookup yielded no actionable hint.
            if not any("web-sourced improvement strategy" in str(item.get("reason", "")) for item in load_rewrite_backlog()):
                queue_user_request(
                    message=(
                        "Rewrite engine scanned files but found no safe transform candidates. "
                        "I already attempted web research and no actionable fix pattern was found. "
                        "Do you want me to prioritize more aggressive transforms now?"
                    ),
                    source="auto_rewrite_runtime",
                    context={
                        "scanned_files": scanned_files,
                        "eligible_files": eligible_files,
                        "candidate_generation_count": candidate_generation_count,
                        "attempted_rewrites": attempted_rewrites,
                        "status_counts": status_counts,
                    },
                    request_type="approval",
                )

    save_auto_rewrite_log(log_data)
    return results

_last_autonomous_ui_work_at: float = 0.0
_last_ai_os_autowrite_at: float = 0.0
_workspace_review_snapshot_cache: dict[str, Any] = {
    "generated_at": 0.0,
    "cache_key": "",
    "selected_files": [],
    "workspace_analysis": {},
}

def _workspace_review_cache_key(policy: dict) -> str:
    return "|".join(
        [
            str(policy.get("code_improvement_target_files", 8)),
            str(policy.get("autonomous_ui_review_max_files", 12)),
            str(policy.get("rewrite_scan_full_workspace", True)),
            str(policy.get("workspace_paths", [])),
            str(policy.get("self_heal_focus_files", [])),
            str(policy.get("self_heal_focus_only", False)),
        ]
    )

def _chunk_text_for_typing(text: str, chunk_size: int = 32) -> list[str]:
    value = str(text or "")
    size = max(8, int(chunk_size or 32))
    return [value[i:i + size] for i in range(0, len(value), size)] or [""]

def _get_workspace_review_snapshot(policy: dict, force_refresh: bool = False) -> dict:
    """Return cached workspace targets and analysis to keep recurring cycles fast."""
    ttl_sec = max(30, int(policy.get("workspace_review_snapshot_ttl_sec", 180) or 180))
    now_ts = time.time()
    cache_key = _workspace_review_cache_key(policy)
    cached = dict(_workspace_review_snapshot_cache)
    if not force_refresh and cached.get("cache_key") == cache_key and (now_ts - float(cached.get("generated_at", 0.0) or 0.0)) < ttl_sec:
        return {
            "selected_files": list(cached.get("selected_files", [])),
            "workspace_analysis": dict(cached.get("workspace_analysis", {})),
            "cache_hit": True,
        }

    selected_files = _select_workspace_review_files(
        policy,
        max_count=max(1, int(policy.get("code_improvement_target_files", 8) or 8)),
    )
    focus_files = policy.get("self_heal_focus_files", [])
    if isinstance(focus_files, list):
        focus_paths = []
        for item in focus_files:
            candidate = str(item or "").strip()
            if not candidate:
                continue
            if candidate not in selected_files:
                selected_files.insert(0, candidate)
            focus_paths.append(candidate)
        if bool(policy.get("self_heal_focus_only", False)) and focus_paths:
            selected_files = focus_paths
    workspace_analysis = {}
    try:
        workspace_analysis = analyze_workspace_comprehensive(WORKSPACE_ROOT)
    except Exception as exc:
        workspace_analysis = {"status": "error", "reason": str(exc)[:200]}

    _workspace_review_snapshot_cache.update(
        {
            "generated_at": now_ts,
            "cache_key": cache_key,
            "selected_files": list(selected_files),
            "workspace_analysis": dict(workspace_analysis),
        }
    )
    return {
        "selected_files": selected_files,
        "workspace_analysis": workspace_analysis,
        "cache_hit": False,
    }

def _split_import_csv(text: str) -> list[str]:
    return [part.strip() for part in text.split(",") if part.strip()]

def _aggressive_python_refactor(original: str) -> tuple[str, list[str]]:
    """Perform stronger but still validation-guarded Python refactors line by line."""
    text = original
    changes: list[str] = []

    lines = text.splitlines(keepends=True)
    rewritten_lines: list[str] = []
    prev_blank = False
    for line in lines:
        newline = ""
        body = line
        if line.endswith("\r\n"):
            newline = "\r\n"
            body = line[:-2]
        elif line.endswith("\n"):
            newline = "\n"
            body = line[:-1]
        trimmed = body.rstrip(" \t")
        if trimmed != body:
            changes.append("aggressive_trim_trailing_ws")
        blank = not trimmed.strip()
        if blank and prev_blank:
            changes.append("aggressive_collapse_blank_lines")
            continue
        prev_blank = blank
        rewritten_lines.append(trimmed + newline)
    text = "".join(rewritten_lines)

    try:
        tree = ast.parse(text)
        used_names = {node.id for node in ast.walk(tree) if isinstance(node, ast.Name) and isinstance(node.ctx, ast.Load)}
        import_nodes: list[tuple[int, int, str]] = []
        for node in tree.body:
            if isinstance(node, (ast.Import, ast.ImportFrom)) and hasattr(node, "lineno"):
                start = int(getattr(node, "lineno", 0) or 0)
                end = int(getattr(node, "end_lineno", start) or start)
                if start > 0 and end == start:
                    import_nodes.append((start - 1, end - 1, type(node).__name__))
        if import_nodes:
            line_list = text.splitlines()
            for node in tree.body:
                if not isinstance(node, (ast.Import, ast.ImportFrom)) or not hasattr(node, "lineno"):
                    continue
                if int(getattr(node, "end_lineno", node.lineno) or node.lineno) != int(node.lineno):
                    continue
                idx = int(node.lineno) - 1
                if idx < 0 or idx >= len(line_list):
                    continue
                raw_line = line_list[idx]
                stripped = raw_line.strip()
                if stripped.startswith("import "):
                    comment = ""
                    if "#" in raw_line:
                        code_part, comment = raw_line.split("#", 1)
                        stripped = code_part.strip()
                        comment = "#" + comment
                    imported = stripped[len("import "):]
                    kept_parts = []
                    for part in _split_import_csv(imported):
                        alias = None
                        module = part
                        if " as " in part:
                            module, alias = [piece.strip() for piece in part.split(" as ", 1)]
                        symbol = (alias or module.split(".")[0]).strip()
                        if symbol in used_names or module.split(".")[0] in used_names:
                            kept_parts.append(part)
                    if kept_parts:
                        newline = "\n" if raw_line.endswith("\n") else ""
                        line_list[idx] = "import " + ", ".join(kept_parts) + ((" " + comment.strip()) if comment else "") + newline
                    else:
                        line_list[idx] = ""
                        changes.append("aggressive_prune_unused_import")
                elif stripped.startswith("from ") and " import " in stripped:
                    comment = ""
                    if "#" in raw_line:
                        code_part, comment = raw_line.split("#", 1)
                        stripped = code_part.strip()
                        comment = "#" + comment
                    module_part, names_part = stripped[5:].split(" import ", 1)
                    if names_part.strip() == "*":
                        continue
                    kept_parts = []
                    for part in _split_import_csv(names_part):
                        alias = None
                        name = part
                        if " as " in part:
                            name, alias = [piece.strip() for piece in part.split(" as ", 1)]
                        symbol = (alias or name).strip()
                        if symbol in used_names or name in used_names:
                            kept_parts.append(part)
                    if kept_parts:
                        newline = "\n" if raw_line.endswith("\n") else ""
                        line_list[idx] = f"from {module_part.strip()} import {', '.join(kept_parts)}" + ((" " + comment.strip()) if comment else "") + newline
                    else:
                        line_list[idx] = ""
                        changes.append("aggressive_prune_unused_import")
            text = "\n".join(line_list)
    except Exception:
        pass

    try:
        tree = ast.parse(text)
        docstring_nodes = sum(1 for node in ast.walk(tree) if isinstance(node, (ast.FunctionDef, ast.AsyncFunctionDef, ast.ClassDef)) and ast.get_docstring(node))
        if docstring_nodes:
            changes.append("aggressive_preserve_existing_docstrings")
    except Exception:
        pass

    return text, changes

def _apply_aggressive_python_rewrite(path: Path, policy: dict) -> dict[str, Any]:
    original = path.read_text(encoding="utf-8")
    updated, changes = _aggressive_python_refactor(original)
    if updated == original:
        return {"status": "noop", "file": str(path), "reason": "no aggressive transforms applied", "changes_count": 0}
    prechange = _create_prechange_backup_and_git_push(path, original, policy)
    try:
        path.write_text(updated, encoding="utf-8")
        py_compile.compile(str(path), doraise=True)
        return {
            "status": "improved",
            "file": str(path),
            "changes_count": len(changes),
            "transforms_applied": changes,
            "prechange_backup_path": str(prechange.get("backup_path", "")),
            "prechange_git_pushed": bool(prechange.get("git_pushed", False)),
            "prechange_git_error": str(prechange.get("git_error", "")),
        }
    except Exception as exc:
        try:
            path.write_text(original, encoding="utf-8")
        except Exception:
            pass
        return {
            "status": "rolled_back",
            "file": str(path),
            "reason": f"aggressive validation failed: {str(exc)[:180]}",
            "prechange_backup_path": str(prechange.get("backup_path", "")),
            "prechange_git_pushed": bool(prechange.get("git_pushed", False)),
            "prechange_git_error": str(prechange.get("git_error", "")),
        }

def _run_high_impact_self_heal_pass(policy: dict, minimum_improvements: int | None = None) -> dict:
    """Apply a focused rewrite pass to the most promising files when the main cycle underperforms."""
    target_minimum = max(1, int(minimum_improvements or policy.get("self_heal_min_improvements_per_cycle", 3) or 3))
    max_targets = max(target_minimum, int(policy.get("self_heal_max_targets_per_cycle", 12) or 12))
    if not bool(policy.get("self_heal_enable_high_impact_fallback", True)):
        return {"status": "disabled", "minimum_improvements": target_minimum}

    snapshot = _get_workspace_review_snapshot(policy, force_refresh=True)
    candidate_paths: list[Path] = []
    seen: set[str] = set()
    for rel in snapshot.get("selected_files", []):
        candidate = Path(rel)
        if not candidate.is_absolute():
            candidate = (WORKSPACE_ROOT / candidate).resolve()
        if not candidate.exists() or not candidate.is_file():
            continue
        if str(candidate) in seen:
            continue
        seen.add(str(candidate))
        candidate_paths.append(candidate)

    if not candidate_paths:
        return {"status": "no_targets", "minimum_improvements": target_minimum}

    scored_candidates: list[tuple[float, Path]] = []
    for candidate in candidate_paths:
        if not _is_high_value_workspace_candidate(candidate):
            continue
        score = _score_high_impact_edit_candidate(candidate)
        if candidate.suffix.lower() == ".py":
            score += 1.5
        scored_candidates.append((score, candidate))

    scored_candidates.sort(key=lambda item: (-item[0], len(str(item[1]))))
    focused_targets = [path for _score, path in scored_candidates[:max_targets]]
    if not focused_targets:
        return {"status": "no_targets", "minimum_improvements": target_minimum}

    results: list[dict[str, Any]] = []
    improved_files = 0
    total_improvements = 0
    bytes_saved = 0
    aggressive_enabled = bool(policy.get("self_heal_aggressive_mode_enabled", True))
    for target in focused_targets:
        try:
            result = apply_safe_rewrite_with_rollback(target, policy)
            if aggressive_enabled and target.suffix.lower() == ".py" and result.get("status") in {"noop", "skipped"}:
                aggressive_result = _apply_aggressive_python_rewrite(target, policy)
                if aggressive_result.get("status") == "improved":
                    result = aggressive_result
        except Exception as exc:
            result = {"status": "error", "file": str(target), "reason": str(exc)[:180]}
        results.append(result)
        if result.get("status") in {"improved", "kept"}:
            improved_files += 1
            total_improvements += int(result.get("changes_count", 0) or 0)
            bytes_saved += int(result.get("reduced_bytes", 0) or 0)
        if improved_files >= target_minimum:
            break

    return {
        "status": "ok" if improved_files >= target_minimum else "partial",
        "minimum_improvements": target_minimum,
        "targets": [str(path) for path in focused_targets],
        "results": results,
        "improved_files": improved_files,
        "total_improvements": total_improvements,
        "bytes_saved": bytes_saved,
        "workspace_cache_hit": bool(snapshot.get("cache_hit", False)),
    }

def _maybe_run_periodic_ui_work(policy: dict) -> dict:
    """Run a direct code-improvement cycle instead of driving blank UI windows."""
    global _last_autonomous_ui_work_at
    if not bool(policy.get("code_improvement_enabled", True)):
        return {"status": "disabled"}

    min_interval_sec = max(
        0.0,
        float(
            policy.get(
                "code_improvement_interval_sec",
                policy.get("autonomous_ui_interval_sec", 600),
            )
            or 600
        ),
    )
    now_ts = time.time()
    if min_interval_sec > 0 and (now_ts - _last_autonomous_ui_work_at) < min_interval_sec:
        return {"status": "throttled", "wait_sec": round(min_interval_sec - (now_ts - _last_autonomous_ui_work_at), 2)}

    snapshot = _get_workspace_review_snapshot(policy)
    selected_files = list(snapshot.get("selected_files", []))
    if not selected_files:
        return {"status": "no_targets"}
    workspace_analysis = dict(snapshot.get("workspace_analysis", {}))

    workspace_root = WORKSPACE_ROOT.resolve()
    priority_files = [
        WORKSPACE_ROOT / "create" / "skynetv2_agent.py",
        WORKSPACE_ROOT / "create" / "autonomous_code_improver.py",
    ]
    focus_files = policy.get("self_heal_focus_files", [])
    if isinstance(focus_files, list):
        for focus_file in reversed(focus_files):
            candidate = Path(str(focus_file or "").strip())
            if not candidate.is_absolute():
                candidate = (workspace_root / candidate).resolve()
            if candidate.exists() and candidate.is_file():
                rel_focus = str(candidate.relative_to(workspace_root)).replace("\\", "/")
                if rel_focus not in selected_files:
                    selected_files.insert(0, rel_focus)
    if bool(policy.get("self_heal_focus_only", False)):
        selected_files = [
            str(Path(str(item)).resolve().relative_to(workspace_root)).replace("\\", "/")
            for item in selected_files
            if str(item).strip()
        ][: max(1, int(policy.get("code_improvement_target_files", 8) or 8))]
    for priority in reversed(priority_files):
        if priority.exists():
            rel_priority = str(priority.resolve().relative_to(workspace_root)).replace("\\", "/")
            if rel_priority not in selected_files:
                selected_files.insert(0, rel_priority)

    normalized_targets: list[Path] = []
    current_file = Path(__file__).resolve()
    if current_file.exists():
        normalized_targets.append(current_file)

    for rel_path in selected_files:
        candidate = Path(rel_path)
        if not candidate.is_absolute():
            candidate = (workspace_root / candidate).resolve()
        if candidate not in normalized_targets:
            normalized_targets.append(candidate)

    ui_review = {"status": "disabled"}
    if bool(policy.get("local_input_control_enabled", True)) and _is_desktop_session_available():
        ui_review_policy = dict(policy)
        ui_review_policy["local_input_require_target_window"] = True
        launch_result = _launch_or_focus_vscode_workspace(ui_review_policy)
        visible_actions = [
            {"type": "activate_window", "name": str(policy.get("local_input_target_window_name", "Visual Studio Code") or "Visual Studio Code")},
            {"type": "move", "x": 220, "y": 180},
            {"type": "click", "button": "left"},
            {"type": "sleep", "seconds": 0.25},
        ]
        visible_actions.extend(
            _build_vscode_file_review_actions(
                selected_files[: min(10, len(selected_files))],
                search_term="def ",
                repeat_passes=max(2, int(policy.get("code_improvement_visible_passes", 3) or 3)),
            )
        )
        try:
            ui_review = _execute_local_ui_actions(visible_actions, ui_review_policy)
            ui_review["launch"] = launch_result
            ui_review["action_plan"] = visible_actions
        except Exception as exc:
            ui_review = {"status": "error", "reason": str(exc)[:180], "launch": launch_result}

    shell_checks = []
    if not sys.stdin.isatty():
        shell_checks.append(_run_bash_command("git status --short", cwd=WORKSPACE_ROOT, timeout_sec=15))
        shell_checks.append(_run_bash_command(f"{shlex.quote(sys.executable)} -m py_compile create/skynetv2_agent.py", cwd=WORKSPACE_ROOT, timeout_sec=30))

    web_guidance = {}
    if bool(policy.get("allow_web_lookup", True)) and bool(policy.get("code_improvement_web_queries_enabled", True)):
        try:
            web_guidance = lookup_web_context(
                "python safe refactoring patterns direct file edits whitespace import hygiene",
                policy,
            )
        except Exception as exc:
            web_guidance = {"status": "error", "error": str(exc)[:200]}

    synthesis = run_algorithmic_synthesis(
        problem="direct workspace code improvement",
        language="python",
        goal="safe refactor and condense logic",
    )

    file_results: list[dict[str, Any]] = []
    for target in normalized_targets[: max(1, len(selected_files))]:
        if not target.exists() or not target.is_file():
            continue

        if target.suffix.lower() == ".py":
            try:
                result = improve_python_file_with_web_guidance(target, web_guidance)
            except Exception as exc:
                result = {"status": "error", "file": str(target), "reason": str(exc)[:180]}
        else:
            result = apply_safe_rewrite_with_rollback(target, policy)

        if result.get("status") == "noop":
            if target.suffix.lower() == ".py":
                result = apply_safe_rewrite_with_rollback(target, policy)
        file_results.append(result)

    improved_files = sum(1 for item in file_results if item.get("status") in {"improved", "kept"})
    total_improvements = sum(int(item.get("changes_count", 0) or 0) for item in file_results)
    bytes_saved = sum(int(item.get("reduced_bytes", 0) or 0) for item in file_results)
    self_heal_result = {"status": "skipped", "reason": "threshold met or fallback disabled"}
    minimum_improvements = max(1, int(policy.get("self_heal_min_improvements_per_cycle", 3) or 3))
    if bool(policy.get("self_heal_enable_high_impact_fallback", True)) and improved_files < minimum_improvements:
        needed_more = max(1, minimum_improvements - improved_files)
        try:
            self_heal_result = _run_high_impact_self_heal_pass(policy, minimum_improvements=needed_more)
            file_results.extend(self_heal_result.get("results", []))
            improved_files += int(self_heal_result.get("improved_files", 0) or 0)
            total_improvements += int(self_heal_result.get("total_improvements", 0) or 0)
            bytes_saved += int(self_heal_result.get("bytes_saved", 0) or 0)
        except Exception as exc:
            self_heal_result = {"status": "error", "reason": str(exc)[:180]}

    status = "ok" if improved_files >= minimum_improvements else ("partial" if file_results else "noop")

    if not isinstance(web_guidance, dict):
        # If web_guidance is a string or other type, wrap it in a dict for safe access
        web_guidance_dict = {"raw": str(web_guidance)}
    else:
        web_guidance_dict = web_guidance

    result = {
        "status": status,
        "mode": "visible_ui_review_and_code_improvement",
        "targets": [str(path) for path in normalized_targets[: max(1, len(selected_files))]],
        "selected_files": selected_files,
        "snapshot_cache_hit": bool(snapshot.get("cache_hit", False)),
        "ui_review": ui_review,
        "self_heal": self_heal_result,
        "action_log": ui_review.get("steps", []),
        "shell_checks": shell_checks,
        "web_guidance": {
            "query": web_guidance_dict.get("query", ""),
            "source_count": len(web_guidance_dict.get("sources", [])) if isinstance(web_guidance_dict.get("sources", []), list) else 0,
            # Defensive: Only call .get if google_ai is a dict
            "google_ai_status": web_guidance_dict["google_ai"].get("status", "") if isinstance(web_guidance_dict.get("google_ai", {}), dict) else "",
            "raw": web_guidance_dict.get("raw", None),
        },
        "synthesis": synthesis,
        "workspace_analysis": workspace_analysis,
        "file_results": file_results,
        "code_improvements": {
            "improved_files": improved_files,
            "total_improvements": total_improvements,
            "bytes_saved": bytes_saved,
        },
    }

    _last_autonomous_ui_work_at = now_ts

    try:
        out_dir = Path(str(policy.get("autonomous_ui_output_dir", BASE_DIR / "autonomous_generated" / "ui_cycle_reports"))).expanduser()
        out_dir.mkdir(parents=True, exist_ok=True)
        marker_path = out_dir / "ui_cycle_last_run.json"
        write_json(
            marker_path,
            {
                "at": datetime.now().isoformat(),
                "mode": result.get("mode"),
                "status": result.get("status"),
                "targets": result.get("targets", []),
                "selected_files": result.get("selected_files", []),
                "snapshot_cache_hit": bool(result.get("snapshot_cache_hit", False)),
                "ui_review": result.get("ui_review", {}),
                "action_log": result.get("action_log", []),
                "self_heal": result.get("self_heal", {}),
                "improved_files": improved_files,
                "total_improvements": total_improvements,
                "bytes_saved": bytes_saved,
                "shell_checks": shell_checks,
                "web_guidance": result.get("web_guidance", {}),
                "synthesis": result.get("synthesis", {}),
                "workspace_analysis": result.get("workspace_analysis", {}),
            },
        )
    except Exception as exc:
        log_action(f"Direct code improvement marker write failed: {str(exc)[:180]}")

    log_action(
        "Visible UI and code improvement cycle executed: "
        f"status={result.get('status')} targets={len(result.get('targets', []))} "
        f"improved_files={improved_files} improvements={total_improvements} bytes_saved={bytes_saved}"
    )
    return result

def _maybe_autowrite_ai_os_scaffold(policy: dict) -> dict:
    """Continuously evolve a local AI-OS scaffold from current runtime state."""
    global _last_ai_os_autowrite_at
    if not bool(policy.get("ai_os_autowrite_enabled", True)):
        return {"status": "disabled"}

    now_ts = time.time()
    interval_sec = max(15, int(policy.get("ai_os_autowrite_interval_sec", 120) or 120))
    if now_ts - _last_ai_os_autowrite_at < interval_sec:
        return {"status": "throttled"}

    export_external = bool(policy.get("ai_os_autowrite_external_file_enabled", False))
    output_dir = Path(str(policy.get("ai_os_autowrite_output_dir", BASE_DIR / "autonomous_generated" / "ai_os"))).expanduser()
    module_name = str(policy.get("ai_os_autowrite_module_name", "ai_os_kernel_autogen.py")).strip() or "ai_os_kernel_autogen.py"
    output_path = output_dir / module_name

    backlog = load_rewrite_backlog()
    queued = sum(1 for item in backlog if item.get("status") in {"queued", "analyzing", "validated"})
    issues = [str(item.get("reason", "")).strip() for item in backlog[:8] if str(item.get("reason", "")).strip()]

    module_lines = [
        '"""Autonomous AI-OS scaffold generated by skynetv2 daemon.\n',
        "This file is intentionally rewritten over time as the daemon learns.\n",
        '"""',
        "",
        "from dataclasses import dataclass, field",
        "from datetime import datetime",
        "from typing import Any",
        "",
        "",
        "@dataclass",
        "class AIOSKnowledgeState:",
        "    generated_at: str = field(default_factory=lambda: datetime.now(timezone.utc).isoformat())",
        f"    pending_rewrites: int = {queued}",
        "    active_goals: list[str] = field(default_factory=lambda: [",
        "        'learn continuously',",
        "        'scan workspace for failures',",
        "        'propose and apply safe fixes',",
        "        'evolve AI-OS kernel modules',",
        "    ])",
        "",
        "",
        "class AIOSKernelAutogen:",
        "    def __init__(self):",
        "        self.state = AIOSKnowledgeState()",
        "",
        "    def planner_tick(self) -> dict[str, Any]:",
        "        return {",
        "            'status': 'ok',",
        "            'generated_at': self.state.generated_at,",
        "            'pending_rewrites': self.state.pending_rewrites,",
        "            'next_steps': [",
        "                'mine runtime logs and stack traces',",
        "                'synthesize targeted patch candidates',",
        "                'validate patches with compile/test probes',",
        "            ],",
        "        }",
        "",
        "    def issue_hints(self) -> list[str]:",
        "        hints = []",
    ]

    for issue in issues:
        safe_issue = issue.replace("\\", "\\\\").replace("\"", "\\\"")
        module_lines.append(f'        hints.append("{safe_issue[:180]}")')

    module_lines.extend(
        [
            "        return hints",
            "",
            "",
            "if __name__ == '__main__':",
            "    kernel = AIOSKernelAutogen()",
            "    print(kernel.planner_tick())",
            "    print({'issue_hints': kernel.issue_hints()})",
            "",
        ]
    )

    module_text = "\n".join(module_lines)
    memory_payload = load_agent_memory()
    if not isinstance(memory_payload, dict):
        memory_payload = {}
    memory_payload["ai_os_inprocess_scaffold"] = {
        "generated_at": datetime.now().isoformat(),
        "pending_rewrites": queued,
        "issues": issues,
        "module_text": module_text,
    }
    save_agent_memory(memory_payload)

    if export_external:
        try:
            output_dir.mkdir(parents=True, exist_ok=True)
            previous_text = ""
            if output_path.exists():
                previous_text = output_path.read_text(encoding="utf-8", errors="ignore")

            # Keep growing the AI-OS module by appending a new evolution step every run.
            run_tag = datetime.now(timezone.utc).strftime("%Y%m%d_%H%M%S")
            growth_lines = [
                "",
                f"def evolution_step_{run_tag}() -> dict[str, Any]:",
                "    return {",
                f"        'run_tag': '{run_tag}',",
                f"        'generated_at': '{datetime.now(timezone.utc).isoformat()}',",
                f"        'pending_rewrites': {queued},",
                "        'focus': [",
                "            'expand ai-os kernel behavior',",
                "            'preserve previous evolution steps',",
                "            'compile-check generated module each cycle',",
                "        ],",
                "    }",
                "",
            ]

            if previous_text.strip():
                next_text = previous_text.rstrip() + "\n" + "\n".join(growth_lines)
            else:
                next_text = module_text.rstrip() + "\n" + "\n".join(growth_lines)

            output_path.write_text(next_text, encoding="utf-8")
            py_compile.compile(str(output_path), doraise=True)
            _last_ai_os_autowrite_at = now_ts
            log_action(f"AI-OS scaffold evolved (in-process + file): {output_path}")
            return {
                "status": "updated",
                "path": str(output_path),
                "pending_rewrites": queued,
                "storage": "memory+file",
                "growth_appended": True,
            }
        except Exception as exc:
            log_action(f"AI-OS scaffold file export failed (memory update kept): {exc}")
            return {"status": "partial", "reason": str(exc)[:200], "pending_rewrites": queued, "storage": "memory"}

    _last_ai_os_autowrite_at = now_ts
    log_action("AI-OS scaffold updated in skynetv2 memory state.")
    return {"status": "updated", "pending_rewrites": queued, "storage": "memory"}

def _maybe_verify_workspace_runtime(policy: dict) -> dict:
    """Continuously verify workspace Python files compile and queue targeted fixes."""
    global _last_workspace_runtime_check_at
    if not bool(policy.get("workspace_runtime_checks_enabled", True)):
        return {"status": "disabled"}

    now_ts = time.time()
    interval_sec = max(30, int(policy.get("workspace_runtime_checks_interval_sec", 180) or 180))
    if now_ts - _last_workspace_runtime_check_at < interval_sec:
        return {"status": "throttled"}

    max_files = max(50, int(policy.get("workspace_runtime_checks_max_files", 2000) or 2000))
    checked = 0
    failures = []

    for root in _workspace_root_paths(policy):
        if not root.exists() or not root.is_dir():
            continue
        for path in root.glob("**/*.py"):
            if checked >= max_files:
                break
            if not path.is_file() or not path_allowed_for_rewrite(path, policy):
                continue
            checked += 1
            try:
                py_compile.compile(str(path), doraise=True)
            except Exception as exc:
                failures.append((path, str(exc)[:220]))
        if checked >= max_files:
            break

    _last_workspace_runtime_check_at = now_ts

    if failures:
        for path, err in failures[:30]:
            queue_code_rewrite(
                reason=f"python compile failure in {path}: {err}",
                source="workspace_runtime_checks",
                severity="high",
            )
        log_action(f"Workspace runtime check found {len(failures)} compile issue(s) across {checked} file(s).")
        return {"status": "issues", "checked": checked, "failures": len(failures)}

    log_action(f"Workspace runtime check passed for {checked} Python file(s).")
    return {"status": "ok", "checked": checked, "failures": 0}

def start_autonomous_ui_worker():
    global _ui_worker_started
    if _ui_worker_started:
        return
    policy = load_workspace_policy()
    if not bool(policy.get("autonomous_ui_worker_enabled", False)):
        log_action("Autonomous UI worker disabled by policy; direct code improvement path remains available.")
        return

    def _worker_loop():
        while True:
            sleep_sec = 2.0
            try:
                policy = load_workspace_policy()
                sleep_sec = max(0.5, float(policy.get("autonomous_ui_worker_interval_sec", 2) or 2))
                if bool(policy.get("autonomous_ui_worker_enabled", False)):
                    _maybe_run_periodic_ui_work(policy)
            except Exception as exc:
                log_action(f"Autonomous UI worker error (non-fatal): {str(exc)[:180]}")
            time.sleep(sleep_sec)

    thread = threading.Thread(target=_worker_loop, name="skynetv2-ui-worker", daemon=True)
    thread.start()
    _ui_worker_started = True
    log_action("Autonomous UI worker thread started.")

def propose_and_apply_improvements():
    policy = load_workspace_policy()
    ingest_v1_outputs_one_way(policy)
    run_controlled_algorithmic_synthesis(policy)

    status = read_json(TRAINING_STATUS)
    if status:
        dataset_progress = status.get("dataset_progress", {})
        if float(dataset_progress.get("download_rate_mbps", 20) or 0) < 1:
            log_action("Download rate low. Attempting to restart dataset puller.")
            queue_code_rewrite(
                reason="dataset download rate dropped below 1 Mbps",
                source="training_monitor",
                severity="medium",
            )
            maybe_restart_training("dataset download rate below threshold")

    learn_from_nlp_code()

def heartbeat():
    def mutate(state):
        state["last_heartbeat_at"] = datetime.now(SITE_TIMEZONE).isoformat()

    update_registry_state(mutate)

@dataclass
class AIOSKernel:
    name: str = "ai_os_kernel_v1"
    booted_at: str = ""
    cycle_count: int = 0
    last_cycle_at: str = ""
    last_cycle_duration_ms: float = 0.0
    last_cycle_status: str = "booting"
    dispatch_table: dict[str, Any] = field(default_factory=dict)
    command_history: list[dict] = field(default_factory=list)

    def __post_init__(self):
        self.dispatch_table = {
            "status": self._cmd_status,
            "rewrite_now": self._cmd_rewrite_now,
            "discover_devices": self._cmd_discover_devices,
            "scan_network": self._cmd_scan_network,
            "prepare_deployment": self._cmd_prepare_deployment,
            "observe_screen": self._cmd_observe_screen,
            "learn_screen": self._cmd_learn_screen,
            "evolve_website": self._cmd_evolve_website,
            "ref": self._cmd_ref,
            "ask_user": self._cmd_ask_user,
            "user_reply": self._cmd_user_reply,
            "queue_rewrite": self._cmd_queue_rewrite,
            "chat": self._cmd_chat,
            "comprehensive_scan": self._cmd_comprehensive_scan,
            "show_traffic": self._cmd_show_traffic,
            "show_devices": self._cmd_show_devices,
            "scan_all_ports": self._cmd_scan_all_ports,
            "show_network": self._cmd_show_network,
            "ui_action": self._cmd_ui_action,
            "ui_script": self._cmd_ui_script,
            "ui_demo": self._cmd_ui_demo,
        }

    def _publish_state(self):
        state_payload = {
            "name": self.name,
            "booted_at": self.booted_at,
            "cycle_count": int(self.cycle_count),
            "last_cycle_at": self.last_cycle_at,
            "last_cycle_duration_ms": round(float(self.last_cycle_duration_ms), 2),
            "last_cycle_status": self.last_cycle_status,
            "command_bus": {
                "enabled": True,
                "available_commands": sorted(self.dispatch_table.keys()),
                "history_size": len(self.command_history),
                "last_command": self.command_history[-1] if self.command_history else {},
            },
        }

        def mutate(state):
            state["ai_os_kernel"] = state_payload

        update_registry_state(mutate)

    def boot(self):
        if not self.booted_at:
            self.booted_at = datetime.now(SITE_TIMEZONE).isoformat()
        self.last_cycle_status = "running"
        self._publish_state()
        log_action(f"AI OS kernel layer online: {self.name}")

    def _record_command(self, entry: dict, result: dict):
        record = {
            "at": datetime.now().isoformat(),
            "id": str(entry.get("id", "")).strip(),
            "source": str(entry.get("source", "")).strip() or "unknown",
            "text": str(entry.get("text", "")).strip(),
            "result": result if isinstance(result, dict) else {"status": "unknown"},
        }
        self.command_history.append(record)
        self.command_history = self.command_history[-200:]

    def _split_command(self, raw_text: str) -> tuple[str, list[str]]:
        text = normalize_kernel_command_text(raw_text)
        if not text:
            return "", []
        try:
            tokens = shlex.split(text)
        except Exception:
            tokens = [part for part in str(text).split(" ") if part]
        if not tokens:
            return "", []
        command = tokens[0].strip().lower()
        args = tokens[1:]
        return command, args

    def _cmd_status(self, args: list[str], entry: dict) -> dict:
        state = load_user_dialog_state()
        queue = state.get("queue", []) if isinstance(state.get("queue", []), list) else []
        active = state.get("active_request", {}) if isinstance(state.get("active_request", {}), dict) else {}
        return {
            "status": "ok",
            "kernel": {
                "cycle_count": self.cycle_count,
                "last_cycle_status": self.last_cycle_status,
            },
            "user_dialog": {
                "queued": len(queue),
                "active_request_id": active.get("id", "") if active else "",
            },
        }

    def _cmd_rewrite_now(self, args: list[str], entry: dict) -> dict:
        results = trigger_auto_apply_rewrites()
        return {"status": "ok", "rewrites_checked": len(results)}

    def _cmd_discover_devices(self, args: list[str], entry: dict) -> dict:
        discovered = discover_devices()
        return {"status": "ok", "discovered_candidates": len(discovered)}

    def _cmd_scan_network(self, args: list[str], entry: dict) -> dict:
        result = run_network_port_scan_and_email_report(load_network_scan_policy())
        return {
            "status": "ok",
            "networks": int(result.get("total_networks", 0) or 0),
            "hosts_scanned": int(result.get("hosts_scanned_total", 0) or 0),
        }

    def _cmd_prepare_deployment(self, args: list[str], entry: dict) -> dict:
        policy = load_workspace_policy()
        bundles = prepare_install_bundle_for_approved_devices(policy)
        return {
            "status": "ok",
            "bundles_prepared": int(bundles.get("bundles_prepared", 0) or 0),
            "approved_devices_count": int(bundles.get("approved_devices_count", 0) or 0),
        }

    def _cmd_observe_screen(self, args: list[str], entry: dict) -> dict:
        policy = load_workspace_policy()
        result = run_autonomous_screen_learning_cycle(policy, force=True)
        return {"status": "ok", "screen_learning": result}

    def _cmd_learn_screen(self, args: list[str], entry: dict) -> dict:
        policy = load_workspace_policy()
        result = run_autonomous_screen_learning_cycle(policy, force=True)
        return {"status": "ok", "screen_learning": result}

    def _cmd_evolve_website(self, args: list[str], entry: dict) -> dict:
        policy = load_workspace_policy().copy()
        policy["screen_learning_mutation_enabled"] = True
        result = run_autonomous_screen_learning_cycle(policy, force=True)
        return {"status": "ok", "screen_learning": result}

    def _cmd_ref(self, args: list[str], entry: dict) -> dict:
        instruction = " ".join(args).strip()
        if not instruction:
            raw_text = str(entry.get("text", "")).strip()
            if raw_text.lower().startswith("ref "):
                instruction = raw_text[4:].strip()
        if not instruction:
            return {"status": "error", "reason": "missing ref instruction"}

        policy = load_workspace_policy()
        direct = _apply_ref_instruction_to_file(
            instruction=instruction,
            policy=policy,
            source=f"kernel_ref:{entry.get('source', 'bus')}",
        )
        if direct.get("status") in {"created", "updated", "appended"}:
            return {
                "status": "ok",
                "instruction": instruction,
                "direct_apply": direct,
            }

        queued = queue_code_rewrite(
            reason=f"Kernel ref command requested code changes: {instruction}",
            source=f"kernel_ref:{entry.get('source', 'bus')}",
            severity="high",
        )
        run_staged_self_rewrite_executor()
        rewrite_results = trigger_auto_apply_rewrites()
        return {
            "status": "ok",
            "instruction": instruction,
            "direct_apply": direct,
            "queued": queued,
            "rewrites_checked": len(rewrite_results),
        }

    def _cmd_ask_user(self, args: list[str], entry: dict) -> dict:
        message = " ".join(args).strip() or str(entry.get("text", "")).strip()
        if not message:
            return {"status": "error", "reason": "missing message"}
        result = queue_user_request(message=message, source=f"kernel:{entry.get('source','bus')}", request_type="kernel")
        return {"status": "ok", "queued": result.get("status") in {"queued", "already_queued", "already_active"}, "result": result}

    def _cmd_user_reply(self, args: list[str], entry: dict) -> dict:
        reply = " ".join(args).strip()
        if not reply:
            return {"status": "error", "reason": "missing reply text"}
        result = submit_user_reply(reply)
        return {"status": "ok", "result": result}

    def _cmd_queue_rewrite(self, args: list[str], entry: dict) -> dict:
        reason = " ".join(args).strip()
        if not reason:
            return {"status": "error", "reason": "missing rewrite reason"}
        queued = queue_code_rewrite(reason=reason, source=f"kernel_command:{entry.get('source','bus')}", severity="medium")
        return {"status": "ok", "result": queued}

    def _cmd_chat(self, args: list[str], entry: dict) -> dict:
        text = " ".join(args).strip() or str(entry.get("text", "")).strip()
        if not text:
            return {"status": "error", "reason": "empty chat text"}
        command_line = normalize_kernel_command_text(text)
        if command_line != text:
            nested = {"id": entry.get("id", ""), "source": f"{entry.get('source','chat')}:nl", "text": command_line}
            return self._dispatch_command(nested)
        queued = queue_user_request(
            message=text,
            source=f"kernel_chat:{entry.get('source','voice')}",
            context={"via_kernel_command_bus": True},
            request_type="voice_chat",
        )
        return {"status": "ok", "result": queued}

    def _cmd_comprehensive_scan(self, args: list[str], entry: dict) -> dict:
        """Run comprehensive network scan with all ports and traffic tracing."""
        port_mode = " ".join(args).strip() if args else "quick"
        policy = load_network_scan_policy()
        result = _comprehensive_network_scan_with_traffic(policy, port_mode=port_mode)
        return {"status": "ok", "scan": result}

    def _cmd_show_traffic(self, args: list[str], entry: dict) -> dict:
        """Show active inbound/outbound IP connections."""
        connections = _capture_active_connections()
        return {"status": "ok", "connections": connections}

    def _cmd_show_devices(self, args: list[str], entry: dict) -> dict:
        """Show discovered and enrolled devices."""
        devices = _get_discovered_devices()
        return {"status": "ok", "devices": devices}

    def _cmd_scan_all_ports(self, args: list[str], entry: dict) -> dict:
        """Scan all 65535 ports on a given IP."""
        if not args:
            return {"status": "error", "reason": "IP address required"}
        target_ip = args[0]
        timeout_sec = float(args[1]) if len(args) > 1 else 0.1
        try:
            open_ports = _scan_port_range(target_ip, "all", timeout_sec, max_results=1000)
            return {
                "status": "ok",
                "target_ip": target_ip,
                "open_ports_found": len(open_ports),
                "open_ports": sorted(open_ports),
            }
        except Exception as exc:
            return {"status": "error", "reason": str(exc)[:200]}

    def _cmd_show_network(self, args: list[str], entry: dict) -> dict:
        """Show current network status (traffic + devices)."""
        result = {
            "timestamp": datetime.now().isoformat(),
            "active_connections": _capture_active_connections(),
            "discovered_devices": _get_discovered_devices(),
        }
        return {"status": "ok", "network": result}

    def _cmd_ui_action(self, args: list[str], entry: dict) -> dict:
        policy = load_workspace_policy()
        actions = _parse_ui_action_from_args(args)
        if not actions:
            return {
                "status": "error",
                "reason": "missing or invalid ui action",
                "usage": "ui_action <move x y|click [left|middle|right]|dblclick [left|middle|right]|key <spec>|type <text>|sleep <seconds>>",
            }
        result = _execute_local_ui_actions(actions, policy)
        return {"status": "ok" if result.get("status") in {"ok", "partial"} else "error", "ui": result}

    def _cmd_ui_script(self, args: list[str], entry: dict) -> dict:
        policy = load_workspace_policy()
        actions = []
        metadata = entry.get("metadata", {}) if isinstance(entry.get("metadata", {}), dict) else {}
        if isinstance(metadata.get("actions", []), list):
            actions = metadata.get("actions", [])
        elif args:
            raw = " ".join(args).strip()
            try:
                parsed = json.loads(raw)
                if isinstance(parsed, list):
                    actions = parsed
                elif isinstance(parsed, dict):
                    actions = [parsed]
            except Exception:
                actions = []

        if not actions:
            return {
                "status": "error",
                "reason": "ui_script requires metadata.actions list or JSON action list",
            }

        result = _execute_local_ui_actions(actions, policy)
        return {"status": "ok" if result.get("status") in {"ok", "partial"} else "error", "ui": result}

    def _cmd_ui_demo(self, args: list[str], entry: dict) -> dict:
        policy = load_workspace_policy()
        demo_text = "skynetv2 ui takeover demo"
        if args:
            demo_text = " ".join(args).strip() or demo_text
        actions = [
            {"type": "move", "x": 200, "y": 200},
            {"type": "sleep", "seconds": 0.5},
            {"type": "click", "button": "left"},
            {"type": "sleep", "seconds": 0.3},
            {"type": "type", "text": demo_text, "delay_ms": 20},
            {"type": "key", "key": "Return"},
        ]
        result = _execute_local_ui_actions(actions, policy)
        return {"status": "ok" if result.get("status") in {"ok", "partial"} else "error", "ui": result}

    def _dispatch_command(self, entry: dict) -> dict:
        text = str(entry.get("text", "")).strip()
        command, args = self._split_command(text)
        if not command:
            return {"status": "ignored", "reason": "empty command"}
        if command not in self.dispatch_table:
            if entry.get("source") == "voice":
                return self._cmd_chat([text], entry)
            return {"status": "unknown_command", "command": command}
        try:
            return self.dispatch_table[command](args, entry)
        except Exception as exc:
            return {"status": "error", "command": command, "reason": str(exc)[:200]}

    def _pull_commands_from_sources(self, policy: dict) -> list[dict]:
        pending: list[dict] = []

        queue = load_kernel_command_queue()
        queue_changed = False
        max_per_cycle = max(1, int(policy.get("kernel_command_max_per_cycle", 8)))
        for item in queue:
            if len(pending) >= max_per_cycle:
                break
            if item.get("status") != "queued":
                continue
            item["status"] = "processing"
            item["picked_at"] = datetime.now().isoformat()
            pending.append(item)
            queue_changed = True
        if queue_changed:
            save_kernel_command_queue(queue)

        if bool(policy.get("kernel_cli_input_enabled", True)) and len(pending) < max_per_cycle:
            cli_file = Path(str(policy.get("kernel_cli_input_file", KERNEL_CLI_INPUT_FILE))).expanduser()
            for line in _consume_lines_from_input_file(cli_file, max_lines=max_per_cycle - len(pending)):
                pending.append(
                    {
                        "id": hashlib.sha256(f"cli|{time.time()}|{line}".encode("utf-8")).hexdigest()[:16],
                        "source": "cli",
                        "text": line,
                    }
                )
                if len(pending) >= max_per_cycle:
                    break

        if bool(policy.get("kernel_voice_input_enabled", True)) and len(pending) < max_per_cycle:
            voice_file = Path(str(policy.get("kernel_voice_input_file", KERNEL_VOICE_INPUT_FILE))).expanduser()
            for line in _consume_lines_from_input_file(voice_file, max_lines=max_per_cycle - len(pending)):
                pending.append(
                    {
                        "id": hashlib.sha256(f"voice|{time.time()}|{line}".encode("utf-8")).hexdigest()[:16],
                        "source": "voice",
                        "text": line if bool(policy.get("kernel_voice_auto_execute", True)) else f"chat {line}",
                    }
                )
                if len(pending) >= max_per_cycle:
                    break

        if bool(policy.get("kernel_voice_audio_inbox_enabled", True)) and len(pending) < max_per_cycle:
            inbox_dir = Path(str(policy.get("kernel_voice_audio_inbox_dir", BASE_DIR / "voice_inbox"))).expanduser()
            allowed_exts = {
                str(ext).lower().strip()
                for ext in policy.get("kernel_voice_audio_extensions", [".wav", ".mp3", ".m4a", ".ogg", ".flac"])
                if str(ext).strip().startswith(".")
            }
            if inbox_dir.exists() and inbox_dir.is_dir():
                for audio_file in sorted(inbox_dir.iterdir()):
                    if len(pending) >= max_per_cycle:
                        break
                    if not audio_file.is_file() or audio_file.suffix.lower() not in allowed_exts:
                        continue
                    transcript = transcribe_voice_audio_file(audio_file, policy)
                    processed_name = audio_file.with_suffix(audio_file.suffix + ".processed")
                    if transcript:
                        pending.append(
                            {
                                "id": hashlib.sha256(f"voice_audio|{time.time()}|{audio_file}".encode("utf-8")).hexdigest()[:16],
                                "source": "voice",
                                "text": transcript if bool(policy.get("kernel_voice_auto_execute", True)) else f"chat {transcript}",
                                "metadata": {"audio_file": str(audio_file)},
                            }
                        )
                    try:
                        audio_file.rename(processed_name)
                    except Exception:
                        pass

        return pending

    def _finalize_queue_entry(self, entry_id: str, result: dict):
        if not entry_id:
            return
        queue = load_kernel_command_queue()
        changed = False
        for item in queue:
            if str(item.get("id", "")).strip() != entry_id:
                continue
            item["status"] = "done"
            item["completed_at"] = datetime.now().isoformat()
            item["result"] = result if isinstance(result, dict) else {"status": "unknown"}
            changed = True
            break
        if changed:
            save_kernel_command_queue(queue)

    def run_command_bus(self, policy: dict) -> list[dict]:
        if not bool(policy.get("kernel_command_bus_enabled", True)):
            return []
        entries = self._pull_commands_from_sources(policy)
        executed = []
        for entry in entries:
            result = self._dispatch_command(entry)
            executed.append({"entry": entry, "result": result})
            self._record_command(entry, result)
            self._finalize_queue_entry(str(entry.get("id", "")).strip(), result)
        if executed:
            log_action(f"Kernel command bus executed {len(executed)} command(s).")
        return executed

    def run_cycle(self) -> bool:
        started = time.time()
        self.last_cycle_at = datetime.now(SITE_TIMEZONE).isoformat()
        self.last_cycle_status = "running"
        goal_met = False

        policy = load_workspace_policy()
        self.run_command_bus(policy)
        enforce_runtime_log_retention(policy)
        maybe_process_user_dialog(policy)
        maybe_update_memory_and_skill_adaptation(policy)
        maybe_refresh_local_neural_backup_health(policy)
        maybe_refresh_ollama_runtime_health(policy)
        sync_training_status_architecture()
        ensure_end_of_day_workspace_coverage(policy)
        audit_install_targets(policy)
        heartbeat()

        if check_training_goal():
            log_action("GOAL MET: Traininomous_ui_worker_enabled' create/workspace_policy_v2.jsong and dataset targets achieved.")
            with STATUS_TXT.open("a", encoding="utf-8") as handle:
                handle.write(f"\n[skynetv2 agent] GOAL MET at {datetime.now()}\n")
            if bool(policy.get("continue_after_goal_met", True)):
                self.last_cycle_status = "goal_met_continuing"
            else:
                goal_met = True
                self.last_cycle_status = "goal_met"
        else:
            monitor_resources()
            detect_failures()
            propose_and_apply_improvements()
            update_trainer_reliability_trend(policy)
            evaluate_pending_self_heal_outcomes(policy)
            run_autonomous_screen_learning_cycle(policy)
            run_error_learning_cycle()
            run_staged_self_rewrite_executor()
            run_device_discovery_cycle()
            trigger_auto_apply_rewrites()
            _maybe_verify_workspace_runtime(policy)
            refresh_module_statuses()
            evaluate_progress_milestones()
            _maybe_run_periodic_ui_work(policy)
            _maybe_autowrite_ai_os_scaffold(policy)

            if self.cycle_count % 5 == 0:
                discover_system_services()
                discover_packages()
                discover_swarm_services_and_logs(load_workspace_policy())
                log_action("Synthesis cycle complete; backlog, service registry, and package registry are in sync.")

        self.cycle_count += 1
        self.last_cycle_duration_ms = (time.time() - started) * 1000.0
        self._publish_state()
        return goal_met

def check_deployment_status() -> dict:
    rows = list_all_deployment_devices()
    if rows.get("status") != "ok":
        return rows
    devices = rows.get("devices", []) if isinstance(rows.get("devices", []), list) else []
    summary = {
        "total": len(devices),
        "approved": sum(1 for d in devices if bool(d.get("approved", False))),
        "success": sum(1 for d in devices if str(d.get("install_status", "")).lower() == "success"),
        "failed": sum(1 for d in devices if str(d.get("install_status", "")).lower() == "failed"),
        "in_progress": sum(1 for d in devices if str(d.get("install_status", "")).lower() == "in_progress"),
        "bundle_prepared": sum(1 for d in devices if str(d.get("install_status", "")).lower() == "bundle_prepared"),
    }
    return {"status": "ok", "summary": summary, "devices": devices}

def deploy_to_approved_devices(policy: dict | None = None, require_confirmation: bool = False, initiated_by: str = "manual") -> dict:
    policy = policy or load_workspace_policy()
    if require_confirmation and not _prompt_yes_no("Deploy to approved devices now? [y/N]: "):
        return {"status": "cancelled", "initiated_by": initiated_by}
    bundle_result = prepare_install_bundle_for_approved_devices(policy)
    status = str(bundle_result.get("status", "unknown"))
    if status in {"error", "no_approved_devices"}:
        return {
            "status": status,
            "initiated_by": initiated_by,
            "bundles_prepared": int(bundle_result.get("bundles_prepared", 0) or 0),
            "errors": bundle_result.get("errors", []),
        }
    return {
        "status": "bundle_prepared",
        "initiated_by": initiated_by,
        "bundles_prepared": int(bundle_result.get("bundles_prepared", 0) or 0),
        "bundles": bundle_result.get("bundles", []),
        "errors": bundle_result.get("errors", []),
        "note": "direct CLI deployment currently prepares bundles and records status without requiring the daemon lock",
    }

def maybe_run_autonomous_deployment(policy: dict) -> dict:
    if not bool(policy.get("autonomous_deployment_enabled", False)):
        return {"status": "disabled"}
    return deploy_to_approved_devices(
        policy=policy,
        require_confirmation=bool(policy.get("autonomous_deployment_require_confirmation", True)),
        initiated_by="autonomous_loop",
    )

def main():
    cli_args = sys.argv[1:]
    if "--list-enrollment-queue" in cli_args:
        queue = load_device_enrollment_queue()
        summary = {
            "status": "ok",
            "pending": [q for q in queue if str(q.get("status", "")).lower() == "pending"],
            "approved": [q for q in queue if str(q.get("status", "")).lower() == "approved"],
            "rejected": [q for q in queue if str(q.get("status", "")).lower() == "rejected"],
            "total": len(queue),
        }
        print(json.dumps(summary, indent=2))
        return
    if "--check-deployment-status" in cli_args:
        print(json.dumps(check_deployment_status(), indent=2))
        return
    if "--deploy-to-approved-devices" in cli_args:
        require_confirmation = "--require-confirmation" in cli_args
        policy = load_workspace_policy()
        result = deploy_to_approved_devices(
            policy=policy,
            require_confirmation=require_confirmation,
            initiated_by="cli",
        )
        print(json.dumps(result, indent=2))
        return
    if not acquire_single_instance_lock():
        log_action("Another skynetv2 instance is already running; exiting this process.")
        return
    log_action("skynetv2 autonomous core started.")
    _migrate_legacy_state_file(REGISTRY_FILE, LEGACY_REGISTRY_FILE)
    _migrate_legacy_state_file(REWRITE_QUEUE_FILE, LEGACY_REWRITE_QUEUE_FILE)
    _migrate_legacy_state_file(REWRITE_RULES_FILE, LEGACY_REWRITE_RULES_FILE)
    _migrate_legacy_state_file(REWRITE_HISTORY_FILE, LEGACY_REWRITE_HISTORY_FILE)
    _migrate_legacy_state_file(NETWORK_SCAN_POLICY_FILE, LEGACY_NETWORK_SCAN_POLICY_FILE)
    _migrate_legacy_state_file(DEVICE_ENROLLMENT_QUEUE_FILE, LEGACY_DEVICE_ENROLLMENT_QUEUE_FILE)
    _migrate_legacy_state_file(DEVICE_REGISTRY_FILE, LEGACY_DEVICE_REGISTRY_FILE)
    _migrate_legacy_state_file(SERVICE_REGISTRY_FILE, LEGACY_SERVICE_REGISTRY_FILE)
    _migrate_legacy_state_file(PACKAGE_REGISTRY_FILE, LEGACY_PACKAGE_REGISTRY_FILE)
    _migrate_legacy_state_file(WORKSPACE_POLICY_FILE, LEGACY_WORKSPACE_POLICY_FILE)
    _migrate_legacy_state_file(AUTO_REWRITE_LOG_FILE, LEGACY_AUTO_REWRITE_LOG_FILE)
    ensure_registry_state()
    load_network_scan_policy()
    load_device_registry()
    policy = load_workspace_policy()
    ensure_local_user_auth_bootstrap(policy)
    enforce_runtime_log_retention(policy, force=True)
    maybe_process_user_dialog(policy)
    profile_result = apply_training_profile_from_config()
    if profile_result.get("status") not in {"applied", "already_active"}:
        log_action(f"Training profile not applied: {profile_result}")
    load_service_registry()
    load_package_registry()
    load_auto_rewrite_log()
    load_kernel_command_queue()
    backup_health = ensure_local_neural_backup_health(policy)
    if not bool(backup_health.get("healthy", False)):
        log_action("Warning: local neural backup runtime unhealthy; only external LLM runtime is available.")
    ollama_health = ensure_ollama_runtime_health()
    if not bool(ollama_health.get("healthy", False)):
        if bool(backup_health.get("healthy", False)):
            log_action("Warning: Ollama runtime unhealthy at startup; operating in local neural backup mode.")
        else:
            log_action("Warning: Ollama runtime unhealthy at startup; continuing with degraded AI module state.")
    sync_training_status_architecture()
    refresh_module_statuses()
    evaluate_progress_milestones()
    if read_json(DEVICE_ENROLLMENT_QUEUE_FILE) is None:
        save_device_enrollment_queue([])
    manager = build_self_healing_manager()
    start_self_healing_manager(manager)

    kernel = AIOSKernel()
    kernel.boot()
    start_autonomous_ui_worker()
    # Immediately run a direct improvement cycle on startup when enabled.
    try:
        _startup_policy = load_workspace_policy()
        if bool(_startup_policy.get("code_improvement_enabled", True)):
            log_action("Direct code improvement: running startup pass.")
            _maybe_run_periodic_ui_work(_startup_policy)
        _maybe_autowrite_ai_os_scaffold(_startup_policy)
    except Exception as _ui_startup_exc:
        log_action(f"Startup improvement action error (non-fatal): {_ui_startup_exc!s:.150}")

    while True:
        if kernel.run_cycle():
            break
        cycle_policy = load_workspace_policy()
        cycle_sleep = max(0.2, float(cycle_policy.get("autonomous_cycle_sleep_sec", LOOP_INTERVAL) or LOOP_INTERVAL))
        time.sleep(cycle_sleep)

if __name__ == "__main__":
    if "--print-active-architecture" in sys.argv:
        raise SystemExit(print_active_architecture_report())
    elif "--check-ollama" in sys.argv:
        print(json.dumps(ensure_ollama_runtime_health(), indent=2))
    elif "--check-local-neural-backup" in sys.argv:
        print(json.dumps(ensure_local_neural_backup_health(load_workspace_policy()), indent=2))
    elif "--apply-training-profile" in sys.argv:
        print(json.dumps(apply_training_profile_from_config(), indent=2))
    elif "--growth-install-report" in sys.argv:
        raise SystemExit(print_growth_and_install_report())
    elif "--discover-services" in sys.argv:
        services = discover_system_services()
        print(f"\nFound {len(services)} services:")
        for svc in services:
            status = f"{svc.get('active', 'unknown')}/{svc.get('sub', 'unknown')}"
            modifiable = "y" if svc.get("modifiable") else "n"
            print(f"  [{modifiable}] {svc.get('name', 'unknown'):40s} {status}")
    elif "--discover-packages" in sys.argv:
        packages = discover_packages()
        by_type = {}
        for pkg in packages:
            by_type.setdefault(pkg.get("type", "unknown"), 0)
            by_type[pkg.get("type", "unknown")] += 1
        print(f"\nFound {len(packages)} packages:")
        for pkg_type in sorted(by_type):
            print(f"  {pkg_type}: {by_type[pkg_type]}")
    elif "--discover-swarm" in sys.argv:
        services = discover_swarm_services_and_logs(load_workspace_policy())
        print(f"\nFound {len(services)} swarm services:")
        for svc in services:
            print(
                f"  {svc.get('name','unknown'):40s} replicas={svc.get('replicas','?'):12s} "
                f"issues={svc.get('log_issue_hits',0)}"
            )
    elif "--review-enrollment" in sys.argv:
        process_device_enrollment_queue()
    elif "--discover-now" in sys.argv:
        discover_devices()
    elif "--scan-network-now" in sys.argv:
        result = run_network_port_scan_and_email_report(load_network_scan_policy())
        print(json.dumps(result, indent=2))
    elif "--run-safe-improve-now" in sys.argv:
        refresh_module_statuses()
        evaluate_progress_milestones()
        discover_system_services()
        discover_packages()
        learn_from_nlp_code()
        results = trigger_auto_apply_rewrites()
        refresh_module_statuses()
        evaluate_progress_milestones()
        print(f"Applied/rolled-back rewrite checks: {len(results)}")
        for item in results[:20]:
            print(f"- {item.get('status')}: {item.get('file')} ({item.get('reason', '')})")
    elif "--refresh-progress-now" in sys.argv:
        refresh_module_statuses()
        evaluate_progress_milestones()
        print("Progress status refreshed.")
    elif "--memory-skill-report" in sys.argv:
        policy = load_workspace_policy()
        maybe_update_memory_and_skill_adaptation(policy)
        memory = load_agent_memory()
        skills = load_skill_adaptation()
        print(
            json.dumps(
                {
                    "memory": {
                        "updated_at": memory.get("updated_at", ""),
                        "facts_count": len(memory.get("facts", [])) if isinstance(memory.get("facts", []), list) else 0,
                        "issues_count": len(memory.get("issues", [])) if isinstance(memory.get("issues", []), list) else 0,
                        "latest_issue": (memory.get("issues", [])[-1] if isinstance(memory.get("issues", []), list) and memory.get("issues", []) else {}),
                    },
                    "skills": {
                        "updated_at": skills.get("updated_at", ""),
                        "skills_count": len(skills.get("skills", [])) if isinstance(skills.get("skills", []), list) else 0,
                        "latest_gap": (skills.get("gaps", [])[-1] if isinstance(skills.get("gaps", []), list) and skills.get("gaps", []) else {}),
                        "latest_recommendation": (
                            skills.get("recommendations", [])[-1]
                            if isinstance(skills.get("recommendations", []), list) and skills.get("recommendations", [])
                            else {}
                        ),
                    },
                },
                indent=2,
            )
        )
    elif "--user-inbox" in sys.argv:
        state = load_user_dialog_state()
        active = state.get("active_request", {}) if isinstance(state.get("active_request", {}), dict) else {}
        queue = state.get("queue", []) if isinstance(state.get("queue", []), list) else []
        history = state.get("history", []) if isinstance(state.get("history", []), list) else []
        print(
            json.dumps(
                {
                    "active_request": active,
                    "queued_count": len(queue),
