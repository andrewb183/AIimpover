print("[TEST ENTRYPOINT] Running main block")

from __future__ import annotations
import sys
import json
import subprocess
from pathlib import Path
from typing import Any

def generate_multipart_guide(script_path: Path, meta_path: Path):
    """Generate a multi-part guide, creating a unique video for each part with matching narration and visuals."""
    print(f"[DEBUG] Loading metadata from: {meta_path}")
    with open(meta_path, encoding="utf-8") as f:
        meta = json.load(f)
    print(f"[DEBUG] Loading script from: {script_path}")
    with open(script_path, encoding="utf-8") as f:
        script = f.read()

    # Split script into parts by markdown headers
    parts = [p.strip() for p in script.split('# Ollama In-Depth Guide:') if p.strip()]
    print(f"[DEBUG] Found {len(parts)} script parts. Metadata has {len(meta.get('parts', []))} parts.")
    if not parts or 'parts' not in meta:
        print("[Error] No parts found in script or metadata.")
        return

    for idx, part_meta in enumerate(meta['parts']):
        part_num = idx + 1
        print(f"[DEBUG] Processing part {part_num}: {part_meta.get('title')}")
        # Find the script section for this part
        part_title = part_meta['title']
        script_section = next((p for p in parts if f'Part {part_num}' in p), None)
        if not script_section:
            print(f"[Warning] No script section found for part {part_num}.")
            continue
        # Use the first paragraph as intro narration, rest as scene breakdowns
        lines = [l.strip() for l in script_section.split('\n') if l.strip()]
        print(f"[DEBUG] Script section lines for part {part_num}: {lines}")
        intro = lines[0] if lines else part_title
        bullets = [l for l in lines[1:] if l.startswith('-')]
        print(f"[DEBUG] Found {len(bullets)} bullet points for part {part_num}.")
        scenes = []
        scenes.append({
            'title': part_title,
            'body': intro,
            'narration': intro,
            'mono': False,
        })
        for bullet in bullets:
            clean = bullet.lstrip('-').strip()


        if __name__ == "__main__":
            import argparse
            parser = argparse.ArgumentParser(description="Generate multi-part guide videos.")
            parser.add_argument("--script", type=str, required=True, help="Path to the markdown script file.")
            parser.add_argument("--meta", type=str, required=True, help="Path to the metadata JSON file.")
            parser.add_argument("--parts", type=int, default=None, help="Number of parts (optional, for validation only).")
            args = parser.parse_args()

            script_path = Path(args.script)
            meta_path = Path(args.meta)
            print(f"[ENTRYPOINT] script_path={script_path}, meta_path={meta_path}, parts={args.parts}")
            generate_multipart_guide(script_path, meta_path)
            scenes.append({
                'title': clean,
                'body': clean,
                'narration': clean,
                'mono': False,
            })
        print(f"[DEBUG] Rendering {len(scenes)} scenes for part {part_num}.")
        # Render video for this part
        video_id = f"ollama_guide_part{part_num}"
        part_dir = GENERATED_ROOT / video_id
        scene_dir = part_dir / "scenes"
        part_dir.mkdir(parents=True, exist_ok=True)
        scene_dir.mkdir(parents=True, exist_ok=True)
        final_video = REVIEW_VIDEOS_DIR / f"{video_id}.mp4"
        final_thumb = REVIEW_THUMBS_DIR / f"{video_id}.jpg"
        _render_scene_sequence(scenes, scene_dir, final_video, final_thumb)
        print(f"[Done] Generated video for {part_title}: {final_video}")


ROOT = Path(__file__).resolve().parent
GENERATED_ROOT = ROOT / "generated_projects"
REVIEW_VIDEOS_DIR = ROOT / "review_videos"
REVIEW_THUMBS_DIR = ROOT / "review_thumbnails"
FONT_SANS = "/usr/share/fonts/truetype/dejavu/DejaVuSans-Bold.ttf"
FONT_MONO = "/usr/share/fonts/truetype/dejavu/DejaVuSansMono.ttf"
MIN_PUBLISH_DURATION_SECONDS = 900
SCENE_PLANNING_TARGET_SECONDS = 1350


def _safe_text(value: Any) -> str:
    return " ".join(str(value or "").replace("\n", " ").split())


def _truncate_lines(value: str, max_lines: int = 18, max_width: int = 78) -> str:
    import textwrap

    lines: list[str] = []
    for raw in value.splitlines():
        wrapped = textwrap.wrap(raw, width=max_width) or [""]
        lines.extend(wrapped)
    return "\n".join(lines[:max_lines])


def _write(path: Path, content: str) -> Path:
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(content, encoding="utf-8")
    return path


def _run(cmd: list[str], cwd: Path, output_path: Path) -> str:
    result = subprocess.run(cmd, cwd=str(cwd), capture_output=True, text=True, check=False)
    combined = (result.stdout or "") + ("\n" + result.stderr if result.stderr else "")
    output_path.write_text(combined.strip() + ("\n" if combined else ""), encoding="utf-8")
    return combined.strip()


def _audio_duration(audio_path: Path) -> float:
    result = subprocess.run(
        [
            "ffprobe",
            "-v",
            "error",
            "-show_entries",
            "format=duration",
            "-of",
            "default=noprint_wrappers=1:nokey=1",
            str(audio_path),
        ],
        capture_output=True,
        text=True,
        check=False,
    )
    try:
        return float(result.stdout.strip())
    except Exception:
        return 6.0


def _media_duration(video_path: Path) -> float:
    result = subprocess.run(
        [
            "ffprobe",
            "-v",
            "error",
            "-show_entries",
            "format=duration",
            "-of",
            "default=noprint_wrappers=1:nokey=1",
            str(video_path),
        ],
        capture_output=True,
        text=True,
        check=False,
    )
    try:
        return float(result.stdout.strip())
    except Exception:
        return 0.0


def _estimate_scene_seconds(scene: dict[str, Any]) -> float:
    narration = _safe_text(scene.get("narration") or "")
    word_count = max(1, len(narration.split()))
    return max(12.0, (word_count / 2.2) + 2.0)


def _total_estimated_duration(scenes: list[dict[str, Any]]) -> float:
    return sum(_estimate_scene_seconds(scene) for scene in scenes)


def _render_scene_sequence(
    scenes: list[dict[str, Any]],
    scene_dir: Path,
    final_video: Path,
    final_thumb: Path,
) -> float:
    scene_files: list[Path] = []
    for index, scene in enumerate(scenes, start=1):
        scene_files.append(
            _make_scene(
                scene_dir,
                index,
                str(scene["title"]),
                str(scene["body"]),
                str(scene["narration"]),
                mono=bool(scene.get("mono", False)),
            )
        )

    concat_file = scene_dir.parent / "concat.txt"
    concat_file.write_text(
        "\n".join([f"file '{scene.resolve()}'" for scene in scene_files]) + "\n",
        encoding="utf-8",
    )

    subprocess.run(
        [
            "ffmpeg",
            "-y",
            "-f",
            "concat",
            "-safe",
            "0",
            "-i",
            str(concat_file),
            "-c",
            "copy",
            str(final_video),
        ],
        capture_output=True,
        text=True,
        check=True,
    )

    subprocess.run(
        [
            "ffmpeg",
            "-y",
            "-i",
            str(scene_files[0]),
            "-frames:v",
            "1",
            str(final_thumb),
        ],
        capture_output=True,
        text=True,
        check=True,
    )
    return _media_duration(final_video)


def _expand_walkthrough_scenes(
    base_scenes: list[dict[str, Any]],
    files: dict[str, Path],
    pros_cons: dict[str, Any],
) -> list[dict[str, Any]]:
    expanded = list(base_scenes)
    draft_excerpt = _truncate_lines(files["draft_main"].read_text(encoding="utf-8"), max_lines=18, max_width=68)
    main_excerpt = _truncate_lines(files["main"].read_text(encoding="utf-8"), max_lines=18, max_width=68)
    test_excerpt = _truncate_lines(files["test"].read_text(encoding="utf-8"), max_lines=18, max_width=68)
    run_excerpt = _truncate_lines(files["metadata"].read_text(encoding="utf-8"), max_lines=18, max_width=72)
    evidence_excerpt = _truncate_lines(
        (files["readme"].read_text(encoding="utf-8") + "\n\n" + json.dumps(pros_cons, indent=2)),
        max_lines=18,
        max_width=68,
    )

    template_rounds = [
        {
            "title": "Recap: Draft Logic",
            "body": draft_excerpt,
            "narration": (
                "This recap returns to the draft version. The rough code is useful because it gets ideas on screen quickly, "
                "but it also shows why cleanup matters. The logic is compressed, the data shape is informal, and maintenance would get harder over time."
            ),
            "mono": True,
        },
        {
            "title": "Evidence Review: Clean Structure",
            "body": main_excerpt,
            "narration": (
                "Here we slow down and look at the cleaned version again. The benefit is not just style. "
                "The structure makes the program easier to explain, easier to test, and easier to extend with new review rules."
            ),
            "mono": True,
        },
        {
            "title": "Evidence Review: Test Cases",
            "body": test_excerpt,
            "narration": (
                "The test cases matter because they show how the scoring behaves in both a strong example and a weak example. "
                "Repeating the evidence here gives the audience time to connect the rules to the actual expected outcomes."
            ),
            "mono": True,
        },
        {
            "title": "Metadata Context",
            "body": run_excerpt,
            "narration": (
                "This segment ties the code back to the input metadata. "
                "A review pipeline only feels trustworthy when viewers can see the exact context that the code used to make its decision."
            ),
            "mono": True,
        },
        {
            "title": "Pros And Cons Recap",
            "body": evidence_excerpt,
            "narration": (
                "Now we summarize the tradeoffs again in a calmer pace. "
                "The upside is a repeatable review workflow with visible evidence. "
                "The downside is that heuristic scoring is still a simplification and works best when paired with human judgment."
            ),
            "mono": True,
        },
    ]

    round_index = 1
    while _total_estimated_duration(expanded) < SCENE_PLANNING_TARGET_SECONDS:
        for template in template_rounds:
            if _total_estimated_duration(expanded) >= SCENE_PLANNING_TARGET_SECONDS:
                break
            expanded.append(
                {
                    "title": f"{template['title']} {round_index}",
                    "body": template["body"],
                    "narration": template["narration"] + f" This is recap pass {round_index}, reinforcing the same evidence from a slightly slower angle.",
                    "mono": template["mono"],
                }
            )
        round_index += 1
    return expanded


def _expand_foreign_explainer_scenes(
    base_scenes: list[dict[str, Any]],
    *,
    topic_bullets: list[str],
    summary_bullets: list[str],
    transcript_excerpt: str,
    rights_note: str,
    english_script: str,
    description: str,
) -> list[dict[str, Any]]:
    expanded = list(base_scenes)
    transcript_blocks = [
        transcript_excerpt[i:i + 220]
        for i in range(0, len(transcript_excerpt), 220)
        if transcript_excerpt[i:i + 220]
    ] or [description[:220] or "Metadata is limited, so this recap focuses on attribution and uncertainty."]

    round_index = 1
    while _total_estimated_duration(expanded) < SCENE_PLANNING_TARGET_SECONDS:
        transcript_piece = transcript_blocks[(round_index - 1) % len(transcript_blocks)]
        recap_scenes = [
            {
                "title": f"Source Evidence Recap {round_index}",
                "body": _truncate_lines("\n".join(topic_bullets + ["", transcript_piece]), max_lines=18, max_width=74),
                "narration": (
                    "This recap returns to the source evidence. "
                    "The goal is to make the attribution and evidence trail very clear before the English commentary draws any takeaway from it."
                ),
                "mono": False,
            },
            {
                "title": f"English Summary Pass {round_index}",
                "body": _truncate_lines(english_script + "\n\n" + "\n".join(summary_bullets), max_lines=18, max_width=74),
                "narration": (
                    "In this pass, the narration slows down and repeats the English summary. "
                    "That makes the video feel more natural than a hard loop because the recap keeps restating the same idea in audience-friendly language."
                ),
                "mono": False,
            },
            {
                "title": f"Rights And Attribution {round_index}",
                "body": _truncate_lines(rights_note + "\n\nSource attribution stays visible throughout the explainer.", max_lines=18, max_width=74),
                "narration": (
                    "This chapter reinforces the rights-safe framing. "
                    "The upload is commentary only, the original creator stays credited, and uncertain details are treated as uncertain rather than overstated."
                ),
                "mono": False,
            },
        ]
        for scene in recap_scenes:
            if _total_estimated_duration(expanded) >= SCENE_PLANNING_TARGET_SECONDS:
                break
            expanded.append(scene)
        round_index += 1
    return expanded


def _make_audio(text: str, output_path: Path) -> float:
    safe = text.replace("\\", "\\\\").replace(":", "\\:").replace("'", "\\'")
    tmp_audio = str(output_path) + ".tmp.wav"
    # Generate TTS audio with 'slt' voice for clarity
    subprocess.run(
        [
            "ffmpeg",
            "-y",
            "-f",
            "lavfi",
            "-i",
            f"flite=text='{safe}':voice=slt",
            tmp_audio,
        ],
        capture_output=True,
        text=True,
        check=True,
    )
    # Adjust speed to a natural conversational pace (atempo=0.90)
    subprocess.run(
        [
            "ffmpeg",
            "-y",
            "-i",
            tmp_audio,
            "-filter:a",
            "atempo=0.90",
            str(output_path),
        ],
        capture_output=True,
        text=True,
        check=True,
    )
    Path(tmp_audio).unlink(missing_ok=True)
    return _audio_duration(output_path)


def _make_scene(
    scene_dir: Path,
    index: int,
    title: str,
    body: str,
    narration: str,
    *,
    mono: bool = False,
) -> Path:
    title_file = _write(scene_dir / f"scene_{index:02d}_title.txt", title)
    body_file = _write(scene_dir / f"scene_{index:02d}_body.txt", body)
    audio_file = scene_dir / f"scene_{index:02d}.wav"
    duration = max(5.0, _make_audio(narration, audio_file) + 1.0)
    scene_file = scene_dir / f"scene_{index:02d}.mp4"
    font = FONT_MONO if mono else FONT_SANS

    filter_chain = (
        "drawbox=x=60:y=50:w=1160:h=620:color=black@0.40:t=fill,"
        f"drawtext=fontfile={FONT_SANS}:textfile='{title_file}':fontcolor=#F9FAFB:fontsize=44:"
        "x=80:y=80:line_spacing=8,"
        f"drawtext=fontfile={font}:textfile='{body_file}':fontcolor=#D1D5DB:fontsize=24:"
        "x=80:y=170:line_spacing=10"
    )

    subprocess.run(
        [
            "ffmpeg",
            "-y",
            "-f",
            "lavfi",
            "-i",
            f"color=c=#111827:s=1280x720:d={duration}",
            "-i",
            str(audio_file),
            "-vf",
            filter_chain,
            "-r",
            "1",
            "-t",
            str(duration),
            "-c:v",
            "libx264",
            "-preset",
            "ultrafast",
            "-tune",
            "stillimage",
            "-pix_fmt",
            "yuv420p",
            "-c:a",
            "aac",
            "-shortest",
            str(scene_file),
        ],
        capture_output=True,
        text=True,
        check=True,
    )
    return scene_file


def _build_project_files(project_dir: Path, meta: dict[str, Any], metadata_json_path: Path) -> dict[str, Path]:
    title = _safe_text(meta.get("title") or metadata_json_path.stem)

    draft_main = f"""import json
import sys

def score_video(meta):
    score = 0
    if meta.get("duration", 0) >= 900:
        score += 2
    if meta.get("tags"):
        score += 1
    if "AI" in meta.get("title", ""):
        score += 1
    return {{
        "title": meta.get("title"),
        "score": score,
        "pros": ["easy to read title", "usable metadata"],
        "cons": ["rough scoring", "no structured report"],
    }}

if __name__ == "__main__":
    with open(sys.argv[1], "r", encoding="utf-8") as f:
        meta = json.load(f)
    print(json.dumps(score_video(meta), indent=2))
"""

    main_py = f"""from __future__ import annotations

import json
import sys
from dataclasses import dataclass
from typing import Any


@dataclass
class ReviewReport:
    title: str
    score: int
    verdict: str
    pros: list[str]
    cons: list[str]


def build_report(meta: dict[str, Any]) -> ReviewReport:
    title = str(meta.get("title") or "Untitled review")
    duration = int(meta.get("duration") or 0)
    tags = list(meta.get("tags") or [])
    description = str(meta.get("description") or "")

    score = 0
    pros: list[str] = []
    cons: list[str] = []

    if duration >= 900:
        score += 2
        pros.append("Long-form source video gives enough material to fact-check.")
    else:
        cons.append("Short runtime limits how much evidence the review can gather.")

    if tags:
        score += 1
        pros.append("Source metadata includes tags that help categorize the claim.")
    else:
        cons.append("Missing tags make intent classification weaker.")

    if description:
        score += 1
        pros.append("Description provides extra context for the review summary.")
    else:
        cons.append("No description means fewer details to validate against.")

    if "ai" in title.lower():
        score += 1
        pros.append("The topic is clearly AI-related, which matches the review pipeline.")
    else:
        cons.append("Topic fit is less obvious and may need manual interpretation.")

    verdict = "promising" if score >= 4 else "mixed" if score >= 2 else "weak"
    return ReviewReport(title=title, score=score, verdict=verdict, pros=pros, cons=cons)


def main(argv: list[str]) -> int:
    if len(argv) < 2:
        raise SystemExit("usage: python main.py metadata.json")
    with open(argv[1], "r", encoding="utf-8") as handle:
        meta = json.load(handle)
    report = build_report(meta)
    print(json.dumps(report.__dict__, indent=2))
    return 0


if __name__ == "__main__":
    import argparse
    parser = argparse.ArgumentParser(description="Generate code walkthrough or multi-part guide videos.")
    parser.add_argument('--script', type=str, help='Path to the markdown script file for multi-part guides')
    parser.add_argument('--meta', type=str, help='Path to the metadata JSON file for multi-part guides')
    parser.add_argument('--parts', type=int, default=1, help='Number of parts (for multi-part guides)')
    args = parser.parse_args()

    if args.script and args.meta and args.parts > 1:
        generate_multipart_guide(Path(args.script), Path(args.meta))
    else:
        raise SystemExit(main(sys.argv))
"""

    test_py = """from main import build_report


def test_build_report_long_form():
    report = build_report({
        "title": "AI tutorial review",
        "duration": 1200,
        "tags": ["ai"],
        "description": "demo",
    })
    assert report.verdict == "promising"
    assert report.score >= 4


def test_build_report_short_form():
    report = build_report({
        "title": "quick clip",
        "duration": 120,
        "tags": [],
        "description": "",
    })
    assert report.verdict in {"weak", "mixed"}
    assert report.cons
"""

    readme = f"""# {title}

This generated project demonstrates the review pipeline:

1. Write rough code to score the source video.
2. Clean it up into a structured report.
3. Run tests to verify the behavior.
4. Render a narrated walkthrough video that explains the code, the output, and the tradeoffs.
"""

    metadata_copy = project_dir / "metadata_input.json"
    metadata_copy.write_text(metadata_json_path.read_text(encoding="utf-8"), encoding="utf-8")

    return {
        "draft_main": _write(project_dir / "draft_main.py", draft_main),
        "main": _write(project_dir / "main.py", main_py),
        "test": _write(project_dir / "test_main.py", test_py),
        "readme": _write(project_dir / "README.md", readme),
        "metadata": metadata_copy,
    }


def generate_code_walkthrough_assets(meta: dict[str, Any], video_id: str, metadata_json_path: Path) -> dict[str, str]:
    print("[PythonProjectBuilder] Step 1: Creating project directories and files...")
    GENERATED_ROOT.mkdir(parents=True, exist_ok=True)
    REVIEW_VIDEOS_DIR.mkdir(parents=True, exist_ok=True)
    REVIEW_THUMBS_DIR.mkdir(parents=True, exist_ok=True)

    project_dir = GENERATED_ROOT / video_id
    scene_dir = project_dir / "scenes"
    project_dir.mkdir(parents=True, exist_ok=True)
    scene_dir.mkdir(parents=True, exist_ok=True)

    print("[ScriptWriter] Step 2: Building project files (draft, main, test, readme)...")
    files = _build_project_files(project_dir, meta, metadata_json_path)
    py_compile_log = project_dir / "py_compile.log"
    pytest_log = project_dir / "pytest.log"
    run_log = project_dir / "demo_run.log"

    print("[DebugTester] Step 3: Compiling Python files...")
    _run([sys.executable, "-m", "py_compile", "draft_main.py", "main.py", "test_main.py"], project_dir, py_compile_log)
    print("[DebugTester] Step 4: Running tests with pytest...")
    _run([sys.executable, "-m", "pytest", "-q", "test_main.py"], project_dir, pytest_log)
    print("[DebugTester] Step 5: Running main.py for demo output...")
    _run([sys.executable, "main.py", str(files["metadata"])], project_dir, run_log)

    title = _safe_text(meta.get("title") or video_id)
    pros_cons = json.loads((project_dir / "demo_run.log").read_text(encoding="utf-8").strip() or "{}")

    print("[VideoEditor] Step 6: Generating scenes and rendering video...")
    scenes = [
        {
            "title": f"Review Build: {title[:70]}",
            "body": _truncate_lines(
                "Step 1: write code to test the claims in the source video.\n"
                "Step 2: run tests and capture the output.\n"
                "Step 3: explain why the code was cleaned up and what tradeoffs it makes."
            ),
            "narration": (
                f"In this walkthrough, I build a small Python review tool for {title}. "
                "I start with rough code, clean it up, run tests, and explain the pros and cons."
            ),
            "mono": False,
        },
        {
            "title": "Step 1: Draft Code",
            "body": _truncate_lines(files["draft_main"].read_text(encoding="utf-8"), max_lines=18, max_width=68),
            "narration": (
                "First I write a rough draft that scores the source video from duration, tags, and title clues. "
                "It is fast to build, but the logic is cramped and the output shape is loosely defined."
            ),
            "mono": True,
        },
        {
            "title": "Step 2: Cleaned Code",
            "body": _truncate_lines(files["main"].read_text(encoding="utf-8"), max_lines=18, max_width=68),
            "narration": (
                "Next I clean the code into a dataclass-based report builder. "
                "This version is easier to test, easier to explain on screen, and easier to extend later."
            ),
            "mono": True,
        },
        {
            "title": "Step 3: Tests",
            "body": _truncate_lines(files["test"].read_text(encoding="utf-8"), max_lines=18, max_width=68),
            "narration": (
                "Now I add tests so the walkthrough has proof. "
                "The tests verify both a long-form promising case and a short-form weaker case."
            ),
            "mono": True,
        },
        {
            "title": "Step 4: Test Output",
            "body": _truncate_lines(pytest_log.read_text(encoding="utf-8") + "\n\n" + py_compile_log.read_text(encoding="utf-8"), max_lines=18, max_width=72),
            "narration": (
                "Here is the evidence from the run. "
                "The code compiles, the tests pass, and that gives the review more credibility than a hand-wavy claim."
            ),
            "mono": True,
        },
        {
            "title": "Step 5: Result And Tradeoffs",
            "body": _truncate_lines(
                json.dumps(
                    {
                        "verdict": pros_cons.get("verdict"),
                        "score": pros_cons.get("score"),
                        "pros": pros_cons.get("pros", []),
                        "cons": pros_cons.get("cons", []),
                    },
                    indent=2,
                ),
                max_lines=18,
                max_width=68,
            ),
            "narration": (
                "The final report highlights the pros and cons. "
                "The main advantage is a simple repeatable review process. "
                "The downside is that heuristic scoring can miss nuance and still needs human judgment."
            ),
            "mono": True,
        },
    ]
    scenes = _expand_walkthrough_scenes(scenes, files, pros_cons)

    final_video = REVIEW_VIDEOS_DIR / f"{video_id}_review.mp4"
    final_thumb = REVIEW_THUMBS_DIR / f"{video_id}_review.jpg"
    final_duration = _render_scene_sequence(scenes, scene_dir, final_video, final_thumb)

    summary = {
        "project_dir": str(project_dir.resolve()),
        "draft_code_path": str(files["draft_main"].resolve()),
        "final_code_path": str(files["main"].resolve()),
        "test_code_path": str(files["test"].resolve()),
        "pytest_log_path": str(pytest_log.resolve()),
        "run_log_path": str(run_log.resolve()),
        "review_video_path": str(final_video.resolve()),
        "review_thumbnail_path": str(final_thumb.resolve()),
        "review_video_duration_seconds": final_duration,
    }
    summary_path = project_dir / "walkthrough_summary.json"
    summary_path.write_text(json.dumps(summary, indent=2), encoding="utf-8")
    summary["summary_path"] = str(summary_path.resolve())
    return summary


def generate_foreign_explainer_assets(meta: dict[str, Any], video_id: str, metadata_json_path: Path) -> dict[str, str]:
    GENERATED_ROOT.mkdir(parents=True, exist_ok=True)
    REVIEW_VIDEOS_DIR.mkdir(parents=True, exist_ok=True)
    REVIEW_THUMBS_DIR.mkdir(parents=True, exist_ok=True)

    project_dir = GENERATED_ROOT / f"{video_id}_foreign_explainer"
    scene_dir = project_dir / "scenes"
    project_dir.mkdir(parents=True, exist_ok=True)
    scene_dir.mkdir(parents=True, exist_ok=True)

    source_title = _safe_text(meta.get("source_title") or meta.get("title") or video_id)
    source_channel = _safe_text(meta.get("source_uploader") or meta.get("uploader") or "Unknown channel")
    source_url = _safe_text(meta.get("webpage_url") or "")
    language_guess = _safe_text(meta.get("source_language_guess") or "non-English or mixed-language source")
    transcript = _safe_text(meta.get("transcript") or "")
    description = _safe_text(meta.get("source_description") or meta.get("description") or "")
    tags = list(meta.get("source_tags") or meta.get("tags") or [])
    duration = int(meta.get("duration") or 0)
    rights_note = (
        "This package is commentary-only. It avoids reposting translated chapters, full dubbed audio, "
        "or long source-video footage without permission."
    )

    transcript_excerpt = transcript[:900] if transcript else "Transcript unavailable, so the explainer relies on title, description, tags, and channel context."
    topic_bullets = [
        f"Source title: {source_title}",
        f"Channel: {source_channel}",
        f"Likely source language: {language_guess}",
        f"Runtime: {duration} seconds",
        f"Top tags: {', '.join(tags[:6]) if tags else 'none listed'}",
        f"Source URL: {source_url or 'none'}",
    ]
    summary_bullets = [
        "What the source appears to cover",
        transcript_excerpt[:220] or description[:220] or "No transcript or description text was available.",
        "Why an English explainer helps",
        "It makes the theme understandable for English-speaking viewers without reposting the original work.",
    ]
    pros_cons = {
        "pros": [
            "Original English narration instead of a translated reupload.",
            "Clear attribution back to the source creator.",
            "Safer copyright posture than direct localization."
        ],
        "cons": [
            "Some nuance can be lost without a full rights-cleared translation.",
            "Transcript or metadata gaps can limit precision.",
            "Human review is still needed for sensitive factual claims."
        ],
    }

    fact_sheet = {
        "source_title": source_title,
        "source_channel": source_channel,
        "source_url": source_url,
        "source_language_guess": language_guess,
        "duration_seconds": duration,
        "tags": tags[:10],
        "transcript_excerpt": transcript_excerpt,
        "rights_note": rights_note,
    }
    english_script = "\n".join(
        [
            f"Today we're breaking down {source_title} in English.",
            f"The original source appears to be in {language_guess}.",
            "This video is an explainer and commentary piece, not a translated repost.",
            f"We'll use the available transcript, description, and metadata from {source_channel} to summarize the main idea.",
            "Then we'll walk through what seems clear, what is uncertain, and what English-speaking viewers should take away.",
            "If the source makes strong factual claims, those still need independent verification before being treated as true.",
        ]
    )

    _write(project_dir / "source_fact_sheet.json", json.dumps(fact_sheet, indent=2))
    _write(project_dir / "english_explainer_script.txt", english_script + "\n")
    _write(project_dir / "rights_notes.txt", rights_note + "\n")

    scenes = [
        {
            "title": f"English Explainer: {source_title[:64]}",
            "body": _truncate_lines(
                "This is an original English commentary video.\n"
                "It summarizes a likely non-English source without reposting the original in translated form.\n\n"
                + "\n".join(topic_bullets)
            ),
            "narration": (
                f"This English explainer covers {source_title}. "
                "The goal is to help viewers understand the source without simply copying, dubbing, or retranslating it."
            ),
            "mono": False,
        },
        {
            "title": "Source Signals",
            "body": _truncate_lines("\n".join(topic_bullets), max_lines=18, max_width=74),
            "narration": (
                f"The source comes from {source_channel}. "
                f"Our language guess is {language_guess}, based on the available metadata and caption signals."
            ),
            "mono": False,
        },
        {
            "title": "What The Source Says",
            "body": _truncate_lines(transcript_excerpt or description or "No transcript or description text was available.", max_lines=18, max_width=74),
            "narration": (
                "Here are the strongest signals from the transcript or description. "
                "When transcript data is missing, the explainer falls back to title, tags, and channel context."
            ),
            "mono": False,
        },
        {
            "title": "English Commentary Angle",
            "body": _truncate_lines("\n".join(summary_bullets), max_lines=18, max_width=74),
            "narration": (
                "Instead of translating and reposting the source, this pipeline creates a fresh English commentary summary. "
                "That gives English-speaking viewers context while keeping the upload more original."
            ),
            "mono": False,
        },
        {
            "title": "Pros And Limits",
            "body": _truncate_lines(json.dumps(pros_cons, indent=2), max_lines=18, max_width=68),
            "narration": (
                "The biggest advantage is a safer rights posture. "
                "The main limitation is that metadata-based summarization can miss nuance, so high-stakes claims still need human checking."
            ),
            "mono": True,
        },
        {
            "title": "Rights-Safe Publishing",
            "body": _truncate_lines(
                rights_note + "\n\nSource attribution is preserved in the metadata package and description.",
                max_lines=18,
                max_width=74,
            ),
            "narration": (
                "The final output is meant to be commentary only. "
                "It should credit the source, avoid long source footage, and avoid presenting itself as an official English version."
            ),
            "mono": False,
        },
    ]
    scenes = _expand_foreign_explainer_scenes(
        scenes,
        topic_bullets=topic_bullets,
        summary_bullets=summary_bullets,
        transcript_excerpt=transcript_excerpt,
        rights_note=rights_note,
        english_script=english_script,
        description=description,
    )

    final_video = REVIEW_VIDEOS_DIR / f"{video_id}_foreign_explainer.mp4"
    final_thumb = REVIEW_THUMBS_DIR / f"{video_id}_foreign_explainer.jpg"
    final_duration = _render_scene_sequence(scenes, scene_dir, final_video, final_thumb)

    summary = {
        "project_dir": str(project_dir.resolve()),
        "fact_sheet_path": str((project_dir / "source_fact_sheet.json").resolve()),
        "script_path": str((project_dir / "english_explainer_script.txt").resolve()),
        "rights_notes_path": str((project_dir / "rights_notes.txt").resolve()),
        "review_video_path": str(final_video.resolve()),
        "review_thumbnail_path": str(final_thumb.resolve()),
        "review_video_duration_seconds": final_duration,
    }
    summary_path = project_dir / "walkthrough_summary.json"
    summary_path.write_text(json.dumps(summary, indent=2), encoding="utf-8")
    summary["summary_path"] = str(summary_path.resolve())
    return summary
