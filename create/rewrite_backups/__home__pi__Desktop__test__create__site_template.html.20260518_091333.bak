                max-width: 1180px;
                margin: 0 auto;
                padding: 28px 18px 56px;
            }
            .hero {
                background: linear-gradient(145deg, rgba(255,255,255,0.92), rgba(255,255,255,0.74));
                border: 1px solid rgba(255,255,255,0.55);
