        const savedKey = "skynet_saved_items_v1";
        const catalog = [{"kind": "story", "title": "Anthropic has acquired the dev tools startup used by OpenAI, Google, and Cloudflare", "url": "https://techcrunch.com/2026/05/18/anthropic-has-acquired-the-dev-tools-startup-used-by-openai-google-and-cloudflare/", "source": "TechCrunch"}, {"kind": "story", "title": "Elon Musk has lost his lawsuit against Sam Altman and OpenAI", "url": "https://techcrunch.com/2026/05/18/elon-musk-has-lost-his-lawsuit-against-sam-altman-and-openai/", "source": "TechCrunch"}, {"kind": "story", "title": "NYC Health + Hospitals says hackers stole medical data and fingerprints during breach affecting at least 1.8 million people", "url": "https://techcrunch.com/2026/05/18/nyc-health-and-hospitals-says-hackers-stole-medical-data-and-fingerprints-during-breach-affecting-at-least-1-8-million-people/", "source": "TechCrunch"}, {"kind": "story", "title": "Kin Health raises $9M to build an AI notetaker for patients", "url": "https://techcrunch.com/2026/05/18/kin-health-raises-9m-to-build-an-ai-notetaker-for-patients/", "source": "TechCrunch"}, {"kind": "story", "title": "Australian Aboriginals cared for a dingo's grave for decades", "url": "https://arstechnica.com/science/2026/05/1000-year-old-burial-reveals-close-bonds-between-people-and-dingoes/", "source": "Ars Technica"}, {"kind": "story", "title": "Elon Musk took too long to sue OpenAI, jury unanimously agrees", "url": "https://arstechnica.com/tech-policy/2026/05/elon-musk-loses-trial-accusing-sam-altman-openai-of-stealing-a-charity/", "source": "Ars Technica"}, {"kind": "story", "title": "Pompeii victim ID'd as a likely doctor", "url": "https://arstechnica.com/science/2026/05/pompeii-victim-idd-as-a-likely-doctor/", "source": "Ars Technica"}, {"kind": "story", "title": "Guy Gardner makes a cameo in new Lanterns teaser", "url": "https://arstechnica.com/culture/2026/05/new-lanterns-teaser-brings-back-the-superhero-vibes/", "source": "Ars Technica"}, {"kind": "story", "title": "Haiku OS runs on M1 Macs now", "url": "https://discuss.haiku-os.org/t/my-haiku-arm64-progress/19044?page=2", "source": "Hacker News"}, {"kind": "story", "title": "Anthropic acquires Stainless", "url": "https://www.anthropic.com/news/anthropic-acquires-stainless", "source": "Hacker News"}, {"kind": "video", "title": "What are tech CEOs seeking in China with Trump? | DW News", "url": "https://www.youtube.com/watch?v=wxIUD4p8nqA", "source": "DW News"}, {"kind": "video", "title": "Trump Discussed Nvidia Chips With Xi Jinping | Bloomberg Tech 5/15/2026", "url": "https://www.youtube.com/watch?v=pnLuiDLdqW0", "source": "Bloomberg Technology"}, {"kind": "video", "title": "Empty Waymo cars SWARM neighborhood, residents stunned #foxnews #news #shorts #cars #tech", "url": "https://www.youtube.com/watch?v=WVOahY1MSG8", "source": "Fox News"}, {"kind": "video", "title": "Tech News 2170 || Gemini Intelligence, Honor 600, X & Instagram, Figure AI, WhatsApp, Trump, .Etc..", "url": "https://www.youtube.com/watch?v=Jryf5J90QAE", "source": "Prasadtechintelugu"}, {"kind": "video", "title": "\u201cI am going to probably use $300M of Anthropic this year at Salesforce.\u201d - Marc Benioff", "url": "https://www.youtube.com/watch?v=qoUhsZKy39M", "source": "All-In Podcast"}, {"kind": "video", "title": "Amazon announces new AI technology to improve holiday delivery", "url": "https://www.youtube.com/watch?v=1f2z-F-_GFY", "source": "ABC News"}, {"kind": "video", "title": "Meta Expands AI Compute Deal, Nvidia GTC Kicks Off | Bloomberg Tech 3/16/2026", "url": "https://www.youtube.com/watch?v=buuLLZH6gNU", "source": "Bloomberg Technology"}, {"kind": "video", "title": "Kaynes Tech Shares Fall 19% | Management Clarifies Leadership Changes & Long-Term Vision", "url": "https://www.youtube.com/watch?v=VwsJYPEagyU", "source": "NDTV Profit"}];

        const read = (key, fallback) => {
            try {
                const raw = localStorage.getItem(key);
                return raw ? JSON.parse(raw) : fallback;
            } catch (error) {
                return fallback;
            }
        };

        const write = (key, value) => localStorage.setItem(key, JSON.stringify(value));

        const renderProfile = () => {
            const profile = read(profileKey, {});
            const form = document.getElementById("signup-form");
            const status = document.getElementById("signup-status");
            if (form) {
                form.name.value = profile.name || "";
                form.email.value = profile.email || "";
            }
            if (status && profile.name) {
                status.textContent = `Profile saved for ${profile.name}.`;
            }
        };

        const renderSavedItems = () => {
            const saved = read(savedKey, []);
            document.querySelectorAll("[data-saved-items]").forEach((list) => {
                if (!saved.length) {
                    list.innerHTML = "<li>No saved items yet.</li>";
                    return;
                }
                list.innerHTML = saved.map((item) =>
                    `<li><a href="${item.url}" target="_blank" rel="noopener noreferrer">${item.title}</a> <em>(${item.kind})</em></li>`
                ).join("");
            });
        };

        const renderRecommendations = () => {
            const saved = read(savedKey, []);
            const savedUrls = new Set(saved.map((item) => item.url));
            const keywords = new Set(
                saved.flatMap((item) =>
                    item.title.toLowerCase().split(/[^a-z0-9]+/).filter((word) => word.length > 4)
                )
            );
            let recommendations = catalog
                .filter((item) => !savedUrls.has(item.url))
                .map((item) => {
                    let score = 0;
                    if (saved.some((savedItem) => savedItem.source === item.source)) {
                        score += 2;
                    }
                    for (const word of keywords) {
                        if (item.title.toLowerCase().includes(word)) {
                            score += 1;
                        }
                    }
                    return { ...item, score };
                })
                .sort((a, b) => b.score - a.score);

            if (!saved.length) {
                recommendations = recommendations.slice(0, 5);
            } else {
                recommendations = recommendations.filter((item) => item.score > 0).slice(0, 5);
            }

            document.querySelectorAll("[data-recommendations]").forEach((list) => {
                if (!recommendations.length) {
                    list.innerHTML = "<li>Save a few items to personalize this list.</li>";
                    return;
                }
                list.innerHTML = recommendations.map((item) =>
                    `<li><a href="${item.url}" target="_blank" rel="noopener noreferrer">${item.title}</a> <em>(${item.kind})</em></li>`
                ).join("");
            });
        };

        document.addEventListener("click", (event) => {
            const button = event.target.closest(".save-item-btn");
            if (!button) {
                return;
            }
            const saved = read(savedKey, []);
            const item = {
                kind: button.dataset.kind,
                title: button.dataset.title,
                url: button.dataset.url,
                source: button.dataset.source
            };
            if (!saved.some((savedItem) => savedItem.url === item.url)) {
                saved.push(item);
                write(savedKey, saved);
            }
            renderSavedItems();
            renderRecommendations();
        });

        document.addEventListener("submit", (event) => {
            const form = event.target;
            if (!form || form.id !== "signup-form") {
                return;
            }
            event.preventDefault();
            write(profileKey, {
                name: form.name.value.trim(),
                email: form.email.value.trim()
            });
            renderProfile();
        });

        document.addEventListener("DOMContentLoaded", () => {
            renderProfile();
            renderSavedItems();
            renderRecommendations();
        });
    })();
    </script>
    
        </div>
    </body>
    </html>
    