        dest="latest_manifest",
        action="store_true",
        help="Use the newest manifest under generation_archives",
    )
    parser.add_argument("--refeed-endpoint", dest="refeed_endpoint", default="", help="Override model endpoint for refeed request")
    parser.add_argument("--refeed-model", dest="refeed_model", default="", help="Override model name for refeed request")
    parser.add_argument("--refeed-timeout", dest="refeed_timeout", type=int, default=None, help="Timeout seconds for refeed request")
    parser.add_argument("--refeed-max-tokens", dest="refeed_max_tokens", type=int, default=None, help="Token budget for refeed request")
    args, _unknown = parser.parse_known_args()

    manifest_path = args.manifest
    if args.latest_manifest and not manifest_path:
        latest_manifest = find_latest_manifest()
        if latest_manifest is None:
            raise SystemExit("No manifest.json files found under generation_archives")
        manifest_path = str(latest_manifest)
        print(f"Auto-selected latest manifest: {manifest_path}")

    if manifest_path:
        raise SystemExit(
            rejoin_from_manifest(
                manifest_path=manifest_path,
                endpoint_override=args.refeed_endpoint or None,
                model_override=args.refeed_model or None,
                timeout_override=args.refeed_timeout,
                max_tokens_override=args.refeed_max_tokens,
            )
        )

    if args.headless:
        raise SystemExit(launch_headless_outline())

    try:
        root = tk.Tk()
    except tk.TclError as exc:
        print(f"No GUI display available ({exc}); starting headless fallback.")
        raise SystemExit(launch_headless_outline())

    app = IdeaGeneratorApp(root)

    # Handle Ctrl+C gracefully via signal
    def handle_sigint(signum, frame):
        try:
            app.on_closing()
        except Exception:
            pass
        root.quit()

    signal.signal(signal.SIGINT, handle_sigint)

    try:
        root.mainloop()
    except KeyboardInterrupt:
        try:
            app.on_closing()
        except Exception:
            pass


def rejoin_from_manifest(manifest_path, endpoint_override=None, model_override=None, timeout_override=None, max_tokens_override=None):
    manifest_file = Path(manifest_path).expanduser().resolve()
    if not manifest_file.exists():
        print(f"Manifest not found: {manifest_file}")
        return 1

    try:
        with open(manifest_file, 'r', encoding='utf-8') as f:
            manifest = json.load(f)
    except Exception as exc:
        print(f"Failed to read manifest: {exc}")
        return 1

    run_dir = manifest_file.parent
    chunks_dir = run_dir / "chunks"
    if not chunks_dir.exists():
        print(f"Chunks directory not found: {chunks_dir}")
        return 1

    refeed_order = manifest.get("refeed_order") or manifest.get("chunk_files") or []
    if not refeed_order:
        refeed_order = sorted([p.name for p in chunks_dir.glob("chunk_*.txt")])

    chunks = []
    missing = []
    for name in refeed_order:
        chunk_path = chunks_dir / name
        if not chunk_path.exists():
            missing.append(name)
            continue
        chunks.append(chunk_path.read_text(encoding='utf-8'))

    if missing:
        print(f"Missing chunk files in manifest order: {missing}")
        return 1
    if not chunks:
        print("No chunks found to rejoin.")
        return 1

    combined = "".join(chunks)
    combined_file = run_dir / "response_reassembled_from_manifest.txt"
    combined_file.write_text(combined, encoding='utf-8')

    cfg = ConfigLoader.load_config()
    endpoints = cfg.get('models', {}).get('endpoints', {})
    default_endpoint = "http://localhost:11435"
    qwen_ep = endpoints.get('qwen2.5-coder', default_endpoint)
    if isinstance(qwen_ep, list):
        qwen_ep = qwen_ep[0] if qwen_ep else default_endpoint
    endpoint = endpoint_override or os.getenv("REJOIN_REFED_ENDPOINT") or str(qwen_ep)
    if 'ollama-qwen' in endpoint and not os.path.exists('/.dockerenv'):
        endpoint = endpoint.replace('ollama-qwen', 'localhost')
    if 'ollama-deepseek' in endpoint and not os.path.exists('/.dockerenv'):
        endpoint = endpoint.replace('ollama-deepseek', 'localhost')

    model_name = model_override or manifest.get("model") or os.getenv("REJOIN_REFED_MODEL") or "qwen2.5-coder"
    timeout_seconds = timeout_override if timeout_override is not None else int(os.getenv("OUTLINE_REQUEST_TIMEOUT_SECONDS", "14400"))
    timeout_seconds = max(60, min(timeout_seconds, 14400))

    raw_max_tokens = max_tokens_override if max_tokens_override is not None else int(os.getenv("OUTLINE_MODEL_MAX_TOKENS", "1000000"))
    max_tokens = max(500000, min(raw_max_tokens, 1000000))

    refeed_prompt = (
        "You are receiving a previously chunked generation. Reconstruct and merge all content into one coherent final artifact. "
        "Preserve details, fix only obvious truncation seams, and output the final merged result.\n\n"
        f"Source metadata: model={manifest.get('model', 'unknown')}, language={manifest.get('language', 'unknown')}, "
        f"chunks={len(chunks)}\n\n"
        "BEGIN_REJOINED_CONTENT\n"
        f"{combined}\n"
        "END_REJOINED_CONTENT\n"
    )

    payload = {
        "model": model_name,
        "prompt": refeed_prompt,
        "stream": False,
        "options": {
            "num_predict": max_tokens
        }
    }

    request_dump = run_dir / "refeed_request.json"
    with open(request_dump, 'w', encoding='utf-8') as rf:
        json.dump(payload, rf, indent=2)

    print(f"Rejoining chunks from: {manifest_file}")
    print(f"Chunk count: {len(chunks)}")
    print(f"Combined file: {combined_file}")
    print(f"Refeed endpoint: {endpoint}")
    print(f"Refeed model: {model_name}")
    print(f"Refeed timeout: {timeout_seconds}s")
    print(f"Refeed max tokens (clamped 500000-1000000): {max_tokens}")

    try:
        response = requests.post(
            f"{endpoint}/api/generate",
            json=payload,
            timeout=timeout_seconds
        )
    except Exception as exc:
        print(f"Refeed request failed: {exc}")
        return 1

    if response.status_code != 200:
        print(f"Refeed failed: HTTP {response.status_code}: {response.text[:400]}")
        return 1

    data = response.json()
    merged_text = data.get('response', '')
    if not merged_text:
        print("Refeed succeeded but returned empty response.")
        return 1

    output_path = run_dir / "refeed_merged_output.txt"
    output_path.write_text(merged_text, encoding='utf-8')
    print(f"Refeed merged output saved: {output_path}")
    return 0


def find_latest_manifest():
    archive_root = Path(__file__).parent / "generation_archives"
    if not archive_root.exists():
        return None

    manifests = sorted(
        archive_root.glob("*/manifest.json"),
        key=lambda path: path.stat().st_mtime,
        reverse=True,
    )
    return manifests[0] if manifests else None


def launch_headless_outline():
    root = _HeadlessRoot()
    app = IdeaGeneratorApp.__new__(IdeaGeneratorApp)
    app.root = root
    app.headless = True
    app.auto_send_enabled = True
    app.auto_task_drop_enabled = True
    app.config = {}
    app.redis_config = {}
    app.queue_key = "ideas:queue"
    app.models = ["qwen2.5-coder"]
    app.model_runtime_names = {}
    app.model_endpoints = {"qwen2.5-coder": "http://localhost:11435"}
    app.redis_client = None
    app.pg_host = None
    app.pg_user = None
    app.pg_pass = None
    app.pg_db = None
    app.languages = ["Python", "JavaScript", "Java", "C++", "C#", "Go", "Rust"]
    app.idea_queue = queue.Queue()
    app.running = False
    app.thread = None
    app.mode = "Generate"
    app.loaded_ideas = []
    app.web_ideas_used = []
    app.shown_ideas = set()
    app.models_loaded = False
    app.serve_processes = []
    app.generation_interval_seconds = int(os.getenv("OUTLINE_INTERVAL_SECONDS", "300"))
    raw_timeout_seconds = int(os.getenv("OUTLINE_REQUEST_TIMEOUT_SECONDS", "14400"))
    app.request_timeout_seconds = max(60, min(raw_timeout_seconds, 14400))
    raw_max_tokens = int(os.getenv("OUTLINE_MODEL_MAX_TOKENS", "1000000"))
    app.model_max_tokens = max(500000, min(raw_max_tokens, 1000000))
    raw_fallback_tokens = int(os.getenv("OUTLINE_FALLBACK_MAX_TOKENS", "16384"))
    app.fallback_max_tokens = max(1024, min(raw_fallback_tokens, 65536))
    app.archive_large_generations = os.getenv("OUTLINE_ARCHIVE_GENERATIONS", "true").lower() in ("1", "true", "yes")
    app.generation_chunk_chars = max(4000, int(os.getenv("OUTLINE_CHUNK_CHARS", "12000")))
    app.generation_archive_dir = Path(__file__).parent / "generation_archives"
    app.queue_pause_threshold = int(os.getenv("OUTLINE_QUEUE_PAUSE_THRESHOLD", "10"))
    app.queue_resume_threshold = int(os.getenv("OUTLINE_QUEUE_RESUME_THRESHOLD", "1"))
    app.paused = False
    app.status_label = _HeadlessWidget()
    app.start_stop_button = _HeadlessWidget()
    app.load_button = _HeadlessWidget()
    app.log_text = _HeadlessWidget()

    app.run_preflight_checks()

    try:
        app.config = ConfigLoader.load_config()
        app.model_endpoints = app._normalize_model_endpoints(
            app.config.get("models", {}).get("endpoints", {})
        )
        qwen_override = os.environ.get("OLLAMA_QWEN_ENDPOINT")
        deepseek_override = os.environ.get("OLLAMA_DEEPSEEK_ENDPOINT")
        if qwen_override:
            app.model_endpoints["qwen2.5-coder"] = qwen_override
        if deepseek_override:
            app.model_endpoints["deepseek-r1"] = deepseek_override
        if not os.path.exists("/.dockerenv"):
            translated_endpoints = {}
            for model_name, endpoint in app.model_endpoints.items():
                if "ollama-qwen" in endpoint:
                    translated_endpoints[model_name] = endpoint.replace("ollama-qwen", "localhost")
                elif "ollama-deepseek" in endpoint:
                    translated_endpoints[model_name] = endpoint.replace("ollama-deepseek", "localhost")
                else:
                    translated_endpoints[model_name] = endpoint
            app.model_endpoints = translated_endpoints

        app.redis_config = app.config.get("redis", {})
        app.queue_key = app.config.get("queues", {}).get("ideas", app.queue_key)
    except Exception as exc:
        app.log(f"⚠ ConfigLoader initialization failed in headless mode: {exc}, using defaults")

    app.load_ideas_log()
    threading.Thread(target=app.ensure_worker2_running, daemon=True).start()
    threading.Thread(target=app.load_models, daemon=True).start()

    def handle_sigint(signum, frame):
        try:
            app.on_closing()
        except Exception:
            pass
        root.quit()

    signal.signal(signal.SIGINT, handle_sigint)

    try:
        root.mainloop()
    except KeyboardInterrupt:
        try:
            app.on_closing()
        except Exception:
            pass
    return 0

