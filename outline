    def log(self, message):
        timestamp = datetime.now().strftime("%H:%M:%S")
        log_message = f"[{timestamp}] {message}"
        print(log_message)
        if hasattr(self, "log_text") and self.log_text is not None and threading.current_thread() is threading.main_thread():
            self._append_log_line(log_message)
        elif hasattr(self, "log_text") and self.log_text is not None:
            self.root.after(0, lambda: self._append_log_line(log_message))
    
    def ensure_worker2_running(self):
        """Check worker2 Swarm service status without starting any local process."""
        try:
            if not shutil.which("docker"):
                self.log("⚠ Docker CLI not available; cannot check worker2 Swarm service")
                return

            service_name = ""
            docker_result = subprocess.run(
                [
                    "docker",
                    "service",
                    "ls",
                    "--filter",
                    "label=com.docker.stack.namespace=worker2",
                    "--format",
                    "{{.Name}}",
                ],
                capture_output=True,
                text=True,
                timeout=5
            )
            if docker_result.returncode == 0:
                service_lines = [line.strip() for line in docker_result.stdout.splitlines() if line.strip()]
                if service_lines:
                    service_name = service_lines[0]
                    self.log(f"✓ Docker Swarm worker2 service is visible as {service_name}")
                else:
                    self.log("⚠ Docker Swarm worker2 service not found or not reachable")
                    self.log("ℹ outline will not start worker2 locally; deploy the worker2 stack instead")
                    return
            else:
                self.log("⚠ Docker Swarm worker2 service not found or not reachable")
                self.log("ℹ outline will not start worker2 locally; deploy the worker2 stack instead")
                return

            # Optional: log the service details for visibility without managing it.
            result = subprocess.run(
                ["docker", "service", "ps", service_name, "--no-trunc"],
                capture_output=True,
                text=True,
                timeout=5
            )
            if result.returncode == 0 and result.stdout.strip():
                self.log("✓ worker2 task listing retrieved from Swarm")
            else:
                self.log("⚠ Could not retrieve worker2 task listing from Swarm")
        except Exception as e:
            self.log(f"⚠ Could not check worker2 Swarm status: {str(e)}")
    
    def on_closing(self):
        self.running = False
        if self.thread:
            self.thread.join(timeout=20000)
        for p in self.serve_processes:
            p.terminate()
        try:
            self.root.destroy()
        except Exception:
            pass

    def load_models(self):
        def update_status(text):
            self.root.after(0, lambda: self.status_label.config(text=text))
        
        def enable_button():
            self.root.after(0, lambda: self.start_stop_button.config(state=tk.NORMAL))
        
        def disable_button():
            self.root.after(0, lambda: self.start_stop_button.config(state=tk.DISABLED))
        
        disable_button()
        update_status("Status: Loading models...")

        if not self.model_endpoints:
            self.model_endpoints = {"qwen2.5-coder": "http://localhost:11435"}
        
        loaded_models = []
        
        # Check models via ConfigLoader endpoints (support overlay DNS in Swarm)
        for model_name, endpoint in self.model_endpoints.items():
            try:
                self.log(f"Checking model {model_name} at {endpoint}...")
                
                # Health check via /api/tags endpoint
                tags_response = requests.get(
                    f"{endpoint}/api/tags",
                    timeout=3
                )
                
                if tags_response.status_code == 200:
                    tags_data = tags_response.json()
                    model_names = [m.get('name', '') for m in tags_data.get('models', [])]
                    matched_name = next((name for name in model_names if model_name == name or model_name in name), "")

                    if matched_name:
                        self.model_runtime_names[model_name] = matched_name
                        self.log(f"✓ Model {model_name} available at {endpoint}")
                        loaded_models.append(model_name)
                    else:
                        self.log(f"✗ Model {model_name} not found at {endpoint}")
                else:
                    self.log(f"✗ Service at {endpoint} returned status {tags_response.status_code}")
                        
            except requests.exceptions.Timeout:
                self.log(f"⚠ Timeout checking {model_name} at {endpoint} (service may be busy)")
                # Still consider it loaded if port responds
                try:
                    # Quick TCP check via socket
                    import socket
                    from urllib.parse import urlparse
                    parsed = urlparse(endpoint)
                    host = parsed.hostname or 'localhost'
                    port = parsed.port or 11435
                    sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
                    sock.settimeout(1)
                    result = sock.connect_ex((host, port))
                    sock.close()
                    if result == 0:
                        resolved_name = self._resolve_runtime_model_name(endpoint, model_name, timeout=10)
                        self.model_runtime_names[model_name] = resolved_name or model_name
                        if resolved_name:
                            self.log(f"✓ {endpoint} is responding; resolved {model_name} -> {resolved_name} while busy")
                        else:
                            self.log(f"✓ {endpoint} is responding; using fallback runtime name {model_name} while busy")
                        loaded_models.append(model_name)
                except Exception as e:
                    self.log(f"✗ Error checking {model_name}: {str(e)}")
            except Exception as e:
                self.log(f"✗ Error for {model_name} at {endpoint}: {str(e)}")
        
        # Update self.models to only loaded ones
        self.models = loaded_models
        self.log(f"Loaded {len(self.models)} out of {len(self.model_endpoints)} models")
        
        self.models_loaded = True
        update_status("Status: Models loaded")
        enable_button()

        # Auto-start generation for headless/container deployments
        auto_start = os.getenv("OUTLINE_AUTO_START", "false").lower() in ("1", "true", "yes")
        if auto_start and not self.running and loaded_models:
            self.log("OUTLINE_AUTO_START enabled; starting generation loop")
            self.root.after(0, self.toggle_generation)
        elif auto_start and not loaded_models:
            self.log("OUTLINE_AUTO_START requested, but no models were loaded; generation will stay stopped")

