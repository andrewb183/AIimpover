    def toggle_generation(self):
        if self.running:
            self.running = False
            self.status_label.config(text="Status: Stopping...")
            if self.thread:
                self.thread.join(timeout=200)
            self.start_stop_button.config(text="Start Generation")
            self.log("Generation stopped")
            self.status_label.config(text="Status: Stopped")
        else:
            if not self.models_loaded:
                if getattr(self, "headless", False):
                    self.log("Models are still loading. Please wait.")
                    return
                messagebox.showinfo("Info", "Models are still loading. Please wait.")
                return
            self.running = True
            self.thread = threading.Thread(target=self.generation_loop, daemon=True)
            self.thread.start()
            self.start_stop_button.config(text="Stop Generation")
            self.log("Generation started")
            self.status_label.config(text="Status: Running")

    def generation_loop(self):
        try:
            import psutil
        except ImportError:
            psutil = None
        while self.running:
            if psutil is not None:
                self.log(f"RAM usage: {psutil.virtual_memory().percent}%")
            try:
                if self.mode == "Load":
                    if self.loaded_ideas:
                        idea = self.loaded_ideas.pop(0)
                        self.idea_queue.put(idea)
                        self.save_idea(idea)
                        self.log(f"Loaded idea: {idea['title']}")
                    else:
                        self.running = False
                        self.root.after(0, lambda: self.status_label.config(text="Status: No more ideas"))
                        break
                elif self.mode == "Web":
                    idea = self.fetch_web_idea()
                    if idea:
                        self.idea_queue.put(idea)
                        self.save_idea(idea)
                        self.log(f"Fetched idea from web: {idea['title']}")
                        # Check if we have a web idea to pass to mk14
                        self.attempt_mk14_integration(idea)
                else:
                    # Check if queue is paused (too many pending ideas)
                    if not self.check_queue_size_and_pause():
                        # Queue is full, skip generation this cycle
                        time.sleep(self.generation_interval_seconds)
                        continue
                    
                    idea = self.generate_idea()
                    if idea:
                        self.idea_queue.put(idea)
                        self.save_idea(idea)
                        self.log(f"Generated idea: {idea['title']}")
                
                time.sleep(self.generation_interval_seconds)
            except Exception as e:
                self.log(f"Error in generation loop: {str(e)}")
                import traceback
                self.log(f"Traceback: {traceback.format_exc()}")
                time.sleep(60)

    def check_queue_size_and_pause(self):
        """
        Check Redis queue size. Pause generation if >= PAUSE_THRESHOLD.
        Resume if queue drops to <= RESUME_THRESHOLD.
        Returns: True if should generate, False if paused.
        """
        try:
            if not self.redis_client:
                return True  # Default to generating if Redis unavailable

            queue_size = int(cast(Any, self.redis_client.llen(self.queue_key)))
            # Update status label with queue size
            self.set_status_text(f"Status: Running | Queue size: {queue_size}")

            # Transition to paused state
            if queue_size >= self.queue_pause_threshold and not self.paused:
                self.paused = True
                self.log(f"⏸️  PAUSED: Queue has {queue_size} ideas (>= {self.queue_pause_threshold})")
                self.log("        Waiting for workers to process ideas...")
                return False

            # Transition to resumed state
            if queue_size <= self.queue_resume_threshold and self.paused:
                self.paused = False
                self.log(f"▶️  RESUMED: Queue down to {queue_size} ideas (<= {self.queue_resume_threshold})")
                return True

            # Already paused, stay paused
            if self.paused:
                return False

            # Log queue health while running
            if queue_size > 0:
                pct = min(100, int((queue_size / self.queue_pause_threshold) * 100))
                self.log(f"✓ Queue health: {queue_size}/{self.queue_pause_threshold} ({pct}%)")

            return True  # OK to generate

        except Exception as e:
            self.log(f"⚠️  Error checking queue size: {e}")
            return True  # Default to generating if check fails

    def _resolve_runtime_model_name(self, endpoint, model_name, timeout=5):
        try:
            tags_response = requests.get(f"{endpoint}/api/tags", timeout=timeout)
            if tags_response.status_code != 200:
                return ""
            tags_data = tags_response.json()
            model_names = [m.get('name', '') for m in tags_data.get('models', [])]
            return next((name for name in model_names if model_name == name or model_name in name), "")
        except Exception:
            return ""

    def _chunk_text(self, text):
        if not text:
            return []
        return [text[i:i + self.generation_chunk_chars] for i in range(0, len(text), self.generation_chunk_chars)]

    def _sanitize_filename(self, value):
        cleaned = re.sub(r'[^a-zA-Z0-9._-]+', '_', value.strip())
        return cleaned[:120] or "untitled"

    def _archive_generation_response(self, model_name, language, prompt, response_text):
        if not self.archive_large_generations or not response_text:
            return
        try:
            self.generation_archive_dir.mkdir(parents=True, exist_ok=True)
            run_id = f"{datetime.now().strftime('%Y%m%d_%H%M%S')}_{uuid.uuid4().hex[:8]}"
            run_dir = self.generation_archive_dir / run_id
            run_dir.mkdir(parents=True, exist_ok=True)

            prompt_file = run_dir / "prompt.txt"
            response_file = run_dir / "response_raw.txt"
            reassembled_file = run_dir / "response_reassembled.txt"
            chunks_dir = run_dir / "chunks"
            chunks_dir.mkdir(parents=True, exist_ok=True)

            prompt_file.write_text(prompt, encoding="utf-8")
            response_file.write_text(response_text, encoding="utf-8")

            chunks = self._chunk_text(response_text)
            chunk_files = []
            for idx, chunk in enumerate(chunks, start=1):
                chunk_name = f"chunk_{idx:04d}.txt"
                chunk_path = chunks_dir / chunk_name
                chunk_path.write_text(chunk, encoding="utf-8")
                chunk_files.append(chunk_name)

            reassembled_file.write_text("".join(chunks), encoding="utf-8")

            manifest = {
                "run_id": run_id,
                "timestamp": datetime.now().isoformat(),
                "model": model_name,
                "language": language,
                "max_tokens_requested": self.model_max_tokens,
                "fallback_max_tokens": self.fallback_max_tokens,
                "chunk_char_size": self.generation_chunk_chars,
                "response_char_count": len(response_text),
                "chunk_count": len(chunks),
                "chunk_files": chunk_files,
                "refeed_order": chunk_files,
                "refeed_instructions": "Feed chunk files to the model in order, then ask it to merge all parts into one final artifact.",
            }

            manifest_path = run_dir / "manifest.json"
            with open(manifest_path, 'w', encoding='utf-8') as mf:
                json.dump(manifest, mf, indent=2)

            self.log(
                f"✓ Archived generation payload: {run_dir} | chars={len(response_text)} | chunks={len(chunks)}"
            )
        except Exception as archive_err:
            self.log(f"⚠ Could not archive generation payload: {archive_err}")

    def _post_generate(self, endpoint, runtime_model, prompt, max_tokens, timeout_seconds):
        return requests.post(
            f"{endpoint}/api/generate",
            json={
                "model": runtime_model,
                "prompt": prompt,
                "stream": False,
                "options": {
                    "num_predict": max_tokens
                }
            },
            timeout=timeout_seconds
        )

    def generate_idea(self):
        language = random.choice(self.languages)
        prompt = f"Generate a creative idea for a new {language} code project. Provide a title, a brief description, and a sample code snippet. Format as: Title: <title>\nDescription: <desc>\nCode:\n```{language.lower()}\n<code>\n```"
        
        for model in self.models:
            endpoint = self.model_endpoints.get(model, "http://localhost:11435")
            runtime_model = self.model_runtime_names.get(model, model)
            if runtime_model == model:
                resolved_name = self._resolve_runtime_model_name(endpoint, model, timeout=8)
                if resolved_name:
                    runtime_model = resolved_name
                    self.model_runtime_names[model] = resolved_name
            # Health check before POST
            try:
                requests.get(endpoint, timeout=2)
            except Exception:
                self.log(f"Model endpoint {endpoint} not reachable, skipping")
                continue
            try:
                response = self._post_generate(
                    endpoint=endpoint,
                    runtime_model=runtime_model,
                    prompt=prompt,
                    max_tokens=self.model_max_tokens,
                    timeout_seconds=self.request_timeout_seconds,
                )
                if response.status_code == 200:
                    result = response.json().get('response', '')
                    if result:
                        self._archive_generation_response(runtime_model, language, prompt, result)
                        idea = self.parse_idea(result, language)
                        if idea:
                            return idea
                elif response.status_code == 404 and "not found" in response.text.lower():
                    resolved_name = self._resolve_runtime_model_name(endpoint, model, timeout=10)
                    if resolved_name and resolved_name != runtime_model:
                        self.model_runtime_names[model] = resolved_name
                        self.log(f"↻ Resolved runtime name for {model} -> {resolved_name}, retrying")
                        retry_response = self._post_generate(
                            endpoint=endpoint,
                            runtime_model=resolved_name,
                            prompt=prompt,
                            max_tokens=self.model_max_tokens,
                            timeout_seconds=self.request_timeout_seconds,
                        )
                        if retry_response.status_code == 200:
                            result = retry_response.json().get('response', '')
                            if result:
                                self._archive_generation_response(resolved_name, language, prompt, result)
                                idea = self.parse_idea(result, language)
                                if idea:
                                    return idea
                else:
                    self.log(f"⚠ Model {runtime_model} at {endpoint} returned status {response.status_code}: {response.text[:200]}")
            except requests.exceptions.Timeout:
                resolved_name = self._resolve_runtime_model_name(endpoint, model, timeout=10)
                if resolved_name:
                    self.model_runtime_names[model] = resolved_name
                    runtime_model = resolved_name
                self.log(f"⚠ Timeout for model {model} at {endpoint}; retrying with fallback token budget")
                try:
                    fallback_response = self._post_generate(
                        endpoint=endpoint,
                        runtime_model=runtime_model,
                        prompt=prompt,
                        max_tokens=self.fallback_max_tokens,
                        timeout_seconds=min(self.request_timeout_seconds, 1800),
                    )
                    if fallback_response.status_code == 200:
                        result = fallback_response.json().get('response', '')
                        if result:
                            self._archive_generation_response(runtime_model, language, prompt, result)
                            idea = self.parse_idea(result, language)
                            if idea:
                                return idea
                except Exception as fallback_err:
                    self.log(f"⚠ Fallback generation failed for {model} at {endpoint}: {fallback_err}")
            except requests.exceptions.ConnectionError:
                self.log(f"⚠ Connection error for model {model} at {endpoint}, trying next")
            except Exception as e:
                self.log(f"⚠ Error with model {model} at {endpoint}: {str(e)}, trying next")
        
        self.log("✗ Failed to generate idea from all models")
        return None

    def fetch_web_idea(self):
        # Define multiple API sources
        sources = [
            {
                "name": "github",
                "url": "https://api.github.com/search/repositories?q=language:python&sort=stars&order=desc&per_page=20",
                "parser": self._parse_github_response
            },
            {
                "name": "gitlab",
                "url": "https://gitlab.com/api/v4/projects?order_by=stars&sort=desc&per_page=20",
                "parser": self._parse_gitlab_response
            },
            {
                "name": "libraries.io",
                "url": "https://libraries.io/api/search?q=&platforms=pypi&sort=stars&per_page=20",
                "parser": self._parse_librariesio_response
            },
            {
                "name": "bitbucket",
                "url": "https://api.bitbucket.org/2.0/repositories?q=language=\"python\"&sort=-updated_on&pagelen=20",
                "parser": self._parse_bitbucket_response
            }
        ]
        
        # Try sources in random order
        random.shuffle(sources)
        
        for source in sources:
            try:
                self.log(f"Fetching from {source['name']}...")
                response = requests.get(source["url"], timeout=15)
                
                if response.status_code == 200:
                    idea = source["parser"](response.json(), source["name"])
                    if idea:
                        return idea
                else:
                    self.log(f"⚠ {source['name']} returned status {response.status_code}")
            except requests.exceptions.Timeout:
                self.log(f"⚠ Timeout fetching from {source['name']}")
            except Exception as e:
                self.log(f"⚠ Error with {source['name']}: {str(e)}")
        
        self.log("✗ Failed to fetch ideas from all sources")
        return None
    
    def _parse_github_response(self, data, source_name):
        """Parse GitHub API response"""
        repos = data.get('items', [])
        if not repos:
            return None
        
        available_repos = [r for r in repos if r['id'] not in self.web_ideas_used]
        if not available_repos:
            self.web_ideas_used = []
            available_repos = repos
        
        repo = random.choice(available_repos)
