class _HeadlessRoot:
    def __init__(self):
        self._stop = threading.Event()

    def title(self, *args, **kwargs):
        return None

    def geometry(self, *args, **kwargs):
        return None

    def protocol(self, *args, **kwargs):
        return None

    def after(self, delay_ms, callback=None, *args):
        if callback is None:
            return None
        if delay_ms <= 0:
            return callback(*args)
        timer = threading.Timer(float(delay_ms) / 1000.0, callback, args=args)
        timer.daemon = True
        timer.start()
        return timer

    def mainloop(self):
        while not self._stop.wait(1.0):
            pass

    def destroy(self):
        self._stop.set()

    def quit(self):
        self._stop.set()

