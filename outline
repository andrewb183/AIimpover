    @staticmethod
    def _normalize_endpoint(endpoint):
        if isinstance(endpoint, list):
            return endpoint[0] if endpoint else ""
        return endpoint or ""

    def _normalize_model_endpoints(self, endpoints):
        normalized = {}
        if not isinstance(endpoints, dict):
            return normalized
        for model_name, endpoint in endpoints.items():
            value = self._normalize_endpoint(endpoint)
            if value:
                normalized[model_name] = value
        return normalized

