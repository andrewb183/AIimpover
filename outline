    def parse_idea(self, response, language):
        lines = response.split('\n')
        title = ""
        description = ""
        code = ""
        in_code = False
        backtick_count = 0
        
        for line in lines:
            if line.startswith("Title:"):
                title = line[6:].strip()
            elif line.startswith("Description:"):
                description = line[12:].strip()
            elif line.startswith("Code:"):
                in_code = True
            elif in_code:
                if line.strip().startswith("```"):
                    backtick_count += 1
                    if backtick_count == 2:
                        break
                else:
                    code += line + '\n'
        
        if title and (description or code):
            return {
                "title": title,
                "description": description,
                "code": code.strip(),
                "language": language,
                "timestamp": time.time()
            }

        # Fallback parser: tolerate looser model formats and markdown-only responses.
        title_match = re.search(r'^Title:\s*(.+)$', response, flags=re.IGNORECASE | re.MULTILINE)
        if title_match:
            title = title_match.group(1).strip().strip('"')

        desc_match = re.search(r'^Description:\s*(.*)$', response, flags=re.IGNORECASE | re.MULTILINE)
        if desc_match:
            description = desc_match.group(1).strip()

        code_match = re.search(r'```[a-zA-Z0-9_+#-]*\n(.*?)```', response, flags=re.DOTALL)
        if code_match:
            code = code_match.group(1).strip()

        if not title:
            for line in lines:
                stripped = line.strip()
                if stripped and not stripped.startswith('```'):
                    title = stripped[:80]
                    break

        if not description and title:
            description = "Auto-parsed idea from model output."

        if title and (description or code):
            if not code:
                code = f"# Auto-generated fallback snippet for {title}\nprint('Idea generated')"
            return {
                "title": title,
                "description": description,
                "code": code.strip(),
                "language": language,
                "timestamp": time.time()
            }
        
        return None


    def save_idea(self, idea):
        ideas_file = os.path.join(os.path.dirname(__file__), "ideas_log.json")
        queue_key = self.queue_key
        ideas = []

        # Disk space check (10MB minimum)
        if shutil.disk_usage(os.path.dirname(ideas_file)).free < 10 * 1024 * 1024:
            self.log('Low disk space, skipping idea save')
            return

        # Use file locking to prevent concurrent corruption
        lock_file = ideas_file + '.lock'
        try:
            with open(lock_file, 'w') as lock_f:
                fcntl.flock(lock_f.fileno(), fcntl.LOCK_EX)  # Exclusive lock
                try:
                    # Read existing ideas with lock held
                    if os.path.exists(ideas_file) and os.path.getsize(ideas_file) > 0:
                        try:
                            with open(ideas_file, 'r') as f:
                                ideas = json.load(f)
                        except json.JSONDecodeError as e:
                            self.log(f"⚠ ideas_log.json corrupted, resetting: {e}")
                            ideas = []
                        except Exception as e:
                            self.log(f"⚠ Could not read ideas_log.json, continuing: {e}")
                    
                    # Append new idea
                    ideas.append(idea)
                    
                    # Atomic write with lock held
                    temp_name = None
                    try:
                        with NamedTemporaryFile('w', dir=os.path.dirname(ideas_file), delete=False, suffix='.tmp') as tmp:
                            json.dump(ideas, tmp, indent=2)
                            tmp.flush()
                            os.fsync(tmp.fileno())
                            temp_name = tmp.name
                        
                        try:
                            os.replace(temp_name, ideas_file)
                            self.log("✓ Idea saved to ideas_log.json")
                        except OSError as replace_err:
                            # Fallback for bind-mount EBUSY errors
                            if getattr(replace_err, 'errno', None) == 16 or 'resource busy' in str(replace_err).lower():
                                with open(ideas_file, 'w') as f:
                                    json.dump(ideas, f, indent=2)
                                self.log("✓ Idea saved to ideas_log.json (fallback write)")
                            else:
                                raise
                    finally:
                        if temp_name and os.path.exists(temp_name):
                            try:
                                os.unlink(temp_name)
                            except Exception:
                                pass
                finally:
                    fcntl.flock(lock_f.fileno(), fcntl.LOCK_UN)  # Release lock
        except Exception as e:
            self.log(f"⚠ Error saving idea to file (continuing with queue publish): {e}")

        # Redis publish (runs even if file save fails)
        if self.redis_client:
            try:
                self.redis_client.lpush(queue_key, json.dumps(idea))
                self.log(f"✓ Idea published to Redis queue: {queue_key}")
            except Exception as redis_err:
                self.log(f"⚠ Redis publish failed: {redis_err}")
        else:
            self.log("⚠ Redis client unavailable; handoff skipped")

        # Postgres INSERT (best effort)
        if POSTGRES_AVAILABLE and self.pg_host:
            try:
                if psycopg2 is None:
                    raise RuntimeError("psycopg2 module unavailable")
                conn = psycopg2.connect(
                    host=self.pg_host, user=self.pg_user,
                    password=self.pg_pass, database=self.pg_db,
                    connect_timeout=5
                )
                cursor = conn.cursor()
                
                # Generate unique idea_id if not present
                idea_id = idea.get('id') or str(uuid.uuid4())
                
                cursor.execute("""
                    INSERT INTO ideas_queue (idea_id, title, description, language, sample_code, status, attempts)
                    VALUES (%s, %s, %s, %s, %s, 'pending', 0)
                    ON CONFLICT (idea_id) DO NOTHING
                """, (
                    idea_id,
                    idea.get('title', ''),
                    idea.get('description', ''),
                    idea.get('language', 'Python'),
                    idea.get('code', '')
                ))
                
                conn.commit()
                cursor.close()
                conn.close()
                self.log(f"✓ Idea saved to Postgres (idea_id: {idea_id[:8]}...)")
            except Exception as pg_err:
                self.log(f"⚠ Postgres INSERT failed: {pg_err}")
        
        # 3) Best-effort worker check
        try:
            self.ensure_worker2_running()
        except Exception as worker_err:
            self.log(f"⚠ Worker check failed: {worker_err}")
    
    def load_ideas_log(self):
        ideas_file = os.path.join(os.path.dirname(__file__), "ideas_log.json")
        lock_file = ideas_file + '.lock'
        try:
            # Use file locking to prevent reading corrupted data
            with open(lock_file, 'w') as lock_f:
                fcntl.flock(lock_f.fileno(), fcntl.LOCK_SH)  # Shared lock (read)
                try:
                    if os.path.exists(ideas_file) and os.path.getsize(ideas_file) > 0:
                        try:
                            with open(ideas_file, 'r') as f:
                                ideas = json.load(f)
                            self.log(f"Loaded {len(ideas)} ideas from history (showing last 5)")
                            for idea in ideas[-5:]:
                                raw_ts = idea.get('timestamp')
                                if isinstance(raw_ts, (int, float)):
                                    timestamp = datetime.fromtimestamp(raw_ts).strftime("%Y-%m-%d %H:%M:%S")
                                else:
                                    timestamp = "unknown-time"
                                self.log(f"  • {idea['title']} ({timestamp})")
                        except json.JSONDecodeError:
                            # Corrupted file: reset it on next write (don't log to spam)
                            self.log("⚠ ideas_log.json corrupted on startup (will rebuild from Redis)")
                    else:
                        self.log("No ideas history found (file empty or missing)")
                finally:
                    fcntl.flock(lock_f.fileno(), fcntl.LOCK_UN)
        except Exception as e:
            # File lock errors don't prevent startup
            if "corrupt" not in str(e).lower():
                self.log(f"⚠ Error loading ideas log: {str(e)}")

    def check_popup_queue(self):
        try:
            while True:
                idea = self.idea_queue.get_nowait()
                # Skip if already shown
                idea_title = idea.get('title', '')
                if idea_title not in self.shown_ideas:
                    self.shown_ideas.add(idea_title)
                    self.show_popup(idea)
                else:
                    self.log(f"⏭️ Skipping duplicate idea: {idea_title}")
        except queue.Empty:
            pass
        self.root.after(1000, self.check_popup_queue)

    def load_ideas_from_file(self):
        file_path = filedialog.askopenfilename(
            filetypes=[("Text files", "*.txt"), ("JSON files", "*.json")]
        )
        if not file_path:
            return
        
        try:
            with open(file_path, 'r') as f:
                if file_path.endswith('.json'):
                    self.loaded_ideas = json.load(f)
                    if not isinstance(self.loaded_ideas, list):
                        self.loaded_ideas = [self.loaded_ideas]
                else:
                    content = f.read()
                    blocks = content.split('---')
                    self.loaded_ideas = []
                    for block in blocks:
                        if block.strip():
                            idea = self.parse_idea(block.strip(), "Python")
                            if idea:
                                self.loaded_ideas.append(idea)
            
            for idea in self.loaded_ideas:
                if 'language' not in idea:
                    idea['language'] = 'Python'
            
            self.log(f"✓ Loaded {len(self.loaded_ideas)} ideas from file")
        except Exception as e:
            messagebox.showerror("Error", f"Failed to load file: {str(e)}")
            self.log(f"✗ Failed to load file: {str(e)}")

