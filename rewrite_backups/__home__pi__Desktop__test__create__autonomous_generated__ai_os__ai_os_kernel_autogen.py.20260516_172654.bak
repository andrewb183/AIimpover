        hints.append("docker swarm service skynetv2_email-reporter logs show 79 error signatures")
        hints.append("docker swarm service skynetv2_email-reporter logs show 98 error signatures")
        hints.append("docker swarm service skynetv2_email-reporter logs show 82 error signatures")
        hints.append("docker swarm service skynetv2_email-reporter logs show 84 error signatures")
        return hints

